---
// DiagnosticSection.astro
// "Are You Telling The Right Story?" — diagnostic section for home page
// Full-bleed dark panel with three prism-colored diagnostic cards and atmospheric glow.
---
 
<section class="diagnostic-section">
  <div class="diagnostic-inner">
 
    <p class="diagnostic-eyebrow">A Diagnostic</p>
 
    <h2 class="diagnostic-headline">
      Are You Telling<br/>
      The <span class="gold">Right</span> Story?
    </h2>
 
    <p class="diagnostic-subtitle">Most films get made. Few move the needle.</p>
 
    <div class="diagnostic-cards">
 
      <article class="diagnostic-card card-people">
        <div class="card-number">01</div>
        <p class="card-headline">If your team's video felt flat the moment it shipped…</p>
        <p class="card-body">The brief was met. The visuals were polished. Nothing moved.</p>
      </article>
 
      <article class="diagnostic-card card-immersion">
        <div class="card-number">02</div>
        <p class="card-headline">If the story is there, but every attempt to tell it looks like everyone else's…</p>
        <p class="card-body">The insight. The turning point. The truth that matters. It's there. It's not landing.</p>
      </article>
 
      <article class="diagnostic-card card-moments">
        <div class="card-number">03</div>
        <p class="card-headline">If you need a film that does something, not just exists…</p>
        <p class="card-body">Drive donations. Recruit talent. Win board approval. The film isn't the goal. The outcome is.</p>
      </article>
 
    </div>
 
    <div class="diagnostic-footer">
      <p class="diagnostic-tagline">Most agencies sell production. PRISM finds the story first.</p>
    </div>
 
  </div>
</section>
 
<style>
  .diagnostic-section {
    background: var(--color-bg-mid);
    padding: 6rem 2rem;
    position: relative;
    overflow: hidden;
  }
 
  /* Subtle gold hairline rules at top & bottom of panel — matches Process page treatment */
  .diagnostic-section::before,
  .diagnostic-section::after {
    content: '';
    position: absolute;
    left: 20%;
    right: 20%;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(232, 197, 116, 0.35), transparent);
    pointer-events: none;
  }
  .diagnostic-section::before { top: 0; }
  .diagnostic-section::after { bottom: 0; }
 
  .diagnostic-inner {
    max-width: 1100px;
    margin: 0 auto;
    text-align: center;
  }
 
  .diagnostic-eyebrow {
    font-family: var(--font-wordmark, system-ui);
    font-size: 0.75rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin: 0 0 1.5rem;
    font-weight: 400;
  }
 
  .diagnostic-headline {
    font-family: var(--font-sans);
    font-weight: 300;
    font-size: clamp(2.25rem, 6.5vw, 4.5rem);
    line-height: 1.1;
    letter-spacing: -0.025em;
    color: var(--color-text-primary);
    margin: 0 0 1rem;
    text-wrap: balance;
  }
 
  .diagnostic-headline .gold {
    color: var(--color-accent);
    font-weight: 400;
  }
 
  .diagnostic-subtitle {
    font-family: var(--font-sans);
    font-size: clamp(1rem, 1.5vw, 1.15rem);
    color: var(--color-text-muted);
    font-style: italic;
    font-weight: 300;
    margin: 0 0 3.5rem;
  }
 
  /* ============ CARDS ============ */
  .diagnostic-cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    margin-bottom: 3.5rem;
  }
 
  .diagnostic-card {
    position: relative;
    border-radius: 4px;
    padding: 1.75rem 1.35rem;
    text-align: left;
    transition: transform 0.5s ease, border-color 0.4s ease;
    isolation: isolate;
  }
 
  /* Atmospheric glow — sits behind card, intensifies on hover */
  .diagnostic-card::before {
    content: '';
    position: absolute;
    inset: -25px;
    z-index: -1;
    border-radius: 50%;
    filter: blur(35px);
    opacity: 0.35;
    transition: opacity 0.6s ease, transform 0.6s ease;
    will-change: opacity, transform;
  }
 
  .diagnostic-card:hover {
    transform: translateY(-4px);
  }
 
  .diagnostic-card:hover::before {
    opacity: 0.9;
    transform: scale(1.15);
  }
 
  /* People (coral) — card 01 */
  .card-people {
    background: rgba(212, 117, 111, 0.06);
    border: 1px solid rgba(212, 117, 111, 0.4);
  }
  .card-people::before {
    background: radial-gradient(circle, rgba(212, 117, 111, 0.5), transparent 70%);
  }
  .card-people .card-number {
    color: rgba(212, 117, 111, 1);
  }
  .card-people:hover {
    border-color: rgba(212, 117, 111, 0.75);
  }
 
  /* Immersion (green) — card 02 */
  .card-immersion {
    background: rgba(163, 188, 126, 0.06);
    border: 1px solid rgba(163, 188, 126, 0.4);
  }
  .card-immersion::before {
    background: radial-gradient(circle, rgba(163, 188, 126, 0.5), transparent 70%);
  }
  .card-immersion .card-number {
    color: rgba(163, 188, 126, 1);
  }
  .card-immersion:hover {
    border-color: rgba(163, 188, 126, 0.75);
  }
 
  /* Moments (purple) — card 03 */
  .card-moments {
    background: rgba(165, 131, 181, 0.06);
    border: 1px solid rgba(165, 131, 181, 0.4);
  }
  .card-moments::before {
    background: radial-gradient(circle, rgba(165, 131, 181, 0.5), transparent 70%);
  }
  .card-moments .card-number {
    color: rgba(165, 131, 181, 1);
  }
  .card-moments:hover {
    border-color: rgba(165, 131, 181, 0.75);
  }
 
  .card-number {
    font-family: var(--font-wordmark, system-ui);
    font-size: 0.7rem;
    letter-spacing: 0.18em;
    font-weight: 500;
    margin: 0 0 1rem;
  }
 
  .card-headline {
    font-family: var(--font-sans);
    font-size: 0.95rem;
    font-weight: 400;
    line-height: 1.5;
    color: rgba(248, 250, 252, 0.95);
    margin: 0 0 0.75rem;
  }
 
  .card-body {
    font-family: var(--font-sans);
    font-size: 0.875rem;
    font-weight: 300;
    line-height: 1.65;
    color: rgba(248, 250, 252, 0.6);
    margin: 0;
    text-wrap: pretty;
  }
 
  /* ============ FOOTER (tagline + CTA) ============ */
  .diagnostic-tagline {
    font-family: var(--font-sans);
    font-size: clamp(0.95rem, 1.3vw, 1.1rem);
    color: rgba(248, 250, 252, 0.8);
    font-style: italic;
    font-weight: 300;
    margin: 0 0 1.75rem;
  }
 
  .diagnostic-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.95rem 1.75rem;
    background: color-mix(in srgb, var(--color-accent) 10%, transparent);
    border: 1px solid var(--color-accent);
    border-radius: 2px;
    color: var(--color-accent);
    font-family: var(--font-wordmark, system-ui);
    font-size: 0.78rem;
    font-weight: 400;
    letter-spacing: 0.15em;
    text-decoration: none;
    text-transform: uppercase;
    transition: all 0.3s ease;
  }
 
  .diagnostic-cta:hover {
    background: color-mix(in srgb, var(--color-accent) 20%, transparent);
    transform: translateY(-1px);
  }
 
  .cta-arrow {
    font-size: 1rem;
    transition: transform 0.3s ease;
  }
 
  .diagnostic-cta:hover .cta-arrow {
    transform: translateX(3px);
  }
 
  /* ============ MOBILE ============ */
  @media (max-width: 900px) {
    .diagnostic-section {
      padding: 4rem 1.25rem;
    }
 
    .diagnostic-section::before,
    .diagnostic-section::after {
      left: 10%;
      right: 10%;
    }
 
    .diagnostic-headline {
      font-size: clamp(1.9rem, 9vw, 2.75rem);
      line-height: 1.15;
    }
 
    .diagnostic-subtitle {
      margin-bottom: 2.5rem;
    }
 
    .diagnostic-cards {
      grid-template-columns: 1fr;
      gap: 1.25rem;
      margin-bottom: 2.5rem;
    }
 
    .diagnostic-card {
      padding: 1.5rem 1.25rem;
    }
 
    /* Slightly more visible glow on mobile since no hover state */
    .diagnostic-card::before {
      opacity: 0.5;
    }
  }
</style>
 
