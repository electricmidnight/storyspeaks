---
import BrandMark from './BrandMark.astro';

const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';
const isHome = currentPath === '/';

const activeSection =
  isHome ? 'home' :
  currentPath.startsWith('/process') ? 'process' :
  currentPath.startsWith('/work') ? 'work' :
  currentPath.startsWith('/about') ? 'about' :
  currentPath.startsWith('/contact') ? 'contact' : '';
---

<nav class="site-nav site-nav--desktop" aria-label="Primary">
  <div class="site-nav__container">
    <div class={`site-nav__controller ${!isHome ? 'navigated' : ''}`}>

      <div class={`nav-link-container home-link ${activeSection === 'home' ? 'is-current' : ''}`}>
        <div class="nav-link-wrapper">
          <a href="/" class="nav-link-button">Home</a>
          <a href="/" class="nav-link-button-hover" aria-hidden="true">Home</a>
        </div>
      </div>

      <div class={`nav-link-container ${activeSection === 'process' ? 'active' : ''}`}>
        <div class="nav-link-wrapper">
          <a href="/process/" class="nav-link-button">Process</a>
          <a href="/process/" class="nav-link-button-hover" aria-hidden="true">Process</a>
          {activeSection === 'process' && <a href="/" class="nav-close-btn" aria-label="Return to home"></a>}
        </div>
      </div>

      <div class={`nav-link-container ${activeSection === 'work' ? 'active' : ''}`}>
        <div class="nav-link-wrapper">
          <a href="/work/" class="nav-link-button">Work</a>
          <a href="/work/" class="nav-link-button-hover" aria-hidden="true">Work</a>
          {activeSection === 'work' && <a href="/" class="nav-close-btn" aria-label="Return to home"></a>}
        </div>
      </div>

      <a href="/" class="logo-container" aria-label="The Story Speaks — home">
        <BrandMark variant="on-dark" size="sm" showWordmark={true} />
      </a>

      <div class={`nav-link-container ${activeSection === 'about' ? 'active' : ''}`}>
        <div class="nav-link-wrapper">
          <a href="/about/" class="nav-link-button">About</a>
          <a href="/about/" class="nav-link-button-hover" aria-hidden="true">About</a>
          {activeSection === 'about' && <a href="/" class="nav-close-btn" aria-label="Return to home"></a>}
        </div>
      </div>

      <div class={`nav-link-container ${activeSection === 'contact' ? 'active' : ''}`}>
        <div class="nav-link-wrapper">
          <a href="/contact/" class="nav-link-button">Contact</a>
          <a href="/contact/" class="nav-link-button-hover" aria-hidden="true">Contact</a>
          {activeSection === 'contact' && <a href="/" class="nav-close-btn" aria-label="Return to home"></a>}
        </div>
      </div>

    </div>
  </div>
</nav>

<nav class="site-nav site-nav--mobile" aria-label="Primary mobile">
  <div class="mobile-header">
    <a href="/" class="mobile-logo-link" aria-label="The Story Speaks — home">
      <BrandMark variant="on-dark" size="sm" showWordmark={true} />
    </a>
  </div>
</nav>

<button class="hamburger" id="hamburger" aria-label="Open menu" aria-expanded="false">
  <span class="hamburger-line"></span>
  <span class="hamburger-line"></span>
  <span class="hamburger-line"></span>
</button>

<div class="mobile-menu" id="mobileMenu">
  <a href="/" class={`mobile-nav-link ${activeSection === 'home' ? 'active' : ''}`}>Home</a>
  <a href="/process/" class={`mobile-nav-link ${activeSection === 'process' ? 'active' : ''}`}>Process</a>
  <a href="/work/" class={`mobile-nav-link ${activeSection === 'work' ? 'active' : ''}`}>Work</a>
  <a href="/about/" class={`mobile-nav-link ${activeSection === 'about' ? 'active' : ''}`}>About</a>
  <a href="/contact/" class={`mobile-nav-link ${activeSection === 'contact' ? 'active' : ''}`}>Contact</a>
</div>

<style>
  .site-nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 1000;
    background: rgba(10, 22, 40, 0.85);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
  }
  .site-nav--desktop { display: block; }
  .site-nav--mobile { display: none; }

  .site-nav__container {
    display: flex;
    align-items: center;
    justify-content: center;
    max-width: 1400px;
    margin: 0 auto;
    padding: 22px 30px 18px;
  }

  .site-nav__controller {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 45px;
    width: 100%;
    transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .nav-link-container {
    position: relative;
    overflow: hidden;
    height: 24px;
    cursor: pointer;
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .nav-link-container.home-link {
    width: 0;
    opacity: 0;
    overflow: hidden;
    margin-right: -50px;
    transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .site-nav__controller.navigated .nav-link-container.home-link {
    width: auto;
    opacity: 1;
    margin-right: 0;
  }

  .nav-link-container.active {
    overflow: visible;
    height: auto;
  }
  .nav-link-container.active .nav-link-wrapper {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 8px 12px;
    border: 1px solid var(--color-accent);
    background: rgba(232, 197, 116, 0.08);
  }

  .nav-link-wrapper {
    display: flex;
    align-items: center;
    position: relative;
  }

  .nav-link-button,
  .nav-link-button-hover {
    display: block;
    font-family: var(--font-wordmark);
    font-size: 15px;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    text-decoration: none;
    white-space: nowrap;
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.4s ease;
  }
  .nav-link-button { color: #fff; }
  .nav-link-button-hover {
    position: absolute;
    top: 0; left: 0;
    color: var(--color-accent);
    transform: translateY(100%);
  }

  .nav-link-container:not(.active):hover .nav-link-button {
    transform: translateY(-100%);
    opacity: 0;
  }
  .nav-link-container:not(.active):hover .nav-link-button-hover {
    transform: translateY(0);
  }
  .nav-link-container.active .nav-link-button {
    color: var(--color-accent);
    transform: none;
  }
  .nav-link-container.active .nav-link-button-hover { display: none; }

  .nav-close-btn {
    display: inline-block;
    width: 18px;
    height: 18px;
    position: relative;
    cursor: pointer;
    opacity: 0.7;
    transition: opacity 0.3s ease;
    flex-shrink: 0;
  }
  .nav-close-btn:hover { opacity: 1; }
  .nav-close-btn::before,
  .nav-close-btn::after {
    content: '';
    position: absolute;
    top: 50%; left: 50%;
    width: 14px;
    height: 1.5px;
    background: var(--color-accent);
  }
  .nav-close-btn::before { transform: translate(-50%, -50%) rotate(45deg); }
  .nav-close-btn::after  { transform: translate(-50%, -50%) rotate(-45deg); }

  .logo-container {
    display: flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1);
    opacity: 1;
    width: auto;
    overflow: visible;
    cursor: pointer;
  }
  .site-nav__controller.navigated .logo-container {
    opacity: 0;
    width: 0;
    margin: 0 -22.5px;
    overflow: hidden;
  }
  .logo-container:hover { opacity: 0.85; }

  /* Hamburger and mobile menu are now siblings of .site-nav, not children — so they're not trapped by backdrop-filter */
  .hamburger { display: none; }
  .mobile-menu { display: none; }

  /* ============ MOBILE BREAKPOINT ============ */
  @media (max-width: 991px) {
    .site-nav--desktop { display: none; }
    .site-nav--mobile  { display: block; padding: 0; }

    .mobile-header {
      display: flex;
      align-items: center;
      justify-content: flex-start;
      padding: 15px 20px 12px;
    }

    .hamburger {
      position: fixed;
      top: 14px;
      right: 20px;
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      width: 40px; height: 40px;
      background: transparent;
      border: none;
      cursor: pointer;
      z-index: 1002;
      padding: 0;
    }
    .hamburger-line {
      width: 28px; height: 2px;
      background: #fff;
      margin: 4px 0;
      transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
      transform-origin: center;
    }
    .hamburger.open .hamburger-line:nth-child(1) { transform: rotate(45deg) translate(6px, 6px); }
    .hamburger.open .hamburger-line:nth-child(2) { opacity: 0; transform: translateX(-20px); }
    .hamburger.open .hamburger-line:nth-child(3) { transform: rotate(-
