---
// FilmTeaserSection.astro
// Outcome-first home page section. Lives between PrismTeaserSection and the next section.
// Leads with display headline of outcomes, three film stills as supporting evidence, CTA to /work/.
---
 
<section class="film-teaser-section">
  <div class="ft-inner">
 
    <p class="ft-eyebrow">The Work</p>
 
    <h2 class="ft-headline">
      Five Emmys.<br/>
      <span class="gold">National PBS.</span><br/>
      A film festival.<br/>
      <span class="gold">A symphony.</span>
    </h2>
 
    <p class="ft-tagline">The outcomes of strategic storytelling.</p>
 
    <div class="ft-films">
      <a href="/work" class="ft-film" aria-label="Healthcare film: Acts of Kindness — view all films">
        <div class="ft-film-image ft-film-healthcare"></div>
        <p class="ft-film-label">Healthcare · <span>Acts of Kindness</span></p>
      </a>
      <a href="/work" class="ft-film" aria-label="Nonprofit film: The Shadow Between Us — view all films">
        <div class="ft-film-image ft-film-nonprofit"></div>
        <p class="ft-film-label">Nonprofit · <span>The Shadow Between Us</span></p>
      </a>
      <a href="/work" class="ft-film" aria-label="Corporate film: The Soundtrack Project — view all films">
        <div class="ft-film-image ft-film-corporate"></div>
        <p class="ft-film-label">Corporate · <span>The Soundtrack Project</span></p>
      </a>
    </div>
 
    <div class="ft-cta-wrapper">
      <a href="/work" class="ft-cta">
        <span>See the Films</span>
        <span class="ft-cta-arrow">→</span>
      </a>
    </div>
 
  </div>
</section>
 
<style>
  .film-teaser-section {
    background: var(--color-bg-mid, #0d1b32);
    padding: 6rem 2rem;
    position: relative;
    overflow: hidden;
  }
 
  /* Subtle gold hairline rules top & bottom */
  .film-teaser-section::before,
  .film-teaser-section::after {
    content: '';
    position: absolute;
    left: 20%;
    right: 20%;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(232, 197, 116, 0.25), transparent);
    pointer-events: none;
  }
  .film-teaser-section::before { top: 0; }
  .film-teaser-section::after { bottom: 0; }
 
  .ft-inner {
    max-width: 920px;
    margin: 0 auto;
    text-align: center;
  }
 
  .ft-eyebrow {
    font-family: var(--font-wordmark, system-ui);
    font-size: 0.75rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-accent, #e8c574);
    margin: 0 0 1.5rem;
    font-weight: 400;
  }
 
  .ft-headline {
    font-family: var(--font-sans, system-ui);
    font-weight: 300;
    font-size: clamp(2.25rem, 5.5vw, 4rem);
    line-height: 1.05;
    letter-spacing: -0.03em;
    color: var(--color-text-primary, #f8fafc);
    margin: 0 0 1rem;
  }
 
  .ft-headline .gold {
    color: var(--color-accent, #e8c574);
    font-weight: 400;
  }
 
  .ft-tagline {
    font-family: var(--font-sans, system-ui);
    font-size: clamp(1rem, 1.5vw, 1.15rem);
    color: rgba(248, 250, 252, 0.65);
    font-style: italic;
    font-weight: 300;
    margin: 0 0 3rem;
  }
 
  /* ============ FILMS ROW (supporting evidence) ============ */
  .ft-films {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
    max-width: 760px;
    margin: 0 auto 3rem;
  }
 
  .ft-film {
    text-decoration: none;
    color: inherit;
    display: block;
  }
 
  .ft-film-image {
    width: 100%;
    aspect-ratio: 16 / 9;
    background-size: cover;
    background-position: center;
    border-radius: 3px;
    opacity: 0.78;
    transition: opacity 0.4s ease, transform 0.4s ease;
    border: 1px solid rgba(232, 197, 116, 0.18);
  }
 
  .ft-film:hover .ft-film-image {
    opacity: 1;
    transform: translateY(-3px);
    border-color: rgba(232, 197, 116, 0.45);
  }
 
  .ft-film-healthcare {
    background-image: url('/images/geisinger-acts-of-kindness.jpg');
    background-color: #2a1810;
  }
 
  .ft-film-nonprofit {
    background-image: url('/images/shadow-between-us-poster.jpg');
    background-color: #0a1a2a;
  }
 
  .ft-film-corporate {
    background-image: url('/images/soundtrack-project-poster.jpg');
    background-color: #1a2010;
  }
 
  .ft-film-label {
    font-family: var(--font-sans, system-ui);
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(232, 197, 116, 0.85);
    margin: 0.85rem 0 0;
    font-weight: 500;
    transition: color 0.3s ease;
  }
 
  .ft-film-label span {
    color: rgba(248, 250, 252, 0.75);
    font-weight: 300;
    text-transform: none;
    letter-spacing: 0.02em;
  }
 
  .ft-film:hover .ft-film-label {
    color: var(--color-accent, #e8c574);
  }
 
  /* ============ CTA ============ */
  .ft-cta-wrapper {
    text-align: center;
  }
 
  .ft-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.95rem 1.75rem;
    background: color-mix(in srgb, var(--color-accent, #e8c574) 10%, transparent);
    border: 1px solid var(--color-accent, #e8c574);
    border-radius: 2px;
    color: var(--color-accent, #e8c574);
    font-family: var(--font-wordmark, system-ui);
    font-size: 0.78rem;
    font-weight: 400;
    letter-spacing: 0.15em;
    text-decoration: none;
    text-transform: uppercase;
    transition: all 0.3s ease;
  }
 
  .ft-cta:hover {
    background: color-mix(in srgb, var(--color-accent, #e8c574) 20%, transparent);
    transform: translateY(-1px);
  }
 
  .ft-cta-arrow {
    font-size: 1rem;
    transition: transform 0.3s ease;
  }
 
  .ft-cta:hover .ft-cta-arrow {
    transform: translateX(3px);
  }
 
  /* ============ MOBILE ============ */
  @media (max-width: 900px) {
    .film-teaser-section {
      padding: 4rem 1.25rem;
    }
 
    .film-teaser-section::before,
    .film-teaser-section::after {
      left: 10%;
      right: 10%;
    }
 
    .ft-headline {
      font-size: clamp(2rem, 9vw, 3rem);
      line-height: 1.1;
    }
 
    .ft-tagline {
      margin-bottom: 2.25rem;
    }
 
    .ft-films {
      gap: 0.75rem;
      margin-bottom: 2.25rem;
    }
 
    .ft-film-label {
      font-size: 0.6rem;
      letter-spacing: 0.08em;
      margin-top: 0.65rem;
    }
 
    .ft-film-label span {
      display: block;
      margin-top: 0.15rem;
    }
 
    /* Slightly more visible image opacity on mobile (no hover state) */
    .ft-film-image {
      opacity: 0.88;
    }
  }
 
  @media (max-width: 480px) {
    .ft-films {
      grid-template-columns: 1fr;
      max-width: 340px;
      gap: 1rem;
      margin-bottom: 2.5rem;
    }
 
    .ft-film-label {
      font-size: 0.7rem;
    }
 
    .ft-film-label span {
      display: inline;
      margin-top: 0;
    }
  }
</style>
 
