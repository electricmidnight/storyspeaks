---
// Hero.astro — opening section
---

<section class="hero">
  <div class="hero-inner">
    <div class="eyebrow">Boulder &middot; Denver &middot; The Rockies</div>
    <h1>
      Emmy-Winning Storytelling,<br />
      <em>Rooted in the Rockies</em>
    </h1>
    <p class="subhead">
      Handcrafted films full of heart and empathy &mdash; for nonprofits,
      hospitals, universities, scientific institutions, and brands that know
      story is everything.
    </p>
    <div class="cta-row">
      <a class="btn btn-primary" href="#films">See the Films</a>
      <a class="btn btn-secondary" href="#contact">Start a Conversation</a>
    </div>
    <div class="credentials">
      <span>5 Emmys</span>
      <span class="sep">&middot;</span>
      <span>TED Honored</span>
      <span class="sep">&middot;</span>
      <span>National Addys</span>
      <span class="sep">&middot;</span>
      <span>20+ Countries</span>
    </div>
  </div>
</section>

<style>
 .hero {
    background-color: var(--color-bg-deep);
    background-image:
      linear-gradient(
        135deg,
        rgba(10, 22, 40, 0.78) 0%,
        rgba(26, 47, 74, 0.62) 100%
      ),
      url('/hero-flatirons-winter.jpg');
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    min-height: 88vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 6rem 2rem;
    color: var(--color-text);
    text-align: center;
    position: relative;
  }
  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(
      ellipse at center,
      transparent 0%,
      rgba(0, 0, 0, 0.45) 100%
    );
    pointer-events: none;
  }

  .hero-inner {
    position: relative;
    z-index: 2;
    max-width: var(--hero-width);
    margin: 0 auto;
  }

  .hero h1 {
    font-size: clamp(2.25rem, 5.5vw, 4.75rem);
    line-height: 1.05;
    margin: 0 0 1.5rem 0;
    color: var(--color-text);
  }

  .hero h1 em {
    font-style: italic;
    color: var(--color-accent);
    font-weight: 300;
  }

  .subhead {
    font-size: clamp(1rem, 1.5vw, 1.2rem);
    line-height: 1.65;
    max-width: 680px;
    margin: 0 auto 2.5rem;
    opacity: 0.92;
    font-weight: 300;
  }

  .cta-row {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .credentials {
    margin-top: 3rem;
    font-size: 0.75rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    opacity: 0.75;
  }

  .credentials .sep {
    margin: 0 0.65rem;
    opacity: 0.5;
  }

  @media (max-width: 768px) {
    .hero {
      min-height: 78vh;
      padding: 4.5rem 1.5rem;
    }
    .cta-row {
      flex-direction: column;
      align-items: stretch;
    }
    .credentials {
      margin-top: 2.25rem;
      line-height: 2.1;
    }
  }
</style>
