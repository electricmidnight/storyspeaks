---
// FinalCTASection.astro
// Closing section of the home page. Final invitation to start a conversation.
---

<section class="final-cta-section">
  <div class="fc-inner">

    <p class="fc-eyebrow">Let's Begin</p>

    <h2 class="fc-headline">
      Have a story <span class="gold">worth telling?</span>
    </h2>

    <p class="fc-tagline">Let's find it together.</p>

    <div class="fc-cta-wrapper">
      <a href="/contact" class="fc-cta">
        <span>Start a Conversation</span>
        <span class="fc-cta-arrow">→</span>
      </a>
    </div>

  </div>
</section>

<style>
  .final-cta-section {
    background: var(--color-bg-deep, #0a1628);
    padding: 7rem 2rem;
    position: relative;
    overflow: hidden;
  }

  /* Subtle gold hairlines top & bottom (matches other home sections) */
  .final-cta-section::before,
  .final-cta-section::after {
    content: '';
    position: absolute;
    left: 20%;
    right: 20%;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(232, 197, 116, 0.25), transparent);
    pointer-events: none;
  }
  .final-cta-section::before { top: 0; }
  .final-cta-section::after { bottom: 0; }

  /* Atmospheric gold glow centered behind the headline */
  .final-cta-section .fc-inner::before {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 60%;
    height: 60%;
    background: radial-gradient(ellipse at center, rgba(232, 197, 116, 0.08), transparent 70%);
    pointer-events: none;
    z-index: 0;
  }

  .fc-inner {
    max-width: 820px;
    margin: 0 auto;
    text-align: center;
    position: relative;
  }

  .fc-inner > * {
    position: relative;
    z-index: 1;
  }

  .fc-eyebrow {
    font-family: var(--font-wordmark, system-ui);
    font-size: 0.75rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-accent, #e8c574);
    margin: 0 0 1.5rem;
    font-weight: 400;
  }

  .fc-headline {
    font-family: var(--font-sans, system-ui);
    font-weight: 300;
    font-size: clamp(2.25rem, 5.5vw, 4rem);
    line-height: 1.1;
    letter-spacing: -0.025em;
    color: var(--color-text-primary, #f8fafc);
    margin: 0 0 1.25rem;
    text-wrap: balance;
  }

  .fc-headline .gold {
    color: var(--color-accent, #e8c574);
    font-weight: 400;
  }

  .fc-tagline {
    font-family: var(--font-sans, system-ui);
    font-size: clamp(1.05rem, 1.6vw, 1.3rem);
    color: rgba(248, 250, 252, 0.75);
    font-style: italic;
    font-weight: 300;
    margin: 0 0 2.75rem;
  }

  .fc-cta-wrapper {
    text-align: center;
  }

  .fc-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.85rem;
    padding: 1.15rem 2.25rem;
    background: var(--color-accent, #e8c574);
    border: 1px solid var(--color-accent, #e8c574);
    border-radius: 2px;
    color: var(--color-bg-deep, #0a1628);
    font-family: var(--font-wordmark, system-ui);
    font-size: 0.9rem;
    font-weight: 500;
    letter-spacing: 0.15em;
    text-decoration: none;
    text-transform: uppercase;
    transition: all 0.3s ease;
    box-shadow: 0 8px 28px rgba(232, 197, 116, 0.25);
  }

  .fc-cta:hover {
    background: #f0d28d;
    border-color: #f0d28d;
    transform: translateY(-2px);
    box-shadow: 0 12px 40px rgba(232, 197, 116, 0.4);
  }

  .fc-cta-arrow {
    font-size: 1.1rem;
    transition: transform 0.3s ease;
  }

  .fc-cta:hover .fc-cta-arrow {
    transform: translateX(4px);
  }

  /* ============ MOBILE ============ */
  @media (max-width: 900px) {
    .final-cta-section {
      padding: 5rem 1.25rem;
    }

    .final-cta-section::before,
    .final-cta-section::after {
      left: 10%;
      right: 10%;
    }

    .fc-headline {
      font-size: clamp(2rem, 9vw, 2.75rem);
      line-height: 1.15;
    }

    .fc-tagline {
      margin-bottom: 2.25rem;
    }

    .fc-cta {
      padding: 1rem 1.75rem;
      font-size: 0.85rem;
    }
  }
</style>
