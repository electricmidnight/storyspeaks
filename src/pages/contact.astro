---
// contact.astro — Start a Conversation
// Hybrid contact page: B's structure with A's warmth woven through.
// Form submits via mailto for now; easy to swap to Formspree or Pages Functions later.
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Start a Conversation — The Story Speaks">

  <main class="contact-page">

    <section class="contact-hero">
      <p class="contact-eyebrow">Start a Conversation</p>
      <h1 class="contact-headline">Let's talk <span class="gold">story.</span></h1>
      <p class="contact-subtitle">No pitch. No pressure. Just a conversation.</p>
    </section>

    <section class="contact-letter">
      <p>
        The best films I've made started with a conversation, not a brief. Someone called and told me about a person, a place, or a problem they were trying to give voice to. We talked it through together.
      </p>
      <p>
        If you have a story you're trying to find &mdash; or one you can feel the shape of but can't quite tell &mdash; I'd love to hear about it.
      </p>
    </section>

    <section class="contact-fit">
      <div class="fit-card">
        <p class="fit-title">Best Fit</p>
        <p class="fit-text">
          Brand films, documentaries, and impact narratives for healthcare systems, research institutions, nonprofits, and brands where the story matters more than the spec sheet.
        </p>
      </div>
      <div class="fit-card">
        <p class="fit-title">Typical Timeline</p>
        <p class="fit-text">
          Most engagements run six weeks to six months. Budgets vary widely. Bring the project; we'll figure out the scope together.
        </p>
      </div>
    </section>

    <section class="contact-form-wrapper">
      <form class="contact-form" id="contactForm" method="post" action="mailto:Lance@thestoryspeaks.com" enctype="text/plain">

        <div class="form-row form-row-split">
          <div class="form-field">
            <label class="form-label" for="cf-name">Your Name</label>
            <input class="form-input" type="text" id="cf-name" name="Name" required autocomplete="name" />
          </div>
          <div class="form-field">
            <label class="form-label" for="cf-email">Email</label>
            <input class="form-input" type="email" id="cf-email" name="Email" required autocomplete="email" />
          </div>
        </div>

        <div class="form-field">
          <label class="form-label" for="cf-org">Organization</label>
          <input class="form-input" type="text" id="cf-org" name="Organization" placeholder="If applicable" autocomplete="organization" />
        </div>

        <div class="form-field">
          <label class="form-label" for="cf-project">What are you working on?</label>
          <input class="form-input" type="text" id="cf-project" name="Project" placeholder="Documentary, brand film, campaign &mdash; or not sure yet" />
        </div>

        <div class="form-field">
          <label class="form-label" for="cf-message">Tell me about the story</label>
          <textarea class="form-textarea" id="cf-message" name="Message" rows="5" placeholder="What are you trying to say? Who needs to hear it? What would success look like? &mdash; whatever you'd tell me if we were on the phone." required></textarea>
        </div>

        <div class="form-actions">
          <button type="submit" class="form-submit">
            <span>Send the Note</span>
            <span class="submit-arrow">&rarr;</span>
          </button>
        </div>

        <p class="form-status" id="cf-status" aria-live="polite"></p>

      </form>
    </section>

    <section class="contact-next">
      <p class="next-title">What Happens Next</p>
      <ol class="next-steps">
        <li class="next-step">
          <div class="step-num">1</div>
          <p class="step-text"><strong>I read it personally.</strong> Every inquiry. Usually within a day.</p>
        </li>
        <li class="next-step">
          <div class="step-num">2</div>
          <p class="step-text"><strong>You'll hear back within two business days</strong> with thoughts and questions.</p>
        </li>
        <li class="next-step">
          <div class="step-num">3</div>
          <p class="step-text"><strong>If there's a fit, we get on a 30-minute call.</strong> No pitch deck required.</p>
        </li>
      </ol>
    </section>

    <section class="contact-aside">
      <p class="aside-label">Prefer email?</p>
      <p class="aside-text">
        <a href="mailto:Lance@thestoryspeaks.com">Lance@thestoryspeaks.com</a>
      </p>
    </section>

  </main>

</BaseLayout>

<style>
  .contact-page {
    background: var(--color-bg-deep, #0a1628);
    color: var(--color-text-primary, #f8fafc);
    min-height: 100vh;
    padding: 0 2rem 5rem;
    position: relative;
  }

  /* Horizontal accent line under nav, matching the work page treatment */
  .contact-page::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg,
      transparent,
      rgba(232, 197, 116, 0.4) 20%,
      rgba(232, 197, 116, 0.4) 80%,
      transparent
    );
    pointer-events: none;
    z-index: 1;
  }

  /* ============ HERO HEADER ============ */
  .contact-hero {
    max-width: 720px;
    margin: 0 auto;
    padding: 6rem 0 2rem;
    text-align: center;
  }

  .contact-eyebrow {
    font-family: var(--font-wordmark, system-ui);
    font-size: 0.75rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-accent, #e8c574);
    margin: 0 0 1.5rem;
    font-weight: 400;
  }

  .contact-headline {
    font-family: var(--font-sans, system-ui);
    font-weight: 300;
    font-size: clamp(2.5rem, 6vw, 4rem);
    line-height: 1.05;
    letter-spacing: -0.025em;
    margin: 0 0 1rem;
  }

  .contact-headline .gold {
    color: var(--color-accent, #e8c574);
    font-weight: 400;
  }

  .contact-subtitle {
    font-family: var(--font-sans, system-ui);
    font-size: clamp(1.05rem, 1.6vw, 1.25rem);
    color: rgba(248, 250, 252, 0.75);
    font-style: italic;
    font-weight: 300;
    margin: 0;
  }

  /* ============ LETTER ============ */
  .contact-letter {
    max-width: 580px;
    margin: 0 auto 3rem;
    padding: 0 0.5rem;
  }

  .contact-letter p {
    font-family: var(--font-sans, system-ui);
    font-size: clamp(0.95rem, 1.3vw, 1.05rem);
    line-height: 1.8;
    color: rgba(248, 250, 252, 0.85);
    font-weight: 300;
    margin: 0 0 1.25rem;
    /* Prevent single-word orphans on the last line of each paragraph */
    text-wrap: pretty;
  }

  .contact-letter p:last-child {
    margin-bottom: 0;
  }

  /* ============ FIT CARDS ============ */
  .contact-fit {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
    max-width: 720px;
    margin: 0 auto 3rem;
  }

  .fit-card {
    padding: 1.25rem 1.5rem;
    border: 1px solid rgba(232, 197, 116, 0.22);
    border-radius: 3px;
    background: rgba(232, 197, 116, 0.025);
  }

  .fit-title {
    font-family: var(--font-wordmark, system-ui);
    font-size: 0.7rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-accent, #e8c574);
    font-weight: 500;
    margin: 0 0 0.65rem;
  }

  .fit-text {
    font-family: var(--font-sans, system-ui);
    font-size: 0.9rem;
    color: rgba(248, 250, 252, 0.8);
    margin: 0;
    font-weight: 300;
    line-height: 1.65;
    text-wrap: pretty;
  }

  /* ============ FORM ============ */
  .contact-form-wrapper {
    max-width: 560px;
    margin: 0 auto;
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.35rem;
  }

  .form-row-split {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    margin: 0;
  }

  .form-field {
    display: flex;
    flex-direction: column;
  }

  .form-label {
    font-family: var(--font-wordmark, system-ui);
    font-size: 0.68rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(232, 197, 116, 0.9);
    font-weight: 500;
    margin: 0 0 0.55rem;
  }

  .form-input,
  .form-textarea {
    width: 100%;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(232, 197, 116, 0.25);
    border-radius: 3px;
    padding: 0.8rem 1rem;
    color: var(--color-text-primary, #f8fafc);
    font-family: var(--font-sans, system-ui);
    font-size: 0.95rem;
    font-weight: 300;
    box-sizing: border-box;
    transition: border-color 0.3s ease, background 0.3s ease;
  }

  .form-textarea {
    min-height: 130px;
    resize: vertical;
    line-height: 1.6;
  }

  .form-input::placeholder,
  .form-textarea::placeholder {
    color: rgba(248, 250, 252, 0.4);
    font-style: italic;
  }

  .form-input:focus,
  .form-textarea:focus {
    outline: none;
    border-color: var(--color-accent, #e8c574);
    background: rgba(255, 255, 255, 0.06);
    box-shadow: 0 0 0 1px rgba(232, 197, 116, 0.35);
  }

  .form-actions {
    text-align: center;
    margin-top: 0.5rem;
  }

  .form-submit {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem 2rem;
    background: var(--color-accent, #e8c574);
    border: 1px solid var(--color-accent, #e8c574);
    border-radius: 2px;
    color: var(--color-bg-deep, #0a1628);
    font-family: var(--font-wordmark, system-ui);
    font-size: 0.85rem;
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    cursor: pointer;
    transition: all 0.3s ease;
    box-shadow: 0 6px 20px rgba(232, 197, 116, 0.2);
  }

  .form-submit:hover {
    background: #f0d28d;
    border-color: #f0d28d;
    transform: translateY(-2px);
    box-shadow: 0 10px 28px rgba(232, 197, 116, 0.35);
  }

  .submit-arrow {
    font-size: 1rem;
    transition: transform 0.3s ease;
  }

  .form-submit:hover .submit-arrow {
    transform: translateX(3px);
  }

  .form-status {
    margin: 0;
    min-height: 1.25rem;
    text-align: center;
    font-size: 0.85rem;
    color: rgba(232, 197, 116, 0.85);
    font-style: italic;
  }

  /* ============ WHAT HAPPENS NEXT ============ */
  .contact-next {
    max-width: 720px;
    margin: 4rem auto 0;
    padding: 2.25rem 2rem;
    background: rgba(232, 197, 116, 0.04);
    border: 1px solid rgba(232, 197, 116, 0.18);
    border-radius: 4px;
  }

  .next-title {
    font-family: var(--font-wordmark, system-ui);
    font-size: 0.72rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-accent, #e8c574);
    font-weight: 500;
    margin: 0 0 1.5rem;
    text-align: center;
  }

  .next-steps {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .next-step {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .next-step:last-child {
    margin-bottom: 0;
  }

  .step-num {
    flex-shrink: 0;
    width: 26px;
    height: 26px;
    border-radius: 50%;
    background: rgba(232, 197, 116, 0.15);
    border: 1px solid rgba(232, 197, 116, 0.55);
    color: var(--color-accent, #e8c574);
    font-family: var(--font-wordmark, system-ui);
    font-size: 0.75rem;
    font-weight: 500;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .step-text {
    font-family: var(--font-sans, system-ui);
    font-size: 0.95rem;
    color: rgba(248, 250, 252, 0.85);
    font-weight: 300;
    line-height: 1.6;
    margin: 0;
    padding-top: 0.15rem;
  }

  .step-text strong {
    color: var(--color-text-primary, #f8fafc);
    font-weight: 500;
  }

  /* ============ ASIDE / DIRECT EMAIL ============ */
  .contact-aside {
    max-width: 560px;
    margin: 3rem auto 0;
    padding-top: 2rem;
    border-top: 1px solid rgba(232, 197, 116, 0.18);
    text-align: center;
  }

  .aside-label {
    font-family: var(--font-wordmark, system-ui);
    font-size: 0.65rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgba(232, 197, 116, 0.7);
    font-weight: 500;
    margin: 0 0 0.75rem;
  }

  .aside-text {
    font-family: var(--font-sans, system-ui);
    font-size: 0.95rem;
    color: rgba(248, 250, 252, 0.8);
    margin: 0;
    font-weight: 300;
  }

  .aside-text a {
    color: var(--color-accent, #e8c574);
    text-decoration: none;
    border-bottom: 1px solid rgba(232, 197, 116, 0.4);
    transition: border-color 0.3s ease;
  }

  .aside-text a:hover {
    border-bottom-color: var(--color-accent, #e8c574);
  }

  /* ============ MOBILE ============ */
  @media (max-width: 900px) {
    .contact-page {
      padding: 0 1.25rem 4rem;
    }

    .contact-hero {
      padding: 4rem 0 1.5rem;
    }

    .contact-headline {
      font-size: clamp(2rem, 10vw, 3rem);
      line-height: 1.1;
    }

    .contact-letter {
      margin-bottom: 2.5rem;
    }

    .contact-fit {
      grid-template-columns: 1fr;
      gap: 1rem;
      margin-bottom: 2.5rem;
    }

    .form-row-split {
      grid-template-columns: 1fr;
      gap: 1.35rem;
    }

    .contact-next {
      margin-top: 3rem;
      padding: 1.75rem 1.25rem;
    }

    .contact-aside {
      margin-top: 2.5rem;
    }
  }
</style>

<script is:inline>
  // Light progressive enhancement: when the form submits, swap the button label
  // and show a friendly status message. The mailto handoff still works normally.
  (function() {
    const form = document.getElementById('contactForm');
    const status = document.getElementById('cf-status');
    if (!form || !status) return;

    form.addEventListener('submit', () => {
      status.textContent = "Opening your email app...";
    });
  })();
</script>
