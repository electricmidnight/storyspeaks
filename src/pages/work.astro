---
// work.astro — Stories That Deliver
// Featured film case studies with cursor-following video player.
// Ported and adapted from Luminous Story Work page.
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Our Work — The Story Speaks">

  <main class="work-page">

    <!-- ============ HERO HEADER ============ -->
    <section class="work-hero">
      <p class="work-eyebrow">Our Work</p>
      <h1 class="work-headline">
        <span class="word word-stories">STORIES</span>
        <span class="word word-that">THAT</span>
        <span class="word word-deliver">DELIVER</span>
      </h1>
      <p class="work-subtitle">
        Strategic narrative architecture that moves audiences, drives action, and delivers measurable results.
      </p>
    </section>

    <!-- ============ CASES GRID ============ -->
    <section class="cases-section">
      <div class="cases-grid">

        <!-- Case 01: Healthcare / Geisinger -->
        <article class="case-card" data-case="healthcare">
          <div class="case-video-preview">
            <div class="video-poster poster-healthcare">
              <div class="poster-overlay"></div>
              <div class="play-icon-static">
                <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><polygon points="8,5 19,12 8,19"/></svg>
              </div>
            </div>
          </div>
          <div class="case-info">
            <svg class="case-icon" viewBox="0 0 36 36" fill="none" aria-hidden="true">
              <path d="M4 18 L10 18 L13 12 L18 24 L23 14 L26 18 L32 18" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
              <circle cx="18" cy="18" r="15" stroke="currentColor" stroke-width="1.5" fill="none" opacity="0.3"/>
            </svg>
            <div class="case-number">Case 01 — Healthcare</div>
            <h3 class="case-title">Acts of Kindness</h3>
            <p class="case-subtitle">Geisinger Health · $1.5B Pennsylvania Health System</p>
            <p class="case-outcome">
              <strong>An internal film festival.</strong> Six employee story films inspired the system to launch its own.
            </p>
          </div>
        </article>

        <!-- Case 02: Nonprofit / Tenderheart Crusades -->
        <article class="case-card" data-case="nonprofit">
          <div class="case-video-preview">
            <div class="video-poster poster-placeholder">
              <div class="poster-overlay"></div>
              <div class="play-icon-static">
                <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><polygon points="8,5 19,12 8,19"/></svg>
              </div>
            </div>
          </div>
          <div class="case-info">
            <svg class="case-icon" viewBox="0 0 36 36" fill="none" aria-hidden="true">
              <path d="M18 30 C18 30 6 22 6 13 C6 9 9 6 13 6 C15 6 17 7 18 9 C19 7 21 6 23 6 C27 6 30 9 30 13 C30 22 18 30 18 30 Z" stroke="currentColor" stroke-width="2" stroke-linejoin="round" fill="none"/>
            </svg>
            <div class="case-number">Case 02 — Nonprofit</div>
            <h3 class="case-title">The Shadow Between Us</h3>
            <p class="case-subtitle">Tenderheart Crusades · Cleveland</p>
            <p class="case-outcome">
              <strong>Emmy-winning documentary.</strong> Full case study coming soon.
            </p>
          </div>
        </article>

        <!-- Case 03: Corporate / Memphis Chamber -->
        <article class="case-card" data-case="corporate">
          <div class="case-video-preview">
            <div class="video-poster poster-placeholder">
              <div class="poster-overlay"></div>
              <div class="play-icon-static">
                <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><polygon points="8,5 19,12 8,19"/></svg>
              </div>
            </div>
          </div>
          <div class="case-info">
            <svg class="case-icon" viewBox="0 0 36 36" fill="none" aria-hidden="true">
              <rect x="8" y="14" width="20" height="18" stroke="currentColor" stroke-width="2" fill="none"/>
              <rect x="12" y="4" width="12" height="10" stroke="currentColor" stroke-width="2" fill="none"/>
              <line x1="18" y1="14" x2="18" y2="32" stroke="currentColor" stroke-width="1.5"/>
              <line x1="8" y1="22" x2="28" y2="22" stroke="currentColor" stroke-width="1.5"/>
            </svg>
            <div class="case-number">Case 03 — Corporate</div>
            <h3 class="case-title">The Soundtrack Project</h3>
            <p class="case-subtitle">Memphis Chamber of Commerce</p>
            <p class="case-outcome">
              <strong>Emmy-winning film series.</strong> Full case study coming soon.
            </p>
          </div>
        </article>

      </div>

      <!-- Bottom CTA -->
      <div class="work-cta-wrapper">
        <a href="/process" class="work-cta">
          <span>SEE THE PROCESS</span>
          <span class="cta-arrow">→</span>
        </a>
      </div>
    </section>

    <!-- ============ DETAIL VIEW MODAL ============ -->
    <div class="detail-view" id="detailView" aria-hidden="true" role="dialog">
      <div class="detail-overlay" id="detailOverlay"></div>
      <div class="detail-container">

        <div class="detail-left">
          <div class="detail-header-section">
            <button class="detail-back" id="detailBack" type="button">← Back to Cases</button>
            <div class="detail-story-number" id="detailNumber"></div>
            <h2 class="detail-title" id="detailTitle"></h2>
            <p class="detail-subtitle" id="detailSubtitle"></p>
          </div>

          <div class="detail-content">
            <div class="detail-block">
              <div class="detail-label">The Brief</div>
              <div class="detail-text" id="detailChallenge"></div>
            </div>
            <div class="detail-block">
              <div class="detail-label">The PRISM Process</div>
              <div class="detail-text" id="detailProcess"></div>
            </div>
            <div class="detail-block">
              <div class="detail-label">The Outcome</div>
              <div class="detail-text" id="detailOutcome"></div>
            </div>
          </div>

          <div class="detail-actions">
            <button class="detail-button primary" id="detailWatch" type="button">Watch Full Story</button>
            <button class="detail-button" id="detailViewAll" type="button">View All Cases</button>
          </div>
        </div>

        <div class="detail-right">
          <div class="detail-video-container" id="detailVideoContainer">
            <div class="detail-poster" id="detailPoster"></div>
            <div class="detail-video-gradient"></div>
            <div class="detail-play-button" id="detailPlayButton" role="button" aria-label="Play full film">
              <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <polygon points="8,5 19,12 8,19"/>
              </svg>
            </div>
          </div>
        </div>

      </div>
    </div>

    <!-- ============ FULLSCREEN PLAYER MODAL ============ -->
    <div class="fullscreen-mode" id="fullscreenPlayer" aria-hidden="true" role="dialog">
      <div class="fullscreen-header">
        <button class="fullscreen-back-button" id="fullscreenBack" type="button">← Back</button>
        <h3 class="fullscreen-title" id="fullscreenTitle"></h3>
      </div>
      <div class="fullscreen-video-container" id="fullscreenVideoContainer">
        <iframe id="fullscreenIframe" src="" frameborder="0" allow="autoplay; fullscreen; picture-in-picture" allowfullscreen title="Film player"></iframe>
        <div class="fullscreen-empty-state" id="fullscreenEmpty">
          <p>Film coming soon.</p>
        </div>
      </div>
    </div>

  </main>

  <!-- ============ DATA + INTERACTIVITY ============ -->
  <script is:inline>
    // Case data (kept inline so it can be edited as text content)
    const caseData = {
      healthcare: {
        number: 'Case 01 — Healthcare',
        title: 'Acts of Kindness',
        subtitle: 'Geisinger Health · $1.5B Pennsylvania Health System',
        challenge: 'Six films for an internal employee campaign across a $1.5B healthcare system. Under deadline.',
        process: 'Storyfinding refused the generic. Pre-interviews surfaced six subjects with surprising, specific moments worth filming.',
        outcome: 'The series resonated so deeply Geisinger launched an internal film festival across the system. <strong>From brief to legacy in six films.</strong>',
        posterClass: 'poster-healthcare',
        vimeoUrl: 'https://player.vimeo.com/video/412818275?h=36dd52c40e&autoplay=1&badge=0&autopause=0&player_id=0&app_id=58479'
      },
      nonprofit: {
        number: 'Case 02 — Nonprofit',
        title: 'The Shadow Between Us',
        subtitle: 'Tenderheart Crusades · Cleveland',
        challenge: 'Full case study coming soon.',
        process: 'Full case study coming soon.',
        outcome: 'Emmy-winning documentary. <strong>Full details coming soon.</strong>',
        posterClass: 'poster-placeholder',
        vimeoUrl: ''
      },
      corporate: {
        number: 'Case 03 — Corporate',
        title: 'The Soundtrack Project',
        subtitle: 'Memphis Chamber of Commerce',
        challenge: 'Full case study coming soon.',
        process: 'Full case study coming soon.',
        outcome: 'Emmy-winning film series. <strong>Full details coming soon.</strong>',
        posterClass: 'poster-placeholder',
        vimeoUrl: ''
      }
    };

    let currentCase = null;

    // ========== Detail view open/close ==========
    function openDetailView(caseId) {
      const data = caseData[caseId];
      if (!data) return;
      currentCase = caseId;

      document.getElementById('detailNumber').textContent = data.number;
      document.getElementById('detailTitle').textContent = data.title;
      document.getElementById('detailSubtitle').textContent = data.subtitle;
      document.getElementById('detailChallenge').textContent = data.challenge;
      document.getElementById('detailProcess').textContent = data.process;
      document.getElementById('detailOutcome').innerHTML = data.outcome;

      const poster = document.getElementById('detailPoster');
      poster.className = 'detail-poster ' + data.posterClass;

      const detailView = document.getElementById('detailView');
      detailView.classList.add('active');
      detailView.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
    }

    function closeDetailView() {
      const detailView = document.getElementById('detailView');
      detailView.classList.remove('active');
      detailView.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
    }

    // Card click → open detail view
    document.querySelectorAll('.case-card').forEach(card => {
      card.addEventListener('click', () => {
        openDetailView(card.getAttribute('data-case'));
      });
    });

    document.getElementById('detailBack').addEventListener('click', closeDetailView);
    document.getElementById('detailViewAll').addEventListener('click', closeDetailView);
    document.getElementById('detailOverlay').addEventListener('click', closeDetailView);

    // ========== Fullscreen player open/close ==========
    function openFullscreen() {
      if (!currentCase) return;
      const data = caseData[currentCase];

      document.getElementById('fullscreenTitle').textContent = data.title;

      const iframe = document.getElementById('fullscreenIframe');
      const empty = document.getElementById('fullscreenEmpty');

      if (data.vimeoUrl) {
        iframe.src = data.vimeoUrl;
        iframe.style.display = 'block';
        empty.style.display = 'none';
      } else {
        iframe.src = '';
        iframe.style.display = 'none';
        empty.style.display = 'flex';
      }

      const fs = document.getElementById('fullscreenPlayer');
      fs.classList.add('active');
      fs.setAttribute('aria-hidden', 'false');
    }

    function closeFullscreen() {
      const fs = document.getElementById('fullscreenPlayer');
      fs.classList.remove('active');
      fs.setAttribute('aria-hidden', 'true');
      // Stop the video by clearing the iframe src
      document.getElementById('fullscreenIframe').src = '';
    }

    document.getElementById('detailWatch').addEventListener('click', openFullscreen);
    document.getElementById('detailPlayButton').addEventListener('click', openFullscreen);
    document.getElementById('fullscreenBack').addEventListener('click', closeFullscreen);

    // ========== ESC key handling ==========
    document.addEventListener('keydown', (e) => {
      if (e.key !== 'Escape') return;
      const fs = document.getElementById('fullscreenPlayer');
      const dv = document.getElementById('detailView');
      if (fs.classList.contains('active')) {
        closeFullscreen();
      } else if (dv.classList.contains('active')) {
        closeDetailView();
      }
    });

    // ========== Cursor-following play button (the signature interaction) ==========
    (function() {
      const container = document.getElementById('detailVideoContainer');
      const button = document.getElementById('detailPlayButton');
      if (!container || !button) return;

      // Skip on touch devices — the cursor-following has no value there
      const isTouch = window.matchMedia('(hover: none)').matches;
      if (isTouch) return;

      let following = false;

      container.addEventListener('mouseenter', (e) => {
        following = true;
        const rect = container.getBoundingClientRect();
        const x = e.clientX - rect.left - button.offsetWidth / 2;
        const y = e.clientY - rect.top - button.offsetHeight / 2;
        button.style.top = '0';
        button.style.left = '0';
        button.style.transform = `translate(${x}px, ${y}px)`;
      });

      container.addEventListener('mousemove', (e) => {
        if (!following) return;
        const rect = container.getBoundingClientRect();
        const x = e.clientX - rect.left - button.offsetWidth / 2;
        const y = e.clientY - rect.top - button.offsetHeight / 2;
        button.style.transform = `translate(${x}px, ${y}px)`;
      });

      container.addEventListener('mouseleave', () => {
        following = false;
        button.style.top = '50%';
        button.style.left = '50%';
        button.style.transform = 'translate(-50%, -50%)';
      });
    })();
  </script>

</BaseLayout>

<style>
  /* ============================================================
     WORK PAGE — Stories That Deliver
     ============================================================ */

  .work-page {
    background: var(--color-bg-deep, #0a1628);
    color: var(--color-text-primary, #f8fafc);
    min-height: 100vh;
  }

  /* ============ HERO HEADER ============ */
  .work-hero {
    max-width: 1100px;
    margin: 0 auto;
    padding: 7rem 2rem 4rem;
    text-align: center;
  }

  .work-eyebrow {
    font-family: var(--font-wordmark, system-ui);
    font-size: 0.75rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-accent, #e8c574);
    margin: 0 0 1.5rem;
    font-weight: 400;
  }

  .work-headline {
    font-family: var(--font-sans, system-ui);
    font-weight: 300;
    font-size: clamp(2.5rem, 8vw, 5.5rem);
    line-height: 1.05;
    letter-spacing: -0.025em;
    margin: 0 0 1.5rem;
  }

  .work-headline .word {
    display: inline-block;
    margin: 0 0.15em;
  }

  .work-subtitle {
    font-family: var(--font-sans, system-ui);
    font-size: clamp(1rem, 1.5vw, 1.15rem);
    color: var(--color-text-muted, #94a3b8);
    max-width: 640px;
    margin: 0 auto;
    font-weight: 300;
    line-height: 1.65;
    text-wrap: pretty;
  }

  /* ============ CASES GRID ============ */
  .cases-section {
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem 2rem 6rem;
  }

  .cases-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
    margin-bottom: 4rem;
  }

  .case-card {
    position: relative;
    border: 1px solid rgba(232, 197, 116, 0.2);
    border-radius: 20px;
    background: linear-gradient(135deg, rgba(10, 22, 40, 0.6) 0%, rgba(13, 27, 50, 0.85) 100%);
    backdrop-filter: blur(10px);
    overflow: hidden;
    cursor: pointer;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    display: flex;
    flex-direction: column;
  }

  .case-card:hover {
    background: linear-gradient(135deg, rgba(232, 197, 116, 0.08) 0%, rgba(232, 197, 116, 0.12) 100%);
    border-color: var(--color-accent, #e8c574);
    transform: translateY(-12px) scale(1.02);
    box-shadow:
      0 25px 60px rgba(232, 197, 116, 0.35),
      0 0 50px rgba(232, 197, 116, 0.25),
      0 0 100px rgba(232, 197, 116, 0.1),
      inset 0 0 30px rgba(232, 197, 116, 0.06);
  }

  .case-card:hover .case-icon {
    transform: scale(1.2);
    filter: drop-shadow(0 0 25px rgba(232, 197, 116, 0.9)) drop-shadow(0 0 40px rgba(232, 197, 116, 0.5));
  }

  .case-card:hover .case-title {
    color: var(--color-accent, #e8c574);
    text-shadow: 0 0 18px rgba(232, 197, 116, 0.7);
  }

  .case-card:hover .case-number {
    color: var(--color-accent, #e8c574);
  }

  .case-card:hover .video-poster .play-icon-static {
    opacity: 1;
    transform: scale(1.1);
  }

  /* ============ Video preview area (top of card) ============ */
  .case-video-preview {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    overflow: hidden;
  }

  .video-poster {
    width: 100%;
    height: 100%;
    background-size: cover;
    background-position: center;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.6s ease;
  }

  .case-card:hover .video-poster {
    transform: scale(1.05);
  }

  /* Geisinger Amish buggy still — replace path with actual upload location */
  .poster-healthcare {
    background-image: url('/images/geisinger-acts-of-kindness.jpg');
    background-color: #2a1810;
  }

  /* Placeholder poster for cases 02 and 03 */
  .poster-placeholder {
    background: linear-gradient(135deg, rgba(232, 197, 116, 0.08) 0%, rgba(13, 27, 50, 0.95) 100%);
  }

  .poster-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, transparent 50%, rgba(10, 22, 40, 0.4));
    pointer-events: none;
  }

  .play-icon-static {
    width: 52px;
    height: 52px;
    border-radius: 50%;
    background: rgba(232, 197, 116, 0.15);
    backdrop-filter: blur(8px);
    border: 1.5px solid rgba(232, 197, 116, 0.7);
    color: var(--color-accent, #e8c574);
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    z-index: 1;
    opacity: 0.85;
    transition: all 0.4s ease;
  }

  .play-icon-static svg {
    width: 20px;
    height: 20px;
    margin-left: 3px; /* optical centering of triangle */
  }

  /* ============ Case info (bottom of card) ============ */
  .case-info {
    padding: 1.5rem 1.5rem 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .case-icon {
    width: 36px;
    height: 36px;
    color: var(--color-accent, #e8c574);
    margin-bottom: 0.65rem;
    opacity: 0.8;
    transition: all 0.4s ease;
  }

  .case-number {
    font-family: var(--font-wordmark, system-ui);
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.15em;
    color: rgba(232, 197, 116, 0.7);
    text-transform: uppercase;
    margin-bottom: 0.35rem;
    transition: color 0.4s ease;
  }

  .case-title {
    font-family: var(--font-sans, system-ui);
    font-size: 1.25rem;
    font-weight: 500;
    color: var(--color-text-primary, #f8fafc);
    line-height: 1.2;
    margin: 0 0 0.2rem;
    letter-spacing: -0.01em;
    transition: all 0.4s ease;
  }

  .case-subtitle {
    font-family: var(--font-sans, system-ui);
    font-size: 0.8rem;
    color: var(--color-text-muted, #94a3b8);
    line-height: 1.45;
    margin: 0 0 1.25rem;
    font-weight: 300;
  }

  .case-outcome {
    font-family: var(--font-sans, system-ui);
    font-size: 0.8rem;
    color: rgba(248, 250, 252, 0.85);
    line-height: 1.55;
    padding-top: 1.1rem;
    border-top: 1px solid rgba(232, 197, 116, 0.18);
    margin: 0;
    font-weight: 300;
  }

  .case-outcome strong {
    color: var(--color-accent, #e8c574);
    font-weight: 500;
  }

  /* ============ Bottom CTA ============ */
  .work-cta-wrapper {
    text-align: center;
    margin-top: 2rem;
  }

  .work-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem 2rem;
    background: color-mix(in srgb, var(--color-accent, #e8c574) 10%, transparent);
    border: 1px solid var(--color-accent, #e8c574);
    border-radius: 2px;
    color: var(--color-accent, #e8c574);
    font-family: var(--font-wordmark, system-ui);
    font-size: 0.85rem;
    font-weight: 400;
    letter-spacing: 0.15em;
    text-decoration: none;
    text-transform: uppercase;
    transition: all 0.3s ease;
  }

  .work-cta:hover {
    background: color-mix(in srgb, var(--color-accent, #e8c574) 20%, transparent);
    transform: translateY(-2px);
  }

  .cta-arrow {
    transition: transform 0.3s ease;
  }

  .work-cta:hover .cta-arrow {
    transform: translateX(4px);
  }

  /* ============================================================
     DETAIL VIEW MODAL
     ============================================================ */
  .detail-view {
    position: fixed;
    inset: 0;
    z-index: 1000;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.5s ease;
  }

  .detail-view.active {
    opacity: 1;
    pointer-events: auto;
  }

  .detail-overlay {
    position: absolute;
    inset: 0;
    background: rgba(10, 22, 40, 0.85);
    backdrop-filter: blur(15px);
  }

  .detail-container {
    position: relative;
    max-width: 1300px;
    height: 100%;
    margin: 0 auto;
    padding: 5rem 2rem 3rem;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3.5rem;
    align-items: center;
  }

  .detail-left {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    height: 100%;
    max-height: 700px;
  }

  .detail-header-section {
    margin-bottom: 2rem;
  }

  .detail-back {
    background: none;
    border: none;
    color: var(--color-accent, #e8c574);
    font-family: var(--font-sans, system-ui);
    font-size: 0.85rem;
    cursor: pointer;
    padding: 0;
    margin-bottom: 1.75rem;
    letter-spacing: 0.02em;
    transition: opacity 0.3s ease;
  }

  .detail-back:hover {
    opacity: 0.7;
  }

  .detail-story-number {
    font-family: var(--font-wordmark, system-ui);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.18em;
    color: var(--color-accent, #e8c574);
    text-transform: uppercase;
    margin-bottom: 0.75rem;
  }

  .detail-title {
    font-family: var(--font-sans, system-ui);
    font-weight: 300;
    font-size: clamp(1.75rem, 3.5vw, 2.75rem);
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--color-text-primary, #f8fafc);
    margin: 0 0 0.6rem;
  }

  .detail-subtitle {
    font-family: var(--font-sans, system-ui);
    font-size: 0.95rem;
    color: var(--color-text-muted, #94a3b8);
    font-weight: 300;
    margin: 0;
    line-height: 1.5;
  }

  .detail-content {
    flex: 1;
    overflow-y: auto;
    padding-right: 0.5rem;
  }

  .detail-block {
    margin-bottom: 1.5rem;
  }

  .detail-label {
    font-family: var(--font-wordmark, system-ui);
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.18em;
    color: var(--color-accent, #e8c574);
    text-transform: uppercase;
    margin-bottom: 0.5rem;
  }

  .detail-text {
