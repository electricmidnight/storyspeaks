---
// work.astro — Stories That Deliver
// Featured film case studies with cursor-following video player.
// Ported and adapted from Luminous Story Work page.
import BaseLayout from '../layouts/BaseLayout.astro';
---
 
<BaseLayout title="Our Work — The Story Speaks">
 
  <main class="work-page">
 
    <!-- ============ HERO HEADER ============ -->
    <section class="work-hero">
      <p class="work-eyebrow">Our Work</p>
      <h1 class="work-headline">
        <span class="headline-line line-1">STORIES</span>
        <span class="headline-line line-2">THAT <span class="word-deliver">DELIVER</span></span>
      </h1>
      <p class="work-subtitle">
        Strategic narrative architecture that moves audiences,<br/>
        drives action, and delivers measurable results.
      </p>
    </section>
 
    <!-- ============ CASES GRID ============ -->
    <section class="cases-section">
      <div class="cases-grid">
 
        <!-- Case 01: Healthcare / Geisinger -->
        <article class="case-card" data-case="healthcare">
          <div class="case-video-preview">
            <div class="video-poster poster-healthcare">
              <div class="poster-overlay"></div>
              <div class="play-indicator">
                <div class="play-indicator-inner"></div>
              </div>
            </div>
          </div>
          <div class="case-info">
            <svg class="case-icon" viewBox="0 0 36 36" fill="none" aria-hidden="true">
              <path d="M4 18 L10 18 L13 12 L18 24 L23 14 L26 18 L32 18" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
              <circle cx="18" cy="18" r="15" stroke="currentColor" stroke-width="1.5" fill="none" opacity="0.3"/>
            </svg>
            <div class="case-number">Case 01 — Healthcare</div>
            <h3 class="case-title">Acts of Kindness</h3>
            <p class="case-subtitle">Geisinger Health · $1.5B Pennsylvania Health System</p>
            <p class="case-outcome">
              <strong>Campaign:</strong> Six employee kindness films inspired Geisinger to launch its own mini film festival.
            </p>
          </div>
        </article>
 
        <!-- Case 02: Nonprofit / Tenderheart Crusades -->
        <article class="case-card" data-case="nonprofit">
          <div class="case-video-preview">
            <div class="video-poster poster-nonprofit">
              <div class="poster-overlay"></div>
              <div class="play-indicator">
                <div class="play-indicator-inner"></div>
              </div>
            </div>
          </div>
          <div class="case-info">
            <svg class="case-icon" viewBox="0 0 36 36" fill="none" aria-hidden="true">
              <path d="M18 30 C18 30 6 22 6 13 C6 9 9 6 13 6 C15 6 17 7 18 9 C19 7 21 6 23 6 C27 6 30 9 30 13 C30 22 18 30 18 30 Z" stroke="currentColor" stroke-width="2" stroke-linejoin="round" fill="none"/>
            </svg>
            <div class="case-number">Case 02 — Nonprofit</div>
            <h3 class="case-title">The Shadow Between Us</h3>
            <p class="case-subtitle">Tenderheart Crusades · Cleveland</p>
            <p class="case-outcome">
              <strong>Documentary:</strong> Emmy-winning feature on racial unity, now in national PBS rotation.
            </p>
          </div>
        </article>
 
        <!-- Case 03: Corporate / Memphis Chamber -->
        <article class="case-card" data-case="corporate">
          <div class="case-video-preview">
            <div class="video-poster poster-corporate">
              <div class="poster-overlay"></div>
              <div class="play-indicator">
                <div class="play-indicator-inner"></div>
              </div>
            </div>
          </div>
          <div class="case-info">
            <svg class="case-icon" viewBox="0 0 36 36" fill="none" aria-hidden="true">
              <rect x="8" y="14" width="20" height="18" stroke="currentColor" stroke-width="2" fill="none"/>
              <rect x="12" y="4" width="12" height="10" stroke="currentColor" stroke-width="2" fill="none"/>
              <line x1="18" y1="14" x2="18" y2="32" stroke="currentColor" stroke-width="1.5"/>
              <line x1="8" y1="22" x2="28" y2="22" stroke="currentColor" stroke-width="1.5"/>
            </svg>
            <div class="case-number">Case 03 — Corporate</div>
            <h3 class="case-title">The Soundtrack Project</h3>
            <p class="case-subtitle">Memphis Chamber of Commerce</p>
            <p class="case-outcome">
              <strong>Series:</strong> Eight films pairing entrepreneurs with symphony composers. Emmy, ADDY, and TED honors.
            </p>
          </div>
        </article>
 
      </div>
 
      <!-- Bottom CTA -->
      <div class="work-cta-wrapper">
        <a href="/process" class="work-cta">
          <span>SEE THE PROCESS</span>
          <span class="cta-arrow">→</span>
        </a>
      </div>
    </section>
 
    <!-- ============ DETAIL VIEW MODAL ============ -->
    <div class="detail-view" id="detailView" aria-hidden="true" role="dialog">
      <div class="detail-overlay" id="detailOverlay"></div>
 
      <!-- Top-level BACK TO CASES button -->
      <button class="detail-back-top" id="detailBack" type="button">
        <span class="back-arrow">←</span>
        <span>Back to Cases</span>
      </button>
 
      <div class="detail-container">
 
        <div class="detail-left">
          <div class="detail-header-section">
            <div class="detail-story-number" id="detailNumber"></div>
            <h2 class="detail-title" id="detailTitle"></h2>
            <p class="detail-subtitle" id="detailSubtitle"></p>
          </div>
 
          <div class="detail-content">
            <div class="detail-block">
              <div class="detail-label">The Challenge</div>
              <div class="detail-text" id="detailChallenge"></div>
            </div>
            <div class="detail-block">
              <div class="detail-label">The PRISM Process</div>
              <div class="detail-text" id="detailProcess"></div>
            </div>
            <div class="detail-block">
              <div class="detail-label">The Outcome</div>
              <div class="detail-text" id="detailOutcome"></div>
            </div>
          </div>
 
          <div class="detail-actions">
            <button class="detail-button primary" id="detailWatch" type="button">Watch Full Story</button>
            <button class="detail-button" id="detailViewAll" type="button">View All Cases</button>
          </div>
        </div>
 
        <div class="detail-right">
          <div class="detail-video-container" id="detailVideoContainer">
            <iframe class="detail-video-iframe" id="detailVideoIframe" src="" frameborder="0" allow="autoplay; fullscreen; picture-in-picture" allowfullscreen title="Featured film"></iframe>
            <div class="detail-video-empty" id="detailVideoEmpty">
              <p>Film coming soon</p>
            </div>
            <button class="detail-video-clickzone" id="detailVideoClickzone" type="button" aria-label="Play full film"></button>
            <div class="detail-play-button" id="detailPlayButton" aria-hidden="true">
              <span>PLAY</span>
            </div>
          </div>
        </div>
 
      </div>
    </div>
 
  </main>
 
  <!-- ============ DATA + INTERACTIVITY ============ -->
  <script is:inline>
    // Case data (kept inline so it can be edited as text content)
    const caseData = {
      healthcare: {
        number: 'Case 01 — Healthcare',
        title: 'Acts of Kindness',
        subtitle: 'Geisinger Health · $1.5B Pennsylvania Health System',
        challenge: 'Under tight deadlines, find and create films about employee kindness throughout a $1.5 billion multi-campus healthcare system.',
        process: 'Storyfinding and pre-interviews surfaced six subjects with surprising, specific moments worth filming.',
        outcome: 'The series resonated so deeply that Geisinger launched an internal film festival across the system. <strong>From brief to legacy in six films.</strong>',
        vimeoUrl: 'https://player.vimeo.com/video/412818275?h=36dd52c40e&badge=0&autopause=0&dnt=1'
      },
      nonprofit: {
        number: 'Case 02 — Nonprofit',
        title: 'The Shadow Between Us',
        subtitle: 'Tenderheart Crusades · Cleveland',
        challenge: 'A Cleveland nonprofit founder wanted to film a shadow dance about racial unity in the wake of George Floyd. A fragile concept, no clear story.',
        process: 'Deep storyfinding interviews found the center: Cleveland dancer Nehemiah Spencer. His life — Cleveland roots, Juilliard training, return home — became the narrative spine.',
        outcome: 'What started as a short performance film grew into a feature documentary, now in national PBS rotation. <strong>Two Emmys, four nominations, festivals worldwide.</strong>',
        vimeoUrl: 'https://player.vimeo.com/video/666118583?badge=0&autopause=0&dnt=1'
      },
      corporate: {
        number: 'Case 03 — Corporate',
        title: 'The Soundtrack Project',
        subtitle: 'Greater Memphis Chamber',
        challenge: 'The Greater Memphis Chamber wanted to celebrate the rich tapestry of their small business members. To show that the city is much more than FedEx and other larger corporations.',
        process: 'We found compelling characters to profile, then paired each with a composer from the Memphis Symphony. The composers joined the storyfinding and wrote scores that reflected each person\'s spirit — from a laconic cattle farmer to an immigrant\'s path to citizenship.',
        outcome: 'Eight films aired on Memphis PBS, premiered to a packed theater scored live by the Memphis Symphony. <strong>Emmys for writing and editing, a national ADDY, and TED \'Ads Worth Spreading\' recognition.</strong>',
        vimeoUrl: 'https://player.vimeo.com/video/418195942?h=8108119099&badge=0&autopause=0&dnt=1'
      }
    };
 
    let currentCase = null;
 
    // ========== Detail view open ==========
    function openDetailView(caseId) {
      const data = caseData[caseId];
      if (!data) return;
      currentCase = caseId;
 
      document.getElementById('detailNumber').textContent = data.number;
      document.getElementById('detailTitle').textContent = data.title;
      document.getElementById('detailSubtitle').textContent = data.subtitle;
      document.getElementById('detailChallenge').textContent = data.challenge;
      document.getElementById('detailProcess').textContent = data.process;
      document.getElementById('detailOutcome').innerHTML = data.outcome;
 
      // Reset video container to pre-play state
      const container = document.getElementById('detailVideoContainer');
      const iframe = document.getElementById('detailVideoIframe');
      const empty = document.getElementById('detailVideoEmpty');
      container.classList.remove('playing');
 
      if (data.vimeoUrl) {
        iframe.src = data.vimeoUrl;
        iframe.style.display = 'block';
        empty.style.display = 'none';
      } else {
        iframe.src = '';
        iframe.style.display = 'none';
        empty.style.display = 'flex';
      }
 
      const detailView = document.getElementById('detailView');
      detailView.classList.add('active');
      detailView.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
    }
 
    // ========== Detail view close (also stops playback) ==========
    function closeDetailView() {
      const detailView = document.getElementById('detailView');
      detailView.classList.remove('active');
      detailView.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
 
      // Hard-stop the video by clearing iframe src — this kills any audio/playback
      document.getElementById('detailVideoIframe').src = '';
      document.getElementById('detailVideoContainer').classList.remove('playing');
      currentCase = null;
    }
 
    // Card click → open detail view
    document.querySelectorAll('.case-card').forEach(card => {
      card.addEventListener('click', () => {
        openDetailView(card.getAttribute('data-case'));
      });
    });
 
    document.getElementById('detailBack').addEventListener('click', closeDetailView);
    document.getElementById('detailViewAll').addEventListener('click', closeDetailView);
    document.getElementById('detailOverlay').addEventListener('click', closeDetailView);
 
    // ========== PLAY action — start video inline by reloading iframe with autoplay ==========
    function playInline() {
      if (!currentCase) return;
      const data = caseData[currentCase];
      if (!data.vimeoUrl) return;
 
      const container = document.getElementById('detailVideoContainer');
      const iframe = document.getElementById('detailVideoIframe');
 
      // Reload iframe with autoplay parameter — guaranteed to work, no Player API state issues
      const separator = data.vimeoUrl.includes('?') ? '&' : '?';
      iframe.src = data.vimeoUrl + separator + 'autoplay=1';
 
      // Hide PLAY overlay + click zone, exposing Vimeo's native controls
      container.classList.add('playing');
    }
 
    // Click zone (transparent overlay on top of iframe) triggers play
    document.getElementById('detailVideoClickzone').addEventListener('click', playInline);
    // "Watch Full Story" button also triggers play
    document.getElementById('detailWatch').addEventListener('click', playInline);
 
    // ========== ESC key handling ==========
    document.addEventListener('keydown', (e) => {
      if (e.key !== 'Escape') return;
      const dv = document.getElementById('detailView');
      if (dv.classList.contains('active')) {
        closeDetailView();
      }
    });
 
    // ========== Cursor-following PLAY box (the signature interaction) ==========
    (function() {
      const container = document.getElementById('detailVideoContainer');
      const button = document.getElementById('detailPlayButton');
      if (!container || !button) return;
 
      // Skip on touch devices — the cursor-following has no value there
      const isTouch = window.matchMedia('(hover: none)').matches;
      if (isTouch) return;
 
      let following = false;
 
      container.addEventListener('mouseenter', (e) => {
        following = true;
        const rect = container.getBoundingClientRect();
        const x = e.clientX - rect.left - button.offsetWidth / 2;
        const y = e.clientY - rect.top - button.offsetHeight / 2;
        button.style.top = '0';
        button.style.left = '0';
        button.style.transform = `translate(${x}px, ${y}px)`;
      });
 
      container.addEventListener('mousemove', (e) => {
        if (!following) return;
        const rect = container.getBoundingClientRect();
        const x = e.clientX - rect.left - button.offsetWidth / 2;
        const y = e.clientY - rect.top - button.offsetHeight / 2;
        button.style.transform = `translate(${x}px, ${y}px)`;
      });
 
      container.addEventListener('mouseleave', () => {
        following = false;
        button.style.top = '50%';
        button.style.left = '50%';
        button.style.transform = 'translate(-50%, -50%)';
      });
    })();
  </script>
 
</BaseLayout>
 
<style>
  /* ============================================================
     WORK PAGE — Stories That Deliver
     ============================================================ */
 
  .work-page {
    background: var(--color-bg-deep, #0a1628);
    color: var(--color-text-primary, #f8fafc);
    min-height: 100vh;
    position: relative;
  }
 
  /* Horizontal accent line under the nav (work page only for now) */
  .work-page::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg,
      transparent,
      rgba(232, 197, 116, 0.4) 20%,
      rgba(232, 197, 116, 0.4) 80%,
      transparent
    );
    pointer-events: none;
    z-index: 1;
  }
 
  /* ============ HERO HEADER ============ */
  .work-hero {
    max-width: 1100px;
    margin: 0 auto;
    padding: 7rem 2rem 4rem;
    text-align: center;
  }
 
  .work-eyebrow {
    font-family: var(--font-wordmark, system-ui);
    font-size: 0.75rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-accent, #e8c574);
    margin: 0 0 1.5rem;
    font-weight: 400;
  }
 
  .work-headline {
    font-family: var(--font-sans, system-ui);
    font-weight: 300;
    font-size: clamp(2.5rem, 9vw, 6rem);
    line-height: 1.0;
    letter-spacing: -0.025em;
    margin: 0 0 1.75rem;
    text-transform: uppercase;
  }
 
  .work-headline .headline-line {
    display: block;
    line-height: 1.05;
  }
 
  .work-headline .word-deliver {
    color: var(--color-accent, #e8c574);
  }
 
  .work-subtitle {
    font-family: var(--font-sans, system-ui);
    font-size: clamp(1.1rem, 1.65vw, 1.3rem);
    color: var(--color-text-muted, #94a3b8);
    max-width: 720px;
    margin: 0 auto;
    font-weight: 300;
    line-height: 1.6;
    text-wrap: pretty;
  }
 
  /* ============ CASES GRID ============ */
  .cases-section {
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem 2rem 6rem;
  }
 
  .cases-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
    margin-bottom: 4rem;
  }
 
  .case-card {
    position: relative;
    border: 1px solid rgba(232, 197, 116, 0.2);
    border-radius: 20px;
    background: linear-gradient(135deg, rgba(10, 22, 40, 0.6) 0%, rgba(13, 27, 50, 0.85) 100%);
    backdrop-filter: blur(10px);
    overflow: hidden;
    cursor: pointer;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    display: flex;
    flex-direction: column;
  }
 
  .case-card:hover {
    background: linear-gradient(135deg, rgba(232, 197, 116, 0.08) 0%, rgba(232, 197, 116, 0.12) 100%);
    border-color: var(--color-accent, #e8c574);
    transform: translateY(-12px) scale(1.02);
    box-shadow:
      0 25px 60px rgba(232, 197, 116, 0.35),
      0 0 50px rgba(232, 197, 116, 0.25),
      0 0 100px rgba(232, 197, 116, 0.1),
      inset 0 0 30px rgba(232, 197, 116, 0.06);
  }
 
  .case-card:hover .case-icon {
    transform: scale(1.2);
    filter: drop-shadow(0 0 25px rgba(232, 197, 116, 0.9)) drop-shadow(0 0 40px rgba(232, 197, 116, 0.5));
  }
 
  .case-card:hover .case-title {
    color: var(--color-accent, #e8c574);
    text-shadow: 0 0 18px rgba(232, 197, 116, 0.7);
  }
 
  .case-card:hover .case-number {
    color: var(--color-accent, #e8c574);
  }
 
  /* ============ Video preview area (top of card) ============ */
  .case-video-preview {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    overflow: hidden;
  }
 
  .video-poster {
    width: 100%;
    height: 100%;
    background-size: cover;
    background-position: center;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.6s ease;
  }
 
  .case-card:hover .video-poster {
    transform: scale(1.05);
  }
 
  /* Geisinger Amish buggy still */
  .poster-healthcare {
    background-image: url('/images/geisinger-acts-of-kindness.jpg');
    background-color: #2a1810;
  }
 
  /* The Shadow Between Us — Nemo portrait still */
  .poster-nonprofit {
    background-image: url('/images/shadow-between-us-poster.jpg');
    background-color: #0a1a2a;
  }
 
  /* The Soundtrack Project — Memphis father/child on horseback */
  .poster-corporate {
    background-image: url('/images/soundtrack-project-poster.jpg');
    background-color: #1a2010;
  }
 
  /* Placeholder poster for cases 02 and 03 */
  .poster-placeholder {
    background: linear-gradient(135deg, rgba(232, 197, 116, 0.08) 0%, rgba(13, 27, 50, 0.95) 100%);
  }
 
  .poster-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, transparent 50%, rgba(10, 22, 40, 0.4));
    pointer-events: none;
  }
 
  /* Small rectangular play indicator on cards (matches original) */
  .play-indicator {
    width: 60px;
    height: 42px;
    border: 2px solid rgba(232, 197, 116, 0.55);
    border-radius: 4px;
    background: rgba(232, 197, 116, 0.1);
    backdrop-filter: blur(6px);
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    z-index: 1;
    opacity: 0.9;
    transition: all 0.4s ease;
  }
 
  .play-indicator-inner {
    width: 0;
    height: 0;
    border-left: 14px solid rgba(232, 197, 116, 0.9);
    border-top: 9px solid transparent;
    border-bottom: 9px solid transparent;
    margin-left: 3px;
  }
 
  .case-card:hover .play-indicator {
    opacity: 1;
    border-color: var(--color-accent, #e8c574);
    box-shadow: 0 0 20px rgba(232, 197, 116, 0.5);
    transform: scale(1.08);
  }
 
  .case-card:hover .play-indicator-inner {
    border-left-color: var(--color-accent, #e8c574);
  }
 
  /* ============ Case info (bottom of card) ============ */
  .case-info {
    padding: 1.5rem 1.5rem 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }
 
  .case-icon {
    width: 36px;
    height: 36px;
    color: var(--color-accent, #e8c574);
    margin-bottom: 0.65rem;
    opacity: 0.8;
    transition: all 0.4s ease;
  }
 
  .case-number {
    font-family: var(--font-wordmark, system-ui);
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.15em;
    color: rgba(232, 197, 116, 0.7);
    text-transform: uppercase;
    margin-bottom: 0.35rem;
    transition: color 0.4s ease;
  }
 
  .case-title {
    font-family: var(--font-sans, system-ui);
    font-size: 1.25rem;
    font-weight: 500;
    color: var(--color-text-primary, #f8fafc);
    line-height: 1.2;
    margin: 0 0 0.2rem;
    letter-spacing: -0.01em;
    transition: all 0.4s ease;
  }
 
  .case-subtitle {
    font-family: var(--font-sans, system-ui);
    font-size: 0.8rem;
    color: var(--color-text-muted, #94a3b8);
    line-height: 1.45;
    margin: 0 0 1.25rem;
    font-weight: 300;
  }
 
  .case-outcome {
    font-family: var(--font-sans, system-ui);
    font-size: 0.8rem;
    color: rgba(248, 250, 252, 0.85);
    line-height: 1.55;
    padding-top: 1.1rem;
    border-top: 1px solid rgba(232, 197, 116, 0.18);
    margin: 0;
    font-weight: 300;
  }
 
  .case-outcome strong {
    color: var(--color-accent, #e8c574);
    font-weight: 500;
  }
 
  /* ============ Bottom CTA ============ */
  .work-cta-wrapper {
    text-align: center;
    margin-top: 2rem;
  }
 
  .work-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem 2rem;
    background: color-mix(in srgb, var(--color-accent, #e8c574) 10%, transparent);
    border: 1px solid var(--color-accent, #e8c574);
    border-radius: 2px;
    color: var(--color-accent, #e8c574);
    font-family: var(--font-wordmark, system-ui);
    font-size: 0.85rem;
    font-weight: 400;
    letter-spacing: 0.15em;
    text-decoration: none;
    text-transform: uppercase;
    transition: all 0.3s ease;
  }
 
  .work-cta:hover {
    background: color-mix(in srgb, var(--color-accent, #e8c574) 20%, transparent);
    transform: translateY(-2px);
  }
 
  .cta-arrow {
    transition: transform 0.3s ease;
  }
 
  .work-cta:hover .cta-arrow {
    transform: translateX(4px);
  }
 
  /* ============================================================
     DETAIL VIEW MODAL
     ============================================================ */
  .detail-view {
    position: fixed;
    inset: 0;
    z-index: 1000;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.5s ease;
  }
 
  .detail-view.active {
    opacity: 1;
    pointer-events: auto;
  }
 
  .detail-overlay {
    position: absolute;
    inset: 0;
    background: rgba(10, 22, 40, 0.85);
    backdrop-filter: blur(15px);
  }
 
  .detail-container {
    position: relative;
    max-width: 1400px;
    height: 100%;
    margin: 0 auto;
    padding: 7rem 2rem 3rem;
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: 3rem;
    align-items: center;
  }
 
  /* Vertical separator running down the middle of the detail container */
  .detail-container::before {
    content: '';
    position: absolute;
    left: 33.33%;
    top: 10%;
    bottom: 10%;
    width: 1px;
    background: linear-gradient(180deg,
      transparent,
      rgba(232, 197, 116, 0.35) 15%,
      rgba(232, 197, 116, 0.35) 85%,
      transparent
    );
    pointer-events: none;
  }
 
  /* BACK TO CASES button at the top of the detail view */
  .detail-back-top {
    position: absolute;
    top: 1.75rem;
    left: 2rem;
    z-index: 2;
    display: inline-flex;
