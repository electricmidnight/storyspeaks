---
import BaseLayout from '../layouts/BaseLayout.astro';
 
const phases = [
  {
    letter: 'P',
    name: 'PEOPLE',
    colorHex: '#d4756f',
    colorRgb: '212, 117, 111',
    subtitle: 'The Heart of every story.',
    description: 'Characters with desire, uniqueness, and complexity — found, drawn out, and revealed so your audience sees themselves in them.',
  },
  {
    letter: 'R',
    name: 'RESONANCE',
    colorHex: '#f5d589',
    colorRgb: '245, 213, 137',
    subtitle: 'The Why behind the narrative.',
    description: 'Stories crafted with clear purpose that resonate deeply — changing attitudes and driving action.',
  },
  {
    letter: 'I',
    name: 'IMMERSION',
    colorHex: '#a3bc7e',
    colorRgb: '163, 188, 126',
    subtitle: 'The Story Structure that transports.',
    description: 'Stories built to be so engaging that audiences become fully absorbed in your narrative world.',
  },
  {
    letter: 'S',
    name: 'STORYFINDING',
    colorHex: '#86a8c9',
    colorRgb: '134, 168, 201',
    subtitle: 'The Discovery process.',
    description: 'A systematic search for authentic narratives — pre-interviews, uncovering the specific moments.',
  },
  {
    letter: 'M',
    name: 'MOMENTS',
    colorHex: '#a583b5',
    colorRgb: '165, 131, 181',
    subtitle: 'The Visual language.',
    description: 'Moments captured to show rather than tell, using symbolism and surprise to amplify meaning.',
  },
];
---
 
<BaseLayout
  title="Process Animation Test — The Story Speaks"
  description="Interactive PRISM prototype with thin-line/wedge hover."
>
  <main class="test-page">
 
    <div class="test-banner">
      <p class="test-banner-label">TEST PAGE — Interactive PRISM</p>
      <a href="/process/" class="test-banner-link">← Back to /process/</a>
    </div>
 
    <section class="test-hero">
      <p class="eyebrow">Animation Prototype</p>
      <h1 class="test-headline">
        <span class="prism-multicolor">
          <span style="color:#d4756f">P</span><span style="color:#f5d589">R</span><span style="color:#a3bc7e">I</span><span style="color:#86a8c9">S</span><span style="color:#a583b5">M</span>
        </span>
      </h1>
      <p class="test-intro">
        Hover or tap each ray to reveal that phase of the methodology.
      </p>
    </section>
 
    <!-- The entire prism scene lives inside .prism-row. SVG spans the full row -->
    <section class="prism-section">
      <div class="prism-row" id="prismRow">
 
        <!-- SVG with rays + invisible hover polygons. Covers the entire row. -->
        <svg class="rays-svg" id="raysSvg" viewBox="0 0 1400 500" preserveAspectRatio="none">
          <defs>
            <linearGradient id="ray-grad-p" gradientUnits="userSpaceOnUse"><stop offset="0%" stop-color="rgba(212, 117, 111, 0.35)"/><stop offset="100%" stop-color="rgba(212, 117, 111, 0.95)"/></linearGradient>
            <linearGradient id="ray-grad-r" gradientUnits="userSpaceOnUse"><stop offset="0%" stop-color="rgba(245, 213, 137, 0.35)"/><stop offset="100%" stop-color="rgba(245, 213, 137, 0.95)"/></linearGradient>
            <linearGradient id="ray-grad-i" gradientUnits="userSpaceOnUse"><stop offset="0%" stop-color="rgba(163, 188, 126, 0.35)"/><stop offset="100%" stop-color="rgba(163, 188, 126, 0.95)"/></linearGradient>
            <linearGradient id="ray-grad-s" gradientUnits="userSpaceOnUse"><stop offset="0%" stop-color="rgba(134, 168, 201, 0.35)"/><stop offset="100%" stop-color="rgba(134, 168, 201, 0.95)"/></linearGradient>
            <linearGradient id="ray-grad-m" gradientUnits="userSpaceOnUse"><stop offset="0%" stop-color="rgba(165, 131, 181, 0.35)"/><stop offset="100%" stop-color="rgba(165, 131, 181, 0.95)"/></linearGradient>
 
            <filter id="ray-glow" x="-20%" y="-50%" width="140%" height="200%">
              <feGaussianBlur in="SourceGraphic" stdDeviation="2"/>
            </filter>
          </defs>
 
          <!-- Visible rays — JS sets initial geometry after layout -->
          <polygon id="ray-p" class="prism-ray" data-phase="p" points="0,0 0,0 0,0" fill="url(#ray-grad-p)" style="filter: url(#ray-glow); opacity: 0;"/>
          <polygon id="ray-r" class="prism-ray" data-phase="r" points="0,0 0,0 0,0" fill="url(#ray-grad-r)" style="filter: url(#ray-glow); opacity: 0;"/>
          <polygon id="ray-i" class="prism-ray" data-phase="i" points="0,0 0,0 0,0" fill="url(#ray-grad-i)" style="filter: url(#ray-glow); opacity: 0;"/>
          <polygon id="ray-s" class="prism-ray" data-phase="s" points="0,0 0,0 0,0" fill="url(#ray-grad-s)" style="filter: url(#ray-glow); opacity: 0;"/>
          <polygon id="ray-m" class="prism-ray" data-phase="m" points="0,0 0,0 0,0" fill="url(#ray-grad-m)" style="filter: url(#ray-glow); opacity: 0;"/>
 
          <!-- Invisible hover polygons — wide wedge shape catches the cursor easily -->
          <polygon id="hover-p" class="hover-area" data-phase="p" points="0,0 0,0 0,0" fill="transparent" style="pointer-events: all; cursor: pointer;"/>
          <polygon id="hover-r" class="hover-area" data-phase="r" points="0,0 0,0 0,0" fill="transparent" style="pointer-events: all; cursor: pointer;"/>
          <polygon id="hover-i" class="hover-area" data-phase="i" points="0,0 0,0 0,0" fill="transparent" style="pointer-events: all; cursor: pointer;"/>
          <polygon id="hover-s" class="hover-area" data-phase="s" points="0,0 0,0 0,0" fill="transparent" style="pointer-events: all; cursor: pointer;"/>
          <polygon id="hover-m" class="hover-area" data-phase="m" points="0,0 0,0 0,0" fill="transparent" style="pointer-events: all; cursor: pointer;"/>
        </svg>
 
        <!-- LEFT: prism gem + RAW STORY label -->
        <div class="prism-side">
          <div class="raw-story-label">RAW STORY</div>
          <div class="prism-gem" id="prismGem">
            <svg class="prism-pyramid-svg" viewBox="0 0 100 100" preserveAspectRatio="xMidYMid meet">
              <defs>
                <linearGradient id="prism-front-grad" x1="0%" y1="0%" x2="100%" y2="100%">
                  <stop offset="0%"   stop-color="rgba(212, 117, 111, 0.85)"/>
                  <stop offset="25%"  stop-color="rgba(245, 213, 137, 0.85)"/>
                  <stop offset="50%"  stop-color="rgba(163, 188, 126, 0.85)"/>
                  <stop offset="75%"  stop-color="rgba(134, 168, 201, 0.85)"/>
                  <stop offset="100%" stop-color="rgba(165, 131, 181, 0.85)"/>
                </linearGradient>
                <linearGradient id="prism-side-grad" x1="0%" y1="0%" x2="0%" y2="100%">
                  <stop offset="0%"   stop-color="rgba(134, 168, 201, 0.45)"/>
                  <stop offset="100%" stop-color="rgba(165, 131, 181, 0.45)"/>
                </linearGradient>
                <radialGradient id="prism-highlight-grad">
                  <stop offset="0%"   stop-color="rgba(255,255,255,0.6)"/>
                  <stop offset="100%" stop-color="rgba(255,255,255,0)"/>
                </radialGradient>
              </defs>
              <polygon points="50,10 8,82 90,82" fill="url(#prism-front-grad)" stroke="rgba(255,255,255,0.5)" stroke-width="1.5"/>
              <polygon points="50,10 90,82 95,86" fill="url(#prism-side-grad)" stroke="rgba(255,255,255,0.2)" stroke-width="1"/>
              <ellipse cx="50" cy="36" rx="18" ry="22" fill="url(#prism-highlight-grad)"/>
              <circle cx="50" cy="10" r="2.5" fill="rgba(255,255,255,0.95)"/>
            </svg>
          </div>
        </div>
 
        <!-- RIGHT: prism items, vertically stacked. Each row has its own letter/word/description -->
        <div class="items-container" id="itemsContainer">
          {phases.map((phase) => (
            <div
              class={`prism-item letter-${phase.letter.toLowerCase()}`}
              data-phase={phase.letter.toLowerCase()}
              style={`--phase-color: ${phase.colorHex}; --phase-color-rgb: ${phase.colorRgb};`}
            >
              <div class="letter-box">{phase.letter}</div>
              <div class="word-title">{phase.name}</div>
              <div class="description">
                <span class="desc-subtitle">{phase.subtitle}</span> {phase.description}
              </div>
            </div>
          ))}
        </div>
 
      </div>
    </section>
 
  </main>
</BaseLayout>
 
<style>
  .test-page {
    background: var(--color-bg-deep);
    min-height: 100vh;
    padding-top: 6rem;
    padding-bottom: 6rem;
  }
 
  .test-banner {
    max-width: 1200px;
    margin: 0 auto 3rem;
    padding: 1rem 2rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: color-mix(in srgb, var(--color-accent) 8%, transparent);
    border: 1px solid color-mix(in srgb, var(--color-accent) 30%, transparent);
    border-radius: 4px;
  }
 
  .test-banner-label {
    font-family: var(--font-wordmark, 'Fjalla One', sans-serif);
    font-size: 0.75rem;
    color: var(--color-accent);
    letter-spacing: 0.2em;
    margin: 0;
  }
 
  .test-banner-link {
    font-family: var(--font-sans);
    font-size: 0.8rem;
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color 0.2s ease;
  }
 
  .test-banner-link:hover {
    color: var(--color-accent);
  }
 
  .test-hero {
    max-width: 760px;
    margin: 0 auto 3rem;
    padding: 0 2rem;
    text-align: center;
  }
 
  .test-headline {
    font-family: var(--font-sans);
    font-size: clamp(2.5rem, 8vw, 5rem);
    font-weight: 200;
    line-height: 1;
    letter-spacing: -0.05em;
    margin: 1rem 0 1.5rem;
  }
 
  .prism-multicolor {
    font-weight: 200;
  }
 
  .test-intro {
    font-size: clamp(0.9rem, 1.3vw, 1rem);
    line-height: 1.7;
    color: var(--color-text-muted);
    max-width: 480px;
    margin: 0 auto;
    font-weight: 300;
  }
 
  /* ============ THE PRISM SECTION ============ */
  .prism-section {
    max-width: 1400px;
    margin: 4rem auto 0;
    padding: 0 2rem;
  }
 
  .prism-row {
    position: relative;
    display: flex;
    align-items: stretch;
    min-height: 500px;
    gap: 0;
  }
 
  /* SVG: full-row absolute overlay with overflow:visible so rays can extend anywhere */
  .rays-svg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    overflow: visible;
    pointer-events: none;
    z-index: 1;
  }
 
  .prism-ray {
    transition: opacity 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    pointer-events: none;
  }
 
  /* Hover catchers stay clickable even though parent SVG has pointer-events:none */
  .hover-area {
    pointer-events: all;
    cursor: pointer;
  }
 
  /* ============ LEFT: PRISM SIDE ============ */
  .prism-side {
    position: relative;
    width: 280px;
    flex-shrink: 0;
    z-index: 2;
    display: flex;
    align-items: center;
    justify-content: flex-end;
    padding-right: 30px;
  }
 
  .raw-story-label {
    position: absolute;
    left: 0;
    top: 50%;
    transform: translateY(-50%);
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.7);
    letter-spacing: 0.25em;
    text-transform: uppercase;
    pointer-events: none;
    text-shadow: 0 0 12px rgba(245, 213, 137, 0.45);
  }
 
  .prism-gem {
    width: 95px;
    height: 95px;
    position: relative;
    z-index: 3;
    filter: drop-shadow(0 0 28px rgba(245, 213, 137, 0.45));
    animation: prismPulse 4s ease-in-out infinite;
    pointer-events: none;
  }
 
  .prism-pyramid-svg {
    width: 100%;
    height: 100%;
    display: block;
  }
 
  @keyframes prismPulse {
    0%, 100% {
      filter: drop-shadow(0 0 22px rgba(245, 213, 137, 0.35));
    }
    50% {
      filter: drop-shadow(0 0 38px rgba(245, 213, 137, 0.6));
    }
  }
 
  /* ============ RIGHT: PRISM ITEMS ============ */
  .items-container {
    flex: 1;
    position: relative;
    z-index: 4;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 14px;
    padding: 0 2rem 0 0;
  }
 
  .prism-item {
    position: relative;
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.8rem 1.5rem 0.8rem 1rem;
    height: 72px;
    border: 1px solid transparent;
    border-radius: 0 4px 4px 0;
    cursor: pointer;
    transition: background 0.4s cubic-bezier(0.16, 1, 0.3, 1),
                border-color 0.4s cubic-bezier(0.16, 1, 0.3, 1),
                box-shadow 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }
 
  /* Letter box — always visible at rest */
  .letter-box {
    flex-shrink: 0;
    width: 56px;
    height: 56px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-sans);
    font-size: 1.85rem;
    font-weight: 300;
    color: var(--phase-color);
    border: 1.5px solid color-mix(in srgb, var(--phase-color) 75%, transparent);
    background: color-mix(in srgb, var(--phase-color) 12%, transparent);
    border-radius: 4px;
    text-shadow: 0 0 12px color-mix(in srgb, var(--phase-color) 70%, transparent);
    transition: opacity 0.4s cubic-bezier(0.16, 1, 0.3, 1),
                transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }
 
  /* Word title — sits right of the letter box at rest */
  .word-title {
    flex-shrink: 0;
    font-family: var(--font-sans);
    font-size: 1.15rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    color: var(--phase-color);
    line-height: 1;
    text-shadow: 0 0 14px color-mix(in srgb, var(--phase-color) 50%, transparent);
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }
 
  /* Description: absolutely positioned, hidden off-screen at rest */
  .description {
    position: absolute;
    top: 50%;
    right: -100%;
    transform: translateY(-50%);
    width: calc(100% - 240px); /* leaves space for letter-box + word-title on left */
    max-width: 520px;
    font-family: var(--font-sans);
    font-size: 0.88rem;
    font-weight: 300;
    line-height: 1.5;
    color: rgba(255, 255, 255, 0.88);
    opacity: 0;
    transition: right 0.45s cubic-bezier(0.16, 1, 0.3, 1),
                opacity 0.45s cubic-bezier(0.16, 1, 0.3, 1);
    pointer-events: none;
  }
 
  .desc-subtitle {
    font-style: italic;
    color: var(--phase-color);
  }
 
  /* ============ ACTIVE / HOVER STATE ============ */
  .prism-item.active {
    background: color-mix(in srgb, var(--phase-color) 18%, transparent);
    border-color: color-mix(in srgb, var(--phase-color) 55%, transparent);
    border-left-color: transparent; /* visually connects to ray on the left */
    box-shadow: 0 0 28px color-mix(in srgb, var(--phase-color) 45%, transparent),
                0 0 56px color-mix(in srgb, var(--phase-color) 22%, transparent);
  }
 
  .prism-item.active .letter-box {
    opacity: 0;
    transform: scale(0.7);
  }
 
  .prism-item.active .word-title {
    transform: translateX(-72px); /* slides into where letter-box was */
  }
 
  .prism-item.active .description {
    right: 1.5rem;
    opacity: 1;
  }
 
  /* ============ MOBILE LAYOUT ============ */
  @media (max-width: 768px) {
    .prism-section {
      padding: 0 1rem;
    }
 
    .prism-row {
      flex-direction: column;
      align-items: center;
      min-height: auto;
      gap: 2rem;
    }
 
    .rays-svg {
      display: none; /* Hide rays on mobile, use simple expand interaction */
    }
 
    .prism-side {
      width: auto;
      padding-right: 0;
      padding-top: 1rem;
    }
 
    .raw-story-label {
      position: static;
      transform: none;
      margin-bottom: 1rem;
      text-align: center;
    }
 
    .items-container {
      width: 100%;
      max-width: 480px;
      padding: 0;
      gap: 8px;
    }
 
    .prism-item {
      height: auto;
      flex-wrap: wrap;
      padding: 0.85rem 1rem;
      border: 1px solid color-mix(in srgb, var(--phase-color) 35%, transparent);
      border-radius: 4px;
      background: color-mix(in srgb, var(--phase-color) 6%, transparent);
    }
 
    .description {
      position: static;
      transform: none;
      width: 100%;
      max-width: 100%;
      max-height: 0;
      overflow: hidden;
      opacity: 0;
      margin-top: 0;
      padding-top: 0;
      transition: max-height 0.4s ease, opacity 0.4s ease, padding-top 0.4s ease;
    }
 
    .prism-item.active {
      border-left-color: color-mix(in srgb, var(--phase-color) 55%, transparent);
    }
 
    .prism-item.active .letter-box {
      opacity: 1;
      transform: none;
    }
 
    .prism-item.active .word-title {
      transform: none;
    }
 
    .prism-item.active .description {
      max-height: 200px;
      opacity: 1;
      padding-top: 0.5rem;
      margin-top: 0.25rem;
    }
  }
</style>
 
<script is:inline>
  (function () {
    'use strict';
 
    var THIN_HALF = 1.5;   // half-thickness of resting thin line
    var WEDGE_HALF = 36;   // half-height of expanded wedge at target end
    var HOVER_HALF = 50;   // hover catcher slightly wider than visible wedge for forgiving cursor
 
    var phases = ['p', 'r', 'i', 's', 'm'];
 
    function computeGeometry() {
      var row = document.getElementById('prismRow');
      var gem = document.getElementById('prismGem');
      var svg = document.getElementById('raysSvg');
      if (!row || !gem || !svg) return;
 
      var rowRect = row.getBoundingClientRect();
      var gemRect = gem.getBoundingClientRect();
 
      // Set SVG viewBox to match the row's actual pixel size (1:1 coords)
      svg.setAttribute('viewBox', '0 0 ' + rowRect.width + ' ' + rowRect.height);
 
      // Prism center in row-local pixel coords (= SVG viewBox coords)
      var prismX = gemRect.left - rowRect.left + gemRect.width / 2;
      var prismY = gemRect.top - rowRect.top + gemRect.height / 2;
 
      phases.forEach(function (phase) {
        var item = document.querySelector('.prism-item[data-phase="' + phase + '"]');
        if (!item) return;
        var itemRect = item.getBoundingClientRect();
 
        // Ray target: left edge of the prism-item (just before its colored background)
        var targetX = itemRect.left - rowRect.left;
        var targetY = itemRect.top - rowRect.top + itemRect.height / 2;
 
        // Thin line geometry (rest state)
        var thinPoints =
          prismX + ',' + prismY + ' ' +
          targetX + ',' + (targetY - THIN_HALF) + ' ' +
          targetX + ',' + (targetY + THIN_HALF);
 
        // Wedge geometry (hover state) — visible wedge
        var wedgePoints =
          prismX + ',' + prismY + ' ' +
          targetX + ',' + (targetY - WEDGE_HALF) + ' ' +
          targetX + ',' + (targetY + WEDGE_HALF);
 
        // Hover catcher (slightly wider than wedge)
        var hoverPoints =
          prismX + ',' + prismY + ' ' +
          targetX + ',' + (targetY - HOVER_HALF) + ' ' +
          targetX + ',' + (targetY + HOVER_HALF);
 
        var ray = document.getElementById('ray-' + phase);
        if (ray) {
          ray.dataset.thinPoints = thinPoints;
          ray.dataset.wedgePoints = wedgePoints;
          ray.setAttribute('points', thinPoints);
          ray.style.opacity = '0.9';
 
          // Update the gradient direction to follow the ray's actual path
          var grad = document.getElementById('ray-grad-' + phase);
          if (grad) {
            grad.setAttribute('x1', String(prismX));
            grad.setAttribute('y1', String(prismY));
            grad.setAttribute('x2', String(targetX));
            grad.setAttribute('y2', String(targetY));
          }
        }
 
        var hoverArea = document.getElementById('hover-' + phase);
        if (hoverArea) {
          hoverArea.setAttribute('points', hoverPoints);
        }
      });
    }
 
    function activate(phase) {
      // Expand this ray to wedge, others stay thin
      phases.forEach(function (p) {
        var ray = document.getElementById('ray-' + p);
        if (!ray) return;
        ray.style.transition = 'opacity 0.35s ease, points 0.35s cubic-bezier(0.16, 1, 0.3, 1)';
        if (p === phase) {
          ray.setAttribute('points', ray.dataset.wedgePoints);
          ray.style.opacity = '0.95';
        } else {
          ray.setAttribute('points', ray.dataset.thinPoints);
          ray.style.opacity = '0.5';
        }
      });
 
      // Add active class to matching item, remove from others
      var items = document.querySelectorAll('.prism-item');
      for (var i = 0; i < items.length; i++) {
        if (items[i].getAttribute('data-phase') === phase) {
          items[i].classList.add('active');
        } else {
          items[i].classList.remove('active');
        }
      }
    }
 
    function deactivateAll() {
      phases.forEach(function (p) {
        var ray = document.getElementById('ray-' + p);
        if (!ray) return;
        ray.style.transition = 'opacity 0.35s ease, points 0.35s cubic-bezier(0.16, 1, 0.3, 1)';
        ray.setAttribute('points', ray.dataset.thinPoints);
        ray.style.opacity = '0.9';
      });
      var items = document.querySelectorAll('.prism-item');
      for (var i = 0; i < items.length; i++) {
        items[i].classList.remove('active');
      }
    }
 
    function attachHandlers() {
      // 1) Hover catchers in SVG (the wide wedge zones)
      phases.forEach(function (phase) {
        var hoverArea = document.getElementById('hover-' + phase);
        if (hoverArea) {
          hoverArea.addEventListener('mouseenter', function () {
            activate(phase);
          });
          hoverArea.addEventListener('mouseleave', function (e) {
            // Only deactivate if cursor isn't moving to the prism-item
            var toEl = e.relatedTarget;
            if (toEl && toEl.closest && toEl.closest('.prism-item[data-phase="' + phase + '"]')) {
              return; // ignore, item handler will take over
            }
            deactivateAll();
          });
        }
      });
 
      // 2) Direct hover on prism-items (so user can hover the letter/word/description too)
      var items = document.querySelectorAll('.prism-item');
      for (var i = 0; i < items.length; i++) {
        (function (item) {
          var phase = item.getAttribute('data-phase');
          item.addEventListener('mouseenter', function () {
            activate(phase);
          });
          item.addEventListener('mouseleave', function (e) {
            // Only deactivate if cursor isn't moving back to the SVG hover area
            var toEl = e.relatedTarget;
            if (toEl && toEl.id === 'hover-' + phase) {
              return;
            }
            deactivateAll();
          });
          // Tap/click for mobile
          item.addEventListener('click', function () {
            if (item.classList.contains('active')) {
              if (window.innerWidth < 769) {
                deactivateAll();
              }
            } else {
              activate(phase);
            }
          });
        })(items[i]);
      }
    }
 
    function init() {
      // Wait a frame so layout settles before measuring
      requestAnimationFrame(function () {
        computeGeometry();
        attachHandlers();
      });
 
      // Recompute geometry on resize
      var resizeTimer = null;
      window.addEventListener('resize', function () {
        clearTimeout(resizeTimer);
        resizeTimer = setTimeout(function () {
          deactivateAll();
          computeGeometry();
        }, 150);
      });
 
      console.log('[Process Test] Interactive prism initialized (faithful port)');
    }
 
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init);
    } else {
      init();
    }
  })();
</script>
