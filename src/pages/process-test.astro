---
import BaseLayout from '../layouts/BaseLayout.astro';
 
// Each phase: letter, name, color, italic subtitle, full description
const phases = [
  {
    letter: 'P',
    name: 'PEOPLE',
    colorHex: '#d4756f',
    colorRgb: '212, 117, 111',
    subtitle: 'The Heart of every story.',
    description: 'Characters with desire, uniqueness, and complexity — found, drawn out, and revealed so your audience sees themselves in them.',
  },
  {
    letter: 'R',
    name: 'RESONANCE',
    colorHex: '#f5d589',
    colorRgb: '245, 213, 137',
    subtitle: 'The Why behind the narrative.',
    description: 'Stories crafted with clear purpose that resonate deeply — changing attitudes and driving action.',
  },
  {
    letter: 'I',
    name: 'IMMERSION',
    colorHex: '#a3bc7e',
    colorRgb: '163, 188, 126',
    subtitle: 'The Story Structure that transports.',
    description: 'Stories built to be so engaging that audiences become fully absorbed in your narrative world.',
  },
  {
    letter: 'S',
    name: 'STORYFINDING',
    colorHex: '#86a8c9',
    colorRgb: '134, 168, 201',
    subtitle: 'The Discovery process.',
    description: 'A systematic search for authentic narratives — pre-interviews, uncovering the specific moments.',
  },
  {
    letter: 'M',
    name: 'MOMENTS',
    colorHex: '#a583b5',
    colorRgb: '165, 131, 181',
    subtitle: 'The Visual language.',
    description: 'Moments captured to show rather than tell, using symbolism and surprise to amplify meaning.',
  },
];
---
 
<BaseLayout
  title="Process Animation Test — The Story Speaks"
  description="Interactive PRISM prototype — hover each ray to reveal its phase."
>
  <main class="test-page">
 
    <div class="test-banner">
      <p class="test-banner-label">TEST PAGE — Interactive PRISM</p>
      <a href="/process/" class="test-banner-link">← Back to /process/</a>
    </div>
 
    <section class="test-hero">
      <p class="eyebrow">Animation Prototype</p>
      <h1 class="test-headline">
        <span class="prism-multicolor">
          <span style="color:#d4756f">P</span><span style="color:#f5d589">R</span><span style="color:#a3bc7e">I</span><span style="color:#86a8c9">S</span><span style="color:#a583b5">M</span>
        </span>
      </h1>
      <p class="test-intro">
        Hover or tap each ray to reveal that phase of the methodology.
      </p>
    </section>
 
    <!-- The prism stage — flex row: prism container on left, items container on right -->
    <section class="prism-section">
      <div class="prism-row">
 
        <!-- Left: the animation container with the prism gem, raw story label, and rays SVG -->
        <div class="prism-animation-container" id="prismContainer">
 
          <div class="raw-story-label">RAW STORY</div>
 
          <!-- Faceted prism gem in the center -->
          <div class="prism-center" id="prismCenter">
            <svg class="prism-pyramid-svg" viewBox="0 0 100 100" preserveAspectRatio="xMidYMid meet">
              <defs>
                <linearGradient id="prism-front-grad" x1="0%" y1="0%" x2="100%" y2="100%">
                  <stop offset="0%"   stop-color="rgba(212, 117, 111, 0.8)"/>
                  <stop offset="25%"  stop-color="rgba(245, 213, 137, 0.8)"/>
                  <stop offset="50%"  stop-color="rgba(163, 188, 126, 0.8)"/>
                  <stop offset="75%"  stop-color="rgba(134, 168, 201, 0.8)"/>
                  <stop offset="100%" stop-color="rgba(165, 131, 181, 0.8)"/>
                </linearGradient>
                <linearGradient id="prism-side-grad" x1="0%" y1="0%" x2="0%" y2="100%">
                  <stop offset="0%"   stop-color="rgba(134, 168, 201, 0.5)"/>
                  <stop offset="100%" stop-color="rgba(165, 131, 181, 0.5)"/>
                </linearGradient>
                <radialGradient id="prism-highlight-grad">
                  <stop offset="0%"   stop-color="rgba(255,255,255,0.6)"/>
                  <stop offset="100%" stop-color="rgba(255,255,255,0)"/>
                </radialGradient>
              </defs>
              <!-- Front face -->
              <polygon points="50,10 8,82 90,82" fill="url(#prism-front-grad)" stroke="rgba(255,255,255,0.45)" stroke-width="1.5"/>
              <!-- Right side face (depth) -->
              <polygon points="50,10 90,82 95,86" fill="url(#prism-side-grad)" stroke="rgba(255,255,255,0.2)" stroke-width="1"/>
              <!-- Glass highlight -->
              <ellipse cx="50" cy="36" rx="18" ry="22" fill="url(#prism-highlight-grad)"/>
              <!-- Apex -->
              <circle cx="50" cy="10" r="2.5" fill="rgba(255,255,255,0.95)"/>
            </svg>
          </div>
 
          <!-- SVG holding the rays and invisible hover polygons -->
          <svg class="animation-svg" viewBox="0 0 450 450" preserveAspectRatio="none">
            <defs>
              <linearGradient id="ray-gradient-p"><stop offset="0%" stop-color="rgba(212, 117, 111, 0.4)"/><stop offset="100%" stop-color="rgba(212, 117, 111, 0.9)"/></linearGradient>
              <linearGradient id="ray-gradient-r"><stop offset="0%" stop-color="rgba(245, 213, 137, 0.4)"/><stop offset="100%" stop-color="rgba(245, 213, 137, 0.9)"/></linearGradient>
              <linearGradient id="ray-gradient-i"><stop offset="0%" stop-color="rgba(163, 188, 126, 0.4)"/><stop offset="100%" stop-color="rgba(163, 188, 126, 0.9)"/></linearGradient>
              <linearGradient id="ray-gradient-s"><stop offset="0%" stop-color="rgba(134, 168, 201, 0.4)"/><stop offset="100%" stop-color="rgba(134, 168, 201, 0.9)"/></linearGradient>
              <linearGradient id="ray-gradient-m"><stop offset="0%" stop-color="rgba(165, 131, 181, 0.4)"/><stop offset="100%" stop-color="rgba(165, 131, 181, 0.9)"/></linearGradient>
 
              <filter id="ray-glow" x="-20%" y="-50%" width="140%" height="200%">
                <feGaussianBlur in="SourceGraphic" stdDeviation="2"/>
              </filter>
            </defs>
 
            <!-- Visible rays — start collapsed at prism center; JS positions them on init -->
            <polygon id="ray-p" class="prism-ray" points="225,225 225,225 225,225"
              fill="url(#ray-gradient-p)" style="opacity: 0; filter: url(#ray-glow);"/>
            <polygon id="ray-r" class="prism-ray" points="225,225 225,225 225,225"
              fill="url(#ray-gradient-r)" style="opacity: 0; filter: url(#ray-glow);"/>
            <polygon id="ray-i" class="prism-ray" points="225,225 225,225 225,225"
              fill="url(#ray-gradient-i)" style="opacity: 0; filter: url(#ray-glow);"/>
            <polygon id="ray-s" class="prism-ray" points="225,225 225,225 225,225"
              fill="url(#ray-gradient-s)" style="opacity: 0; filter: url(#ray-glow);"/>
            <polygon id="ray-m" class="prism-ray" points="225,225 225,225 225,225"
              fill="url(#ray-gradient-m)" style="opacity: 0; filter: url(#ray-glow);"/>
 
            <!-- Invisible hover polygons (same shape as the expanded wedge) — these catch the cursor -->
            <polygon id="hover-area-p" class="hover-area" data-phase="p" points="225,225 225,225 225,225" fill="transparent" style="cursor: pointer; pointer-events: all;"/>
            <polygon id="hover-area-r" class="hover-area" data-phase="r" points="225,225 225,225 225,225" fill="transparent" style="cursor: pointer; pointer-events: all;"/>
            <polygon id="hover-area-i" class="hover-area" data-phase="i" points="225,225 225,225 225,225" fill="transparent" style="cursor: pointer; pointer-events: all;"/>
            <polygon id="hover-area-s" class="hover-area" data-phase="s" points="225,225 225,225 225,225" fill="transparent" style="cursor: pointer; pointer-events: all;"/>
            <polygon id="hover-area-m" class="hover-area" data-phase="m" points="225,225 225,225 225,225" fill="transparent" style="cursor: pointer; pointer-events: all;"/>
          </svg>
        </div>
 
        <!-- Right: the prism items (letter box + word title + description) -->
        <div class="items-container" id="itemsContainer">
          {phases.map((phase) => (
            <div
              class={`prism-item letter-${phase.letter.toLowerCase()}`}
              data-phase={phase.letter.toLowerCase()}
              style={`--phase-color: ${phase.colorHex}; --phase-color-rgb: ${phase.colorRgb};`}
            >
              <div class="letter-box">{phase.letter}</div>
              <div class="item-content">
                <div class="word-title">{phase.name}</div>
                <div class="description">{phase.subtitle} {phase.description}</div>
              </div>
            </div>
          ))}
        </div>
 
      </div>
    </section>
 
  </main>
</BaseLayout>
 
<style>
  .test-page {
    background: var(--color-bg-deep);
    min-height: 100vh;
    padding-top: 6rem;
    padding-bottom: 6rem;
  }
 
  .test-banner {
    max-width: 1200px;
    margin: 0 auto 3rem;
    padding: 1rem 2rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: color-mix(in srgb, var(--color-accent) 8%, transparent);
    border: 1px solid color-mix(in srgb, var(--color-accent) 30%, transparent);
    border-radius: 4px;
  }
 
  .test-banner-label {
    font-family: var(--font-wordmark, 'Fjalla One', sans-serif);
    font-size: 0.75rem;
    color: var(--color-accent);
    letter-spacing: 0.2em;
    margin: 0;
  }
 
  .test-banner-link {
    font-family: var(--font-sans);
    font-size: 0.8rem;
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color 0.2s ease;
  }
 
  .test-banner-link:hover {
    color: var(--color-accent);
  }
 
  .test-hero {
    max-width: 760px;
    margin: 0 auto 3rem;
    padding: 0 2rem;
    text-align: center;
  }
 
  .test-headline {
    font-family: var(--font-sans);
    font-size: clamp(2.5rem, 8vw, 5rem);
    font-weight: 200;
    line-height: 1;
    letter-spacing: -0.05em;
    margin: 1rem 0 1.5rem;
  }
 
  .prism-multicolor {
    font-weight: 200;
  }
 
  .test-intro {
    font-size: clamp(0.9rem, 1.3vw, 1rem);
    line-height: 1.7;
    color: var(--color-text-muted);
    max-width: 480px;
    margin: 0 auto;
    font-weight: 300;
  }
 
  /* ============ THE PRISM SECTION ============ */
  .prism-section {
    max-width: 1400px;
    margin: 4rem auto 0;
    padding: 0 2rem;
  }
 
  .prism-row {
    display: flex;
    align-items: center;
    gap: 0;
    min-height: 500px;
    position: relative;
  }
 
  /* ============ PRISM ANIMATION CONTAINER ============ */
  .prism-animation-container {
    position: relative;
    width: 450px;
    height: 450px;
    flex-shrink: 0;
  }
 
  /* RAW STORY label */
  .raw-story-label {
    position: absolute;
    left: 50px;
    top: 50%;
    transform: translateY(-50%);
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.7);
    letter-spacing: 0.25em;
    text-transform: uppercase;
    pointer-events: none;
    z-index: 4;
    text-shadow: 0 0 12px rgba(245, 213, 137, 0.5);
  }
 
  /* Faceted prism gem at center */
  .prism-center {
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    width: 90px;
    height: 90px;
    z-index: 3;
    filter: drop-shadow(0 0 28px rgba(245, 213, 137, 0.45));
    animation: prismPulse 4s ease-in-out infinite;
    pointer-events: none;
  }
 
  .prism-pyramid-svg {
    width: 100%;
    height: 100%;
    display: block;
  }
 
  @keyframes prismPulse {
    0%, 100% {
      filter: drop-shadow(0 0 22px rgba(245, 213, 137, 0.35));
    }
    50% {
      filter: drop-shadow(0 0 38px rgba(245, 213, 137, 0.6));
    }
  }
 
  /* The SVG containing the rays and hover areas */
  .animation-svg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    overflow: visible;
    pointer-events: none;
    z-index: 2;
  }
 
  .prism-ray {
    transition: opacity 0.4s ease;
    pointer-events: none;
  }
 
  /* Hover polygons remain interactive */
  .hover-area {
    pointer-events: all;
  }
 
  /* ============ PRISM ITEMS (right column) ============ */
  .items-container {
    flex: 1;
    position: relative;
    z-index: 5;
    margin-left: -60px; /* Overlap the prism container so items start near the prism */
    padding: 1rem 0;
  }
 
  .prism-item {
    position: relative;
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.85rem 1rem;
    margin-bottom: 18px;
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    pointer-events: none; /* The hover polygon in the SVG catches the hover, not the item itself */
  }
 
  .prism-item:last-child {
    margin-bottom: 0;
  }
 
  /* Letter box — always visible */
  .letter-box {
    flex-shrink: 0;
    width: 54px;
    height: 54px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-sans);
    font-size: 1.75rem;
    font-weight: 300;
    color: var(--phase-color);
    border: 1.5px solid color-mix(in srgb, var(--phase-color) 75%, transparent);
    background: color-mix(in srgb, var(--phase-color) 12%, transparent);
    border-radius: 4px;
    text-shadow: 0 0 12px color-mix(in srgb, var(--phase-color) 70%, transparent);
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }
 
  /* Item content (word title + description) */
  .item-content {
    flex: 1;
    position: relative;
    min-width: 0;
  }
 
  .word-title {
    font-family: var(--font-sans);
    font-size: 1.05rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    color: var(--phase-color);
    line-height: 1;
    text-shadow: 0 0 12px color-mix(in srgb, var(--phase-color) 50%, transparent);
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }
 
  /* Description — hidden by default, revealed on hover */
  .description {
    position: absolute;
    top: 50%;
    left: 0;
    transform: translateY(-50%) translateX(-300px);
    font-family: var(--font-sans);
    font-size: 0.85rem;
    font-weight: 300;
    line-height: 1.5;
    color: rgba(255, 255, 255, 0.85);
    width: 480px;
    max-width: calc(100vw - 540px);
    padding-left: 0;
    opacity: 0;
    transition: opacity 0.45s cubic-bezier(0.16, 1, 0.3, 1), transform 0.45s cubic-bezier(0.16, 1, 0.3, 1);
    pointer-events: none;
  }
 
  /* HOVER / ACTIVE STATE */
  .prism-item.active {
    z-index: 10;
  }
 
  /* When active: letter box fades, word title shifts left, description fades in */
  .prism-item.active .letter-box {
    opacity: 0;
    transform: scale(0.7);
  }
 
  .prism-item.active .word-title {
    transform: translateX(-66px);
  }
 
  .prism-item.active .description {
    opacity: 1;
    transform: translateY(-50%) translateX(170px);
  }
 
  /* ============ DESKTOP REFINEMENTS ============ */
  @media (min-width: 992px) {
    .prism-row {
      min-height: 550px;
    }
 
    .letter-box {
      width: 60px;
      height: 60px;
      font-size: 2rem;
    }
 
    .word-title {
      font-size: 1.2rem;
    }
 
    .description {
      font-size: 0.95rem;
      width: 560px;
    }
 
    .prism-item.active .description {
      transform: translateY(-50%) translateX(180px);
    }
  }
 
  /* ============ MOBILE LAYOUT ============ */
  @media (max-width: 768px) {
    .prism-row {
      flex-direction: column;
      align-items: center;
      min-height: auto;
      gap: 1rem;
    }
 
    .prism-animation-container {
      width: 320px;
      height: 320px;
    }
 
    .raw-story-label {
      left: 30px;
      font-size: 0.65rem;
    }
 
    .items-container {
      width: 100%;
      max-width: 420px;
      margin-left: 0;
    }
 
    .prism-item {
      pointer-events: all; /* On mobile, item itself is tappable */
      cursor: pointer;
    }
 
    .description {
      position: static;
      transform: none;
      width: 100%;
      max-width: 100%;
      max-height: 0;
      overflow: hidden;
      margin-top: 0;
      opacity: 1;
      transition: max-height 0.4s ease, margin-top 0.4s ease;
    }
 
    .prism-item.active .letter-box {
      opacity: 1;
      transform: scale(1);
    }
 
    .prism-item.active .word-title {
      transform: none;
    }
 
    .prism-item.active .description {
      max-height: 250px;
      margin-top: 0.5rem;
      transform: none;
    }
  }
</style>
 
<script is:inline>
  (function () {
    'use strict';
 
    // SVG viewport is 450x450 with the prism center at (225, 225)
    var PRISM_CENTER_X = 225;
    var PRISM_CENTER_Y = 225;
    var LINE_THICKNESS = 1.5; // half-thickness of the resting thin line
    var WEDGE_HALF_HEIGHT = 40; // half-height of the expanded wedge at the target end
 
    var rayMap = {
      p: 'ray-p',
      r: 'ray-r',
      i: 'ray-i',
      s: 'ray-s',
      m: 'ray-m'
    };
    var hoverMap = {
      p: 'hover-area-p',
      r: 'hover-area-r',
      i: 'hover-area-i',
      s: 'hover-area-s',
      m: 'hover-area-m'
    };
 
    function computeRayGeometry() {
      var prismContainer = document.getElementById('prismContainer');
      if (!prismContainer) return;
 
      var containerRect = prismContainer.getBoundingClientRect();
      var phases = ['p', 'r', 'i', 's', 'm'];
 
      phases.forEach(function (phase) {
        var item = document.querySelector('.prism-item.letter-' + phase);
        if (!item) return;
        var letterBox = item.querySelector('.letter-box');
        if (!letterBox) return;
 
        var letterRect = letterBox.getBoundingClientRect();
 
        // Center of the letter box, in container-local pixel coordinates
        var targetXPixels = letterRect.left - containerRect.left + (letterRect.width / 2);
        var targetYPixels = letterRect.top - containerRect.top + (letterRect.height / 2);
 
        // Convert to SVG viewBox coordinates (0..450)
        var svgTargetX = (targetXPixels / prismContainer.offsetWidth) * 450;
        var svgTargetY = (targetYPixels / prismContainer.offsetHeight) * 450;
 
        // Thin-line geometry (rest state)
        var thinPoints =
          PRISM_CENTER_X + ',' + PRISM_CENTER_Y + ' ' +
          svgTargetX + ',' + (svgTargetY - LINE_THICKNESS) + ' ' +
          svgTargetX + ',' + (svgTargetY + LINE_THICKNESS);
 
        // Full wedge geometry (hover state)
        var wedgePoints =
          PRISM_CENTER_X + ',' + PRISM_CENTER_Y + ' ' +
          svgTargetX + ',' + (svgTargetY - WEDGE_HALF_HEIGHT) + ' ' +
          svgTargetX + ',' + (svgTargetY + WEDGE_HALF_HEIGHT);
 
        var ray = document.getElementById(rayMap[phase]);
        var hoverArea = document.getElementById(hoverMap[phase]);
 
        if (ray) {
          ray.dataset.thinPoints = thinPoints;
          ray.dataset.wedgePoints = wedgePoints;
          // Set initial thin-line state and make visible
          ray.setAttribute('points', thinPoints);
          ray.style.transition = 'opacity 0.5s ease';
          ray.style.opacity = '0.85';
        }
 
        if (hoverArea) {
          // The invisible hover polygon takes the WIDE wedge shape so it's easy to hit
          hoverArea.setAttribute('points', wedgePoints);
        }
      });
    }
 
    function activatePhase(phase) {
      // Expand this ray to the wedge, others stay thin
      var phases = ['p', 'r', 'i', 's', 'm'];
      phases.forEach(function (p) {
        var ray = document.getElementById(rayMap[p]);
        if (!ray) return;
        ray.style.transition = 'all 0.35s cubic-bezier(0.16, 1, 0.3, 1)';
        if (p === phase) {
          ray.setAttribute('points', ray.dataset.wedgePoints);
          ray.style.opacity = '0.9';
        } else {
          ray.setAttribute('points', ray.dataset.thinPoints);
          ray.style.opacity = '0.4';
        }
      });
 
      // Add active class to matching item
      var items = document.querySelectorAll('.prism-item');
      for (var i = 0; i < items.length; i++) {
        if (items[i].getAttribute('data-phase') === phase) {
          items[i].classList.add('active');
        } else {
          items[i].classList.remove('active');
        }
      }
    }
 
    function deactivateAll() {
      var phases = ['p', 'r', 'i', 's', 'm'];
      phases.forEach(function (p) {
        var ray = document.getElementById(rayMap[p]);
        if (!ray) return;
        ray.style.transition = 'all 0.35s cubic-bezier(0.16, 1, 0.3, 1)';
        ray.setAttribute('points', ray.dataset.thinPoints);
        ray.style.opacity = '0.85';
      });
 
      var items = document.querySelectorAll('.prism-item');
      for (var i = 0; i < items.length; i++) {
        items[i].classList.remove('active');
      }
    }
 
    function attachHoverHandlers() {
      var phases = ['p', 'r', 'i', 's', 'm'];
      phases.forEach(function (phase) {
        var hoverArea = document.getElementById(hoverMap[phase]);
        if (hoverArea) {
          hoverArea.addEventListener('mouseenter', function () {
            activatePhase(phase);
          });
          hoverArea.addEventListener('mouseleave', function () {
            deactivateAll();
          });
          // Click for keyboard/touch support
          hoverArea.addEventListener('click', function () {
            var item = document.querySelector('.prism-item[data-phase="' + phase + '"]');
            if (item && item.classList.contains('active')) {
              deactivateAll();
            } else {
              activatePhase(phase);
            }
          });
        }
      });
 
      // Mobile: tap on the item itself
      var items = document.querySelectorAll('.prism-item');
      for (var i = 0; i < items.length; i++) {
        (function (item) {
          item.addEventListener('click', function () {
            if (window.innerWidth < 769) {
              var phase = item.getAttribute('data-phase');
              if (item.classList.contains('active')) {
                deactivateAll();
              } else {
                activatePhase(phase);
              }
            }
          });
        })(items[i]);
      }
    }
 
    function init() {
      // Wait one frame so layout is settled before we measure
      requestAnimationFrame(function () {
        computeRayGeometry();
        attachHoverHandlers();
      });
 
      // Recalculate on resize (positions of items change with viewport)
      var resizeTimeout = null;
      window.addEventListener('resize', function () {
        clearTimeout(resizeTimeout);
        resizeTimeout = setTimeout(function () {
          deactivateAll();
          computeRayGeometry();
        }, 200);
      });
 
      console.log('[Process Test] Prism initialized with thin-line + wedge hover model');
    }
 
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init);
    } else {
      init();
    }
  })();
</script>
 
