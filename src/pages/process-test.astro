---
import BaseLayout from '../layouts/BaseLayout.astro';
 
const phases = [
  {
    letter: 'P',
    name: 'PEOPLE',
    colorHex: '#d4756f',
    colorRgb: '212, 117, 111',
    subtitle: 'The Heart of every story.',
    description: 'Characters with desire, uniqueness, and complexity — found, drawn out, and revealed so your audience sees themselves in them.',
  },
  {
    letter: 'R',
    name: 'RESONANCE',
    colorHex: '#f5d589',
    colorRgb: '245, 213, 137',
    subtitle: 'The Why behind the narrative.',
    description: 'Stories crafted with clear purpose that resonate deeply — changing attitudes and driving action.',
  },
  {
    letter: 'I',
    name: 'IMMERSION',
    colorHex: '#a3bc7e',
    colorRgb: '163, 188, 126',
    subtitle: 'The Story Structure that transports.',
    description: 'Stories built to be so engaging that audiences become fully absorbed in your narrative world.',
  },
  {
    letter: 'S',
    name: 'STORYFINDING',
    colorHex: '#86a8c9',
    colorRgb: '134, 168, 201',
    subtitle: 'The Discovery process.',
    description: 'A systematic search for authentic narratives — pre-interviews, uncovering the specific moments.',
  },
  {
    letter: 'M',
    name: 'MOMENTS',
    colorHex: '#a583b5',
    colorRgb: '165, 131, 181',
    subtitle: 'The Visual language.',
    description: 'Moments captured to show rather than tell, using symbolism and surprise to amplify meaning.',
  },
];
---
 
<BaseLayout
  title="Process Animation Test — The Story Speaks"
  description="Interactive PRISM prototype: hover each ray to reveal its phase."
>
  <main class="test-page">
 
    <div class="test-banner">
      <p class="test-banner-label">TEST PAGE — Interactive PRISM Prototype</p>
      <a href="/process/" class="test-banner-link">← Back to /process/</a>
    </div>
 
    <section class="test-hero">
      <p class="eyebrow">Interactive Prototype</p>
      <h1 class="test-headline">The <span class="prism-multicolor">
        <span style="color:#d4756f">P</span><span style="color:#f5d589">R</span><span style="color:#a3bc7e">I</span><span style="color:#86a8c9">S</span><span style="color:#a583b5">M</span>
      </span> Method</h1>
      <p class="test-intro">
        Hover over each ray to reveal that phase of the methodology. On mobile, tap each ray.
      </p>
    </section>
 
    <section class="prism-stage">
      <div class="prism-scene" id="prismScene">
 
        <!-- RAW STORY label -->
        <div class="raw-story-label">RAW STORY</div>
 
        <!-- The faceted prism in the center -->
        <div class="prism-gem" id="prismGem">
          <svg class="prism-gem-svg" viewBox="0 0 100 110" preserveAspectRatio="xMidYMid meet">
            <defs>
              <!-- Front face: vertical rainbow gradient (visible spectrum on the prism) -->
              <linearGradient id="prism-front-grad" x1="0%" y1="0%" x2="0%" y2="100%">
                <stop offset="0%"   stop-color="rgba(212, 117, 111, 0.85)"/>
                <stop offset="25%"  stop-color="rgba(245, 213, 137, 0.85)"/>
                <stop offset="50%"  stop-color="rgba(163, 188, 126, 0.85)"/>
                <stop offset="75%"  stop-color="rgba(134, 168, 201, 0.85)"/>
                <stop offset="100%" stop-color="rgba(165, 131, 181, 0.85)"/>
              </linearGradient>
              <!-- Right side face: darker, neutral -->
              <linearGradient id="prism-side-grad" x1="0%" y1="0%" x2="0%" y2="100%">
                <stop offset="0%"   stop-color="rgba(40, 55, 80, 0.85)"/>
                <stop offset="100%" stop-color="rgba(25, 35, 55, 0.85)"/>
              </linearGradient>
              <!-- Highlight overlay -->
              <linearGradient id="prism-highlight-grad" x1="0%" y1="0%" x2="0%" y2="100%">
                <stop offset="0%"   stop-color="rgba(255, 255, 255, 0.4)"/>
                <stop offset="40%"  stop-color="rgba(255, 255, 255, 0.1)"/>
                <stop offset="100%" stop-color="rgba(255, 255, 255, 0)"/>
              </linearGradient>
              <filter id="prism-glow" x="-30%" y="-30%" width="160%" height="160%">
                <feGaussianBlur in="SourceGraphic" stdDeviation="2"/>
                <feMerge>
                  <feMergeNode/>
                  <feMergeNode in="SourceGraphic"/>
                </feMerge>
              </filter>
            </defs>
 
            <!-- Right side face (3D depth) -->
            <polygon points="50,8 80,100 92,92" fill="url(#prism-side-grad)" stroke="rgba(255,255,255,0.3)" stroke-width="0.6"/>
            <!-- Front face (the rainbow) -->
            <polygon points="50,8 20,100 80,100" fill="url(#prism-front-grad)" stroke="rgba(255,255,255,0.55)" stroke-width="0.8"/>
            <!-- Highlight on the left edge of front face -->
            <polygon points="50,8 20,100 32,100 50,30" fill="url(#prism-highlight-grad)" opacity="0.6"/>
            <!-- Apex highlight -->
            <circle cx="50" cy="8" r="1.8" fill="rgba(255,255,255,0.95)"/>
          </svg>
        </div>
 
        <!-- SVG for rays — overflow:visible lets rays extend to the right edge -->
        <svg class="rays-svg" viewBox="0 0 1100 600" preserveAspectRatio="xMidYMid meet">
          <defs>
            <linearGradient id="ray-grad-p-test" gradientUnits="userSpaceOnUse" x1="225" y1="300" x2="1000" y2="120">
              <stop offset="0%" stop-color="rgba(212, 117, 111, 0.3)"/>
              <stop offset="100%" stop-color="rgba(212, 117, 111, 0.9)"/>
            </linearGradient>
            <linearGradient id="ray-grad-r-test" gradientUnits="userSpaceOnUse" x1="225" y1="300" x2="1000" y2="210">
              <stop offset="0%" stop-color="rgba(245, 213, 137, 0.3)"/>
              <stop offset="100%" stop-color="rgba(245, 213, 137, 0.9)"/>
            </linearGradient>
            <linearGradient id="ray-grad-i-test" gradientUnits="userSpaceOnUse" x1="225" y1="300" x2="1000" y2="300">
              <stop offset="0%" stop-color="rgba(163, 188, 126, 0.3)"/>
              <stop offset="100%" stop-color="rgba(163, 188, 126, 0.9)"/>
            </linearGradient>
            <linearGradient id="ray-grad-s-test" gradientUnits="userSpaceOnUse" x1="225" y1="300" x2="1000" y2="390">
              <stop offset="0%" stop-color="rgba(134, 168, 201, 0.3)"/>
              <stop offset="100%" stop-color="rgba(134, 168, 201, 0.9)"/>
            </linearGradient>
            <linearGradient id="ray-grad-m-test" gradientUnits="userSpaceOnUse" x1="225" y1="300" x2="1000" y2="480">
              <stop offset="0%" stop-color="rgba(165, 131, 181, 0.3)"/>
              <stop offset="100%" stop-color="rgba(165, 131, 181, 0.9)"/>
            </linearGradient>
            <filter id="ray-soft-blur" x="-20%" y="-50%" width="140%" height="200%">
              <feGaussianBlur in="SourceGraphic" stdDeviation="2"/>
            </filter>
          </defs>
 
          <!-- Five fanning rays — start narrow at the prism apex, widen at the right edge -->
          <polygon class="prism-ray" data-phase="p" id="rayP" points="225,300 1000,114 1000,126" fill="url(#ray-grad-p-test)" style="filter: url(#ray-soft-blur);"/>
          <polygon class="prism-ray" data-phase="r" id="rayR" points="225,300 1000,204 1000,216" fill="url(#ray-grad-r-test)" style="filter: url(#ray-soft-blur);"/>
          <polygon class="prism-ray" data-phase="i" id="rayI" points="225,300 1000,294 1000,306" fill="url(#ray-grad-i-test)" style="filter: url(#ray-soft-blur);"/>
          <polygon class="prism-ray" data-phase="s" id="rayS" points="225,300 1000,384 1000,396" fill="url(#ray-grad-s-test)" style="filter: url(#ray-soft-blur);"/>
          <polygon class="prism-ray" data-phase="m" id="rayM" points="225,300 1000,474 1000,486" fill="url(#ray-grad-m-test)" style="filter: url(#ray-soft-blur);"/>
        </svg>
 
        <!-- Five hover/tap zones, one per ray. These are wider regions that catch the cursor. -->
        <div class="ray-zones">
          {phases.map((phase) => (
            <div
              class={`ray-zone ray-zone-${phase.letter.toLowerCase()}`}
              data-phase={phase.letter.toLowerCase()}
              role="button"
              tabindex="0"
              aria-label={`Reveal ${phase.name} phase`}
            ></div>
          ))}
        </div>
 
        <!-- Phase reveal panels — one per ray, positioned at the right end of each ray -->
        <div class="phase-reveals">
          {phases.map((phase) => (
            <div
              class={`phase-reveal phase-reveal-${phase.letter.toLowerCase()}`}
              data-phase={phase.letter.toLowerCase()}
              style={`--phase-color: ${phase.colorHex}; --phase-color-rgb: ${phase.colorRgb};`}
            >
              <div class="phase-letter-badge">{phase.letter}</div>
              <div class="phase-text">
                <h3 class="phase-name">{phase.name}</h3>
                <p class="phase-subtitle">{phase.subtitle}</p>
                <p class="phase-description">{phase.description}</p>
              </div>
            </div>
          ))}
        </div>
 
      </div>
    </section>
 
  </main>
</BaseLayout>
 
<style>
  .test-page {
    background: var(--color-bg-deep);
    min-height: 100vh;
    padding-top: 6rem;
    padding-bottom: 6rem;
  }
 
  .test-banner {
    max-width: 1200px;
    margin: 0 auto 3rem;
    padding: 1rem 2rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: color-mix(in srgb, var(--color-accent) 8%, transparent);
    border: 1px solid color-mix(in srgb, var(--color-accent) 30%, transparent);
    border-radius: 4px;
  }
 
  .test-banner-label {
    font-family: var(--font-wordmark, 'Fjalla One', sans-serif);
    font-size: 0.75rem;
    color: var(--color-accent);
    letter-spacing: 0.2em;
    margin: 0;
  }
 
  .test-banner-link {
    font-family: var(--font-sans);
    font-size: 0.8rem;
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color 0.2s ease;
  }
 
  .test-banner-link:hover {
    color: var(--color-accent);
  }
 
  .test-hero {
    max-width: 760px;
    margin: 0 auto 3rem;
    padding: 0 2rem;
    text-align: center;
  }
 
  .test-headline {
    font-family: var(--font-sans);
    font-size: clamp(1.5rem, 4vw, 2.5rem);
    font-weight: 300;
    line-height: 1.2;
    letter-spacing: -0.025em;
    margin: 1rem 0 1.5rem;
  }
 
  .prism-multicolor {
    font-weight: 300;
  }
 
  .test-intro {
    font-size: clamp(0.9rem, 1.3vw, 1rem);
    line-height: 1.7;
    color: var(--color-text-muted);
    max-width: 540px;
    margin: 0 auto;
    font-weight: 300;
  }
 
  /* ============ THE PRISM STAGE ============ */
  .prism-stage {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 2rem;
  }
 
  .prism-scene {
    position: relative;
    width: 100%;
    height: clamp(500px, 65vh, 700px);
    margin: 0 auto;
  }
 
  /* RAW STORY label, left of prism */
  .raw-story-label {
    position: absolute;
    left: 8%;
    top: 50%;
    transform: translateY(-50%);
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.6);
    letter-spacing: 0.25em;
    text-transform: uppercase;
    pointer-events: none;
    z-index: 3;
  }
 
  /* The faceted prism gem in the center */
  .prism-gem {
    position: absolute;
    left: 15%;
    top: 50%;
    transform: translate(-50%, -50%);
    width: clamp(75px, 9vw, 110px);
    height: clamp(82px, 10vw, 121px);
    z-index: 4;
    filter: drop-shadow(0 0 25px rgba(245, 213, 137, 0.35));
    animation: prismPulse 4.5s ease-in-out infinite;
  }
 
  .prism-gem-svg {
    width: 100%;
    height: 100%;
    display: block;
  }
 
  @keyframes prismPulse {
    0%, 100% {
      filter: drop-shadow(0 0 22px rgba(245, 213, 137, 0.3));
    }
    50% {
      filter: drop-shadow(0 0 38px rgba(245, 213, 137, 0.55));
    }
  }
 
  /* The SVG holding the five rays */
  .rays-svg {
    position: absolute;
    left: 0;
    top: 0;
    width: 100%;
    height: 100%;
    overflow: visible;
    pointer-events: none;
    z-index: 2;
  }
 
  /* Default ray state: dim, ready to be activated */
  .prism-ray {
    opacity: 0.45;
    transition: opacity 0.45s cubic-bezier(0.16, 1, 0.3, 1), points 0.45s cubic-bezier(0.16, 1, 0.3, 1);
  }
 
  .prism-ray.dimmed {
    opacity: 0.15;
  }
 
  .prism-ray.active {
    opacity: 1;
  }
 
  /* ============ RAY HOVER/TAP ZONES ============ */
  /* These are large invisible areas that catch the cursor near each ray */
  .ray-zones {
    position: absolute;
    inset: 0;
    z-index: 5;
    pointer-events: none;
  }
 
  .ray-zone {
    position: absolute;
    cursor: pointer;
    pointer-events: all;
    /* Wedge shape from prism to right edge using clip-path */
    left: 15%;
    width: 75%;
    height: 18%;
  }
 
  /* Position each zone vertically to align with its ray */
  .ray-zone-p { top: 11%; clip-path: polygon(0% 80%, 0% 100%, 100% 0%, 100% 20%); }
  .ray-zone-r { top: 27%; clip-path: polygon(0% 60%, 0% 100%, 100% 25%, 100% 45%); }
  .ray-zone-i { top: 41%; clip-path: polygon(0% 40%, 0% 60%, 100% 45%, 100% 55%); }
  .ray-zone-s { top: 55%; clip-path: polygon(0% 0%, 0% 40%, 100% 55%, 100% 75%); }
  .ray-zone-m { top: 71%; clip-path: polygon(0% 0%, 0% 20%, 100% 80%, 100% 100%); }
 
  /* ============ PHASE REVEAL PANELS ============ */
  /* Each phase reveal sits at the right end of its ray, hidden by default */
  .phase-reveals {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 6;
  }
 
  .phase-reveal {
    position: absolute;
    right: 0;
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.25rem 1.5rem;
    width: clamp(280px, 42%, 500px);
    background: color-mix(in srgb, var(--phase-color) 12%, rgba(10, 22, 40, 0.95));
    border: 1px solid color-mix(in srgb, var(--phase-color) 60%, transparent);
    border-radius: 4px;
    box-shadow: 0 0 32px color-mix(in srgb, var(--phase-color) 35%, transparent),
                0 0 64px color-mix(in srgb, var(--phase-color) 18%, transparent);
    opacity: 0;
    transform: translateX(20px);
    transition: opacity 0.4s cubic-bezier(0.16, 1, 0.3, 1), transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    pointer-events: none;
  }
 
  /* Vertical position of each reveal matches its ray endpoint */
  .phase-reveal-p { top: 8%; }
  .phase-reveal-r { top: 26%; }
  .phase-reveal-i { top: 44%; }
  .phase-reveal-s { top: 62%; }
  .phase-reveal-m { top: 80%; }
 
  .phase-reveal.visible {
    opacity: 1;
    transform: translateX(0);
  }
 
  .phase-letter-badge {
    flex-shrink: 0;
    width: 56px;
    height: 56px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-sans);
    font-size: 2rem;
    font-weight: 200;
    color: var(--phase-color);
    border: 1.5px solid var(--phase-color);
    border-radius: 4px;
    text-shadow: 0 0 12px color-mix(in srgb, var(--phase-color) 70%, transparent);
  }
 
  .phase-text {
    flex: 1;
    min-width: 0;
  }
 
  .phase-name {
    font-family: var(--font-sans);
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    color: var(--phase-color);
    margin: 0 0 0.3rem;
    line-height: 1;
  }
 
  .phase-subtitle {
    font-family: var(--font-sans);
    font-style: italic;
    font-weight: 300;
    font-size: 0.9rem;
    color: var(--phase-color);
    margin: 0 0 0.5rem;
    line-height: 1.3;
  }
 
  .phase-description {
    font-family: var(--font-sans);
    font-size: 0.82rem;
    font-weight: 300;
    line-height: 1.55;
    color: var(--color-text-muted);
    margin: 0;
  }
 
  /* ============ DESKTOP REFINEMENTS ============ */
  @media (min-width: 992px) {
    .test-page {
      padding-top: 8rem;
    }
 
    .phase-letter-badge {
      width: 64px;
      height: 64px;
      font-size: 2.4rem;
    }
 
    .phase-name {
      font-size: 0.95rem;
    }
 
    .phase-subtitle {
      font-size: 1.05rem;
    }
 
    .phase-description {
      font-size: 0.9rem;
    }
  }
 
  /* ============ MOBILE FALLBACK ============ */
  @media (max-width: 640px) {
    .prism-scene {
      height: 560px;
    }
 
    .raw-story-label {
      font-size: 0.65rem;
      left: 4%;
    }
 
    .phase-reveal {
      width: 60%;
      padding: 0.85rem 1rem;
    }
 
    .phase-letter-badge {
      width: 42px;
      height: 42px;
      font-size: 1.5rem;
    }
  }
</style>
 
<script is:inline>
  (function () {
    'use strict';
 
    var rays = ['p', 'r', 'i', 'isn', 's', 'm'];
    var allRays = document.querySelectorAll('.prism-ray');
    var allReveals = document.querySelectorAll('.phase-reveal');
    var allZones = document.querySelectorAll('.ray-zone');
 
    function activatePhase(phase) {
      // Highlight target ray, dim others
      for (var i = 0; i < allRays.length; i++) {
        var ray = allRays[i];
        var rayPhase = ray.getAttribute('data-phase');
        ray.classList.remove('dimmed', 'active');
        if (rayPhase === phase) {
          ray.classList.add('active');
        } else {
          ray.classList.add('dimmed');
        }
      }
      // Show matching reveal
      for (var j = 0; j < allReveals.length; j++) {
        var reveal = allReveals[j];
        if (reveal.getAttribute('data-phase') === phase) {
          reveal.classList.add('visible');
        } else {
          reveal.classList.remove('visible');
        }
      }
    }
 
    function deactivateAll() {
      for (var i = 0; i < allRays.length; i++) {
        allRays[i].classList.remove('dimmed', 'active');
      }
      for (var j = 0; j < allReveals.length; j++) {
        allReveals[j].classList.remove('visible');
      }
    }
 
    function attachZoneHandlers() {
      for (var i = 0; i < allZones.length; i++) {
        var zone = allZones[i];
        var phase = zone.getAttribute('data-phase');
 
        (function (zoneEl, phaseValue) {
          zoneEl.addEventListener('mouseenter', function () {
            activatePhase(phaseValue);
          });
          zoneEl.addEventListener('mouseleave', function () {
            deactivateAll();
          });
          // Touch / tap support for mobile
          zoneEl.addEventListener('click', function (e) {
            e.preventDefault();
            // Toggle: if already active, hide; otherwise activate
            var reveal = document.querySelector('.phase-reveal[data-phase="' + phaseValue + '"]');
            if (reveal && reveal.classList.contains('visible')) {
              deactivateAll();
            } else {
              activatePhase(phaseValue);
            }
          });
          zoneEl.addEventListener('focus', function () {
            activatePhase(phaseValue);
          });
          zoneEl.addEventListener('blur', function () {
            deactivateAll();
          });
          zoneEl.addEventListener('keydown', function (e) {
            if (e.key === 'Enter' || e.key === ' ') {
              e.preventDefault();
              activatePhase(phaseValue);
            }
          });
        })(zone, phase);
      }
    }
 
    function init() {
      attachZoneHandlers();
      console.log('[Process Test] Interactive prism initialized with', allZones.length, 'zones');
    }
 
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init);
    } else {
      init();
    }
  })();
</script>
