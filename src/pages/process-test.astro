---
import BaseLayout from '../layouts/BaseLayout.astro';
 
const phases = [
  {
    letter: 'P',
    name: 'PEOPLE',
    colorHex: '#d4756f',
    colorRgb: '212, 117, 111',
    subtitle: 'The Heart of every story.',
    description: 'Characters with desire, uniqueness, and complexity — found, drawn out, and revealed so your audience sees themselves in them.',
  },
  {
    letter: 'R',
    name: 'RESONANCE',
    colorHex: '#f5d589',
    colorRgb: '245, 213, 137',
    subtitle: 'The Why behind the narrative.',
    description: 'Stories crafted with clear purpose that resonate deeply — changing attitudes and driving action.',
  },
  {
    letter: 'I',
    name: 'IMMERSION',
    colorHex: '#a3bc7e',
    colorRgb: '163, 188, 126',
    subtitle: 'The Story Structure that transports.',
    description: 'Stories built to be so engaging that audiences become fully absorbed in your narrative world.',
  },
  {
    letter: 'S',
    name: 'STORYFINDING',
    colorHex: '#86a8c9',
    colorRgb: '134, 168, 201',
    subtitle: 'The Discovery process.',
    description: 'A systematic search for authentic narratives — pre-interviews, uncovering the specific moments.',
  },
  {
    letter: 'M',
    name: 'MOMENTS',
    colorHex: '#a583b5',
    colorRgb: '165, 131, 181',
    subtitle: 'The Visual language.',
    description: 'Moments captured to show rather than tell, using symbolism and surprise to amplify meaning.',
  },
];
---
 
<BaseLayout
  title="Process Animation Test — The Story Speaks"
  description="Interactive PRISM prototype."
>
  <main class="test-page">
 
    <div class="test-banner">
      <p class="test-banner-label">TEST PAGE — Interactive PRISM</p>
      <a href="/process/" class="test-banner-link">← Back to /process/</a>
    </div>
 
    <section class="test-hero">
      <p class="test-intro desktop-intro">Hover or tap each ray to reveal that phase of the methodology.</p>
      <p class="test-intro mobile-intro">Scroll to explore each phase of the methodology.</p>
    </section>
 
    <!-- MOBILE ONLY: mini PRISM preview -->
    <section class="mobile-preview" aria-hidden="true">
      <div class="mp-stage">
        <svg class="mp-rays-svg" viewBox="0 0 280 240" preserveAspectRatio="xMidYMid meet">
          <defs>
            <!-- Rays end at x=210 (letter starts at x=216) so letter sits cleanly to the right of ray end -->
            <linearGradient id="mp-ray-p" gradientUnits="userSpaceOnUse" x1="60" y1="120" x2="210" y2="30">
              <stop offset="0%" stop-color="rgba(212, 117, 111, 0.4)"/>
              <stop offset="100%" stop-color="rgba(212, 117, 111, 0.95)"/>
            </linearGradient>
            <linearGradient id="mp-ray-r" gradientUnits="userSpaceOnUse" x1="60" y1="120" x2="210" y2="75">
              <stop offset="0%" stop-color="rgba(245, 213, 137, 0.4)"/>
              <stop offset="100%" stop-color="rgba(245, 213, 137, 0.95)"/>
            </linearGradient>
            <linearGradient id="mp-ray-i" gradientUnits="userSpaceOnUse" x1="60" y1="120" x2="210" y2="120">
              <stop offset="0%" stop-color="rgba(163, 188, 126, 0.4)"/>
              <stop offset="100%" stop-color="rgba(163, 188, 126, 0.95)"/>
            </linearGradient>
            <linearGradient id="mp-ray-s" gradientUnits="userSpaceOnUse" x1="60" y1="120" x2="210" y2="165">
              <stop offset="0%" stop-color="rgba(134, 168, 201, 0.4)"/>
              <stop offset="100%" stop-color="rgba(134, 168, 201, 0.95)"/>
            </linearGradient>
            <linearGradient id="mp-ray-m" gradientUnits="userSpaceOnUse" x1="60" y1="120" x2="210" y2="210">
              <stop offset="0%" stop-color="rgba(165, 131, 181, 0.4)"/>
              <stop offset="100%" stop-color="rgba(165, 131, 181, 0.95)"/>
            </linearGradient>
            <filter id="mp-blur" x="-20%" y="-50%" width="140%" height="200%">
              <feGaussianBlur stdDeviation="1.5"/>
            </filter>
            <linearGradient id="mp-prism-front" x1="0%" y1="0%" x2="100%" y2="100%">
              <stop offset="0%"   stop-color="rgba(212, 117, 111, 0.85)"/>
              <stop offset="25%"  stop-color="rgba(245, 213, 137, 0.85)"/>
              <stop offset="50%"  stop-color="rgba(163, 188, 126, 0.85)"/>
              <stop offset="75%"  stop-color="rgba(134, 168, 201, 0.85)"/>
              <stop offset="100%" stop-color="rgba(165, 131, 181, 0.85)"/>
            </linearGradient>
            <linearGradient id="mp-prism-side" x1="0%" y1="0%" x2="0%" y2="100%">
              <stop offset="0%"   stop-color="rgba(134, 168, 201, 0.45)"/>
              <stop offset="100%" stop-color="rgba(165, 131, 181, 0.45)"/>
            </linearGradient>
            <radialGradient id="mp-prism-highlight">
              <stop offset="0%"   stop-color="rgba(255,255,255,0.6)"/>
              <stop offset="100%" stop-color="rgba(255,255,255,0)"/>
            </radialGradient>
          </defs>
 
          <!-- Rays end at x=210, letters start at x=216 -->
          <polygon points="60,120 210,22 210,38" fill="url(#mp-ray-p)" filter="url(#mp-blur)"/>
          <polygon points="60,120 210,67 210,83" fill="url(#mp-ray-r)" filter="url(#mp-blur)"/>
          <polygon points="60,120 210,112 210,128" fill="url(#mp-ray-i)" filter="url(#mp-blur)"/>
          <polygon points="60,120 210,157 210,173" fill="url(#mp-ray-s)" filter="url(#mp-blur)"/>
          <polygon points="60,120 210,202 210,218" fill="url(#mp-ray-m)" filter="url(#mp-blur)"/>
        </svg>
 
        <div class="mp-prism-wrap">
          <div class="mp-orb"></div>
          <div class="mp-gem">
            <svg viewBox="0 0 100 100" preserveAspectRatio="xMidYMid meet">
              <polygon points="50,10 8,82 90,82" fill="url(#mp-prism-front)" stroke="rgba(255,255,255,0.5)" stroke-width="1.5"/>
              <polygon points="50,10 90,82 95,86" fill="url(#mp-prism-side)" stroke="rgba(255,255,255,0.2)" stroke-width="1"/>
              <ellipse cx="50" cy="36" rx="18" ry="22" fill="url(#mp-prism-highlight)"/>
              <circle cx="50" cy="10" r="2.5" fill="rgba(255,255,255,0.95)"/>
            </svg>
          </div>
        </div>
 
        <div class="mp-label">
          <span>RAW</span>
          <span>STORY</span>
        </div>
 
        <div class="mp-letter mp-p" style="--phase-color: #d4756f;">P</div>
        <div class="mp-letter mp-r" style="--phase-color: #f5d589;">R</div>
        <div class="mp-letter mp-i" style="--phase-color: #a3bc7e;">I</div>
        <div class="mp-letter mp-s" style="--phase-color: #86a8c9;">S</div>
        <div class="mp-letter mp-m" style="--phase-color: #a583b5;">M</div>
      </div>
    </section>
 
    <!-- DESKTOP: full interactive prism -->
    <section class="prism-section">
      <div class="main-wrapper" id="prismRow">
 
        <div class="prism-animation-container">
 
          <svg class="animation-svg" id="raysSvg" viewBox="0 0 1200 550" preserveAspectRatio="xMinYMid meet">
            <defs>
              <linearGradient id="ray-grad-p" gradientUnits="userSpaceOnUse"><stop offset="0%" stop-color="rgba(212, 117, 111, 0.35)"/><stop offset="100%" stop-color="rgba(212, 117, 111, 0.95)"/></linearGradient>
              <linearGradient id="ray-grad-r" gradientUnits="userSpaceOnUse"><stop offset="0%" stop-color="rgba(245, 213, 137, 0.35)"/><stop offset="100%" stop-color="rgba(245, 213, 137, 0.95)"/></linearGradient>
              <linearGradient id="ray-grad-i" gradientUnits="userSpaceOnUse"><stop offset="0%" stop-color="rgba(163, 188, 126, 0.35)"/><stop offset="100%" stop-color="rgba(163, 188, 126, 0.95)"/></linearGradient>
              <linearGradient id="ray-grad-s" gradientUnits="userSpaceOnUse"><stop offset="0%" stop-color="rgba(134, 168, 201, 0.35)"/><stop offset="100%" stop-color="rgba(134, 168, 201, 0.95)"/></linearGradient>
              <linearGradient id="ray-grad-m" gradientUnits="userSpaceOnUse"><stop offset="0%" stop-color="rgba(165, 131, 181, 0.35)"/><stop offset="100%" stop-color="rgba(165, 131, 181, 0.95)"/></linearGradient>
 
              <filter id="ray-glow" x="-20%" y="-50%" width="140%" height="200%">
                <feGaussianBlur in="SourceGraphic" stdDeviation="2.5"/>
              </filter>
            </defs>
 
            <polygon id="ray-p" class="prism-ray" data-phase="p" points="0,0 0,0 0,0" fill="url(#ray-grad-p)" style="filter: url(#ray-glow); opacity: 0;"/>
            <polygon id="ray-r" class="prism-ray" data-phase="r" points="0,0 0,0 0,0" fill="url(#ray-grad-r)" style="filter: url(#ray-glow); opacity: 0;"/>
            <polygon id="ray-i" class="prism-ray" data-phase="i" points="0,0 0,0 0,0" fill="url(#ray-grad-i)" style="filter: url(#ray-glow); opacity: 0;"/>
            <polygon id="ray-s" class="prism-ray" data-phase="s" points="0,0 0,0 0,0" fill="url(#ray-grad-s)" style="filter: url(#ray-glow); opacity: 0;"/>
            <polygon id="ray-m" class="prism-ray" data-phase="m" points="0,0 0,0 0,0" fill="url(#ray-grad-m)" style="filter: url(#ray-glow); opacity: 0;"/>
 
            <polygon id="hover-p" class="hover-area" data-phase="p" points="0,0 0,0 0,0" fill="transparent" style="pointer-events: all; cursor: pointer;"/>
            <polygon id="hover-r" class="hover-area" data-phase="r" points="0,0 0,0 0,0" fill="transparent" style="pointer-events: all; cursor: pointer;"/>
            <polygon id="hover-i" class="hover-area" data-phase="i" points="0,0 0,0 0,0" fill="transparent" style="pointer-events: all; cursor: pointer;"/>
            <polygon id="hover-s" class="hover-area" data-phase="s" points="0,0 0,0 0,0" fill="transparent" style="pointer-events: all; cursor: pointer;"/>
            <polygon id="hover-m" class="hover-area" data-phase="m" points="0,0 0,0 0,0" fill="transparent" style="pointer-events: all; cursor: pointer;"/>
          </svg>
 
          <div class="raw-story-label">RAW STORY</div>
 
          <div class="prism-center">
            <div class="glass-glow"></div>
 
            <div class="prism-gem" id="prismGem">
              <svg class="prism-pyramid-svg" viewBox="0 0 100 100" preserveAspectRatio="xMidYMid meet">
                <defs>
                  <linearGradient id="prism-front-grad" x1="0%" y1="0%" x2="100%" y2="100%">
                    <stop offset="0%"   stop-color="rgba(212, 117, 111, 0.85)"/>
                    <stop offset="25%"  stop-color="rgba(245, 213, 137, 0.85)"/>
                    <stop offset="50%"  stop-color="rgba(163, 188, 126, 0.85)"/>
                    <stop offset="75%"  stop-color="rgba(134, 168, 201, 0.85)"/>
                    <stop offset="100%" stop-color="rgba(165, 131, 181, 0.85)"/>
                  </linearGradient>
                  <linearGradient id="prism-side-grad" x1="0%" y1="0%" x2="0%" y2="100%">
                    <stop offset="0%"   stop-color="rgba(134, 168, 201, 0.45)"/>
                    <stop offset="100%" stop-color="rgba(165, 131, 181, 0.45)"/>
                  </linearGradient>
                  <radialGradient id="prism-highlight-grad">
                    <stop offset="0%"   stop-color="rgba(255,255,255,0.6)"/>
                    <stop offset="100%" stop-color="rgba(255,255,255,0)"/>
                  </radialGradient>
                </defs>
                <polygon points="50,10 8,82 90,82" fill="url(#prism-front-grad)" stroke="rgba(255,255,255,0.5)" stroke-width="1.5"/>
                <polygon points="50,10 90,82 95,86" fill="url(#prism-side-grad)" stroke="rgba(255,255,255,0.2)" stroke-width="1"/>
                <ellipse cx="50" cy="36" rx="18" ry="22" fill="url(#prism-highlight-grad)"/>
                <circle cx="50" cy="10" r="2.5" fill="rgba(255,255,255,0.95)"/>
              </svg>
            </div>
          </div>
        </div>
 
        <div class="items-container" id="itemsContainer">
          {phases.map((phase) => (
            <div
              class={`prism-item letter-${phase.letter.toLowerCase()}`}
              data-phase={phase.letter.toLowerCase()}
              style={`--phase-color: ${phase.colorHex}; --phase-color-rgb: ${phase.colorRgb};`}
            >
              <div class="letter-box">{phase.letter}</div>
              <div class="word-title">{phase.name}</div>
              <div class="description">
                <span class="desc-subtitle">{phase.subtitle}</span> {phase.description}
              </div>
            </div>
          ))}
        </div>
 
      </div>
    </section>
 
  </main>
</BaseLayout>
 
<style>
  .test-page {
    background: var(--color-bg-deep);
    min-height: 100vh;
    padding-top: 5rem;
    padding-bottom: 4rem;
  }
 
  .test-banner {
    max-width: 1200px;
    margin: 0 auto 2rem;
    padding: 0.85rem 1.75rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: color-mix(in srgb, var(--color-accent) 8%, transparent);
    border: 1px solid color-mix(in srgb, var(--color-accent) 30%, transparent);
    border-radius: 4px;
  }
 
  .test-banner-label {
    font-family: var(--font-wordmark, 'Fjalla One', sans-serif);
    font-size: 0.7rem;
    color: var(--color-accent);
    letter-spacing: 0.2em;
    margin: 0;
  }
 
  .test-banner-link {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color 0.2s ease;
  }
 
  .test-banner-link:hover {
    color: var(--color-accent);
  }
 
  .test-hero {
    max-width: 760px;
    margin: 0 auto 2.5rem;
    padding: 0 2rem;
    text-align: center;
  }
 
  .test-intro {
    font-size: 0.95rem;
    line-height: 1.6;
    color: var(--color-text-muted);
    margin: 0;
    font-weight: 300;
  }
 
  .desktop-intro { display: block; }
  .mobile-intro { display: none; }
 
  .mobile-preview { display: none; }
 
  /* ============ OUTER CONTAINER — desktop ============ */
  .prism-section {
    max-width: 1100px;
    width: 100%;
    margin: 0 auto;
    padding: 0 40px;
  }
 
  .main-wrapper {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 40px;
    pointer-events: auto;
  }
 
  .prism-animation-container {
    position: relative;
    width: 350px;
    height: 550px;
    flex-shrink: 0;
    overflow: visible;
  }
 
  .animation-svg {
    position: absolute;
    width: 1200px;
    height: 100%;
    left: 0;
    top: 0;
    overflow: visible;
    pointer-events: none;
  }
 
  .prism-ray {
    transition: opacity 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    pointer-events: none;
  }
 
  .hover-area {
    pointer-events: all;
    cursor: pointer;
  }
 
  .raw-story-label {
    position: absolute;
    left: 0;
    top: 50%;
    transform: translateY(-50%);
    font-family: var(--font-sans);
    font-size: 1.15rem;
    font-weight: 800;
    color: rgba(248, 250, 252, 0.95);
    letter-spacing: -0.02em;
    pointer-events: none;
    z-index: 3;
    white-space: nowrap;
    text-shadow:
      0 0 10px rgba(248, 250, 252, 0.75),
      0 0 20px rgba(248, 250, 252, 0.45),
      0 0 30px rgba(245, 213, 137, 0.3);
    animation: rawStoryPulse 4s ease-in-out infinite;
  }
 
  @keyframes rawStoryPulse {
    0%, 100% {
      text-shadow:
        0 0 10px rgba(248, 250, 252, 0.75),
        0 0 20px rgba(248, 250, 252, 0.45),
        0 0 30px rgba(245, 213, 137, 0.3);
    }
    50% {
      text-shadow:
        0 0 14px rgba(248, 250, 252, 0.9),
        0 0 28px rgba(248, 250, 252, 0.6),
        0 0 42px rgba(245, 213, 137, 0.45);
    }
  }
 
  .prism-center {
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    width: 100px;
    height: 100px;
    z-index: 4;
  }
 
  .glass-glow {
    position: absolute;
    width: 120px;
    height: 120px;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    background: radial-gradient(circle,
      rgba(212, 117, 111, 0.22) 0%,
      rgba(245, 213, 137, 0.22) 20%,
      rgba(163, 188, 126, 0.22) 40%,
      rgba(134, 168, 201, 0.24) 60%,
      rgba(165, 131, 181, 0.18) 80%,
      transparent 100%);
    border-radius: 50%;
    z-index: 1;
    animation: orbPulse 4s ease-in-out infinite;
    pointer-events: none;
  }
 
  @keyframes orbPulse {
    0%, 100% {
      transform: translate(-50%, -50%) scale(1);
      opacity: 0.85;
    }
    50% {
      transform: translate(-50%, -50%) scale(1.2);
      opacity: 1;
    }
  }
 
  .prism-gem {
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    width: 95px;
    height: 90px;
    z-index: 3;
    filter: drop-shadow(0 0 18px rgba(255, 255, 255, 0.4));
    animation: prismPulse 4s ease-in-out infinite;
    pointer-events: none;
  }
 
  .prism-pyramid-svg {
    width: 100%;
    height: 100%;
    display: block;
  }
 
  @keyframes prismPulse {
    0%, 100% {
      filter: drop-shadow(0 0 15px rgba(255, 255, 255, 0.35));
    }
    50% {
      filter: drop-shadow(0 0 28px rgba(255, 255, 255, 0.55));
    }
  }
 
  .items-container {
    width: 750px;
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 0;
    position: relative;
    z-index: 5;
  }
 
  .prism-item {
    position: relative;
    display: flex;
    align-items: center;
    gap: 1.25rem;
    padding: 0 1.5rem;
    height: 90px;
    border: 1px solid transparent;
    border-left: none;
    cursor: pointer;
    overflow: hidden;
    transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
  }
 
  .letter-box {
    flex-shrink: 0;
    width: 55px;
    height: 55px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-sans);
    font-size: 2rem;
    font-weight: 300;
    color: var(--phase-color);
    border: 1.5px solid color-mix(in srgb, var(--phase-color) 80%, transparent);
    background: color-mix(in srgb, var(--phase-color) 14%, transparent);
    border-radius: 4px;
    text-shadow:
      0 0 12px color-mix(in srgb, var(--phase-color) 70%, transparent),
      0 0 24px color-mix(in srgb, var(--phase-color) 50%, transparent);
    transition: opacity 0.5s cubic-bezier(0.4, 0, 0.2, 1),
                transform 0.5s cubic-bezier(0.4, 0, 0.2, 1);
  }
 
  .word-title {
    flex-shrink: 0;
    font-family: var(--font-sans);
    font-size: 1.15rem;
    font-weight: 600;
    letter-spacing: 0.16em;
    color: var(--phase-color);
    line-height: 1;
    white-space: nowrap;
    text-shadow: 0 0 14px color-mix(in srgb, var(--phase-color) 50%, transparent);
    transition: transform 0.5s cubic-bezier(0.4, 0, 0.2, 1);
  }
 
  .description {
    position: absolute;
    top: 50%;
    left: 280px;
    right: 1.5rem;
    max-width: 460px;
    transform: translateY(-50%) translateX(40px);
    font-family: var(--font-sans);
    font-size: 0.9rem;
    font-weight: 300;
    line-height: 1.55;
    color: rgba(255, 255, 255, 0.88);
    opacity: 0;
    transition: transform 0.5s cubic-bezier(0.4, 0, 0.2, 1),
                opacity 0.5s cubic-bezier(0.4, 0, 0.2, 1);
    pointer-events: none;
  }
 
  .desc-subtitle {
    font-style: italic;
    color: var(--phase-color);
  }
 
  .prism-item.active {
    background: color-mix(in srgb, var(--phase-color) 22%, transparent);
    border-color: color-mix(in srgb, var(--phase-color) 50%, transparent);
    border-left: none;
    box-shadow:
      0 0 36px color-mix(in srgb, var(--phase-color) 55%, transparent),
      0 0 72px color-mix(in srgb, var(--phase-color) 28%, transparent);
    transform: translateY(-3px);
    z-index: 10;
  }
 
  .prism-item.active .letter-box {
    opacity: 0;
    transform: scale(0.7);
  }
 
  .prism-item.active .word-title {
    transform: translateX(-72px);
  }
 
  .prism-item.active .description {
    transform: translateY(-50%) translateX(0);
    opacity: 1;
  }
 
  /* ============ MOBILE ============ */
  @media (max-width: 900px) {
    .desktop-intro { display: none; }
    .mobile-intro { display: block; }
 
    .prism-section { display: none; }
 
    .mobile-preview {
      display: block;
      max-width: 280px;
      margin: 0 auto 3rem;
    }
 
    .mp-stage {
      position: relative;
      width: 280px;
      height: 240px;
      margin: 0 auto;
    }
 
    .mp-rays-svg {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      overflow: visible;
      pointer-events: none;
      z-index: 1;
    }
 
    .mp-prism-wrap {
      position: absolute;
      left: 25px;
      top: 85px;
      width: 70px;
      height: 70px;
      z-index: 3;
      display: flex;
      align-items: center;
      justify-content: center;
    }
 
    .mp-orb {
      position: absolute;
      width: 90px;
      height: 90px;
      left: 50%;
      top: 50%;
      transform: translate(-50%, -50%);
      background: radial-gradient(circle,
        rgba(212, 117, 111, 0.22) 0%,
        rgba(245, 213, 137, 0.22) 20%,
        rgba(163, 188, 126, 0.22) 40%,
        rgba(134, 168, 201, 0.24) 60%,
        rgba(165, 131, 181, 0.18) 80%,
        transparent 100%);
      border-radius: 50%;
      z-index: 1;
      animation: orbPulse 4s ease-in-out infinite;
      pointer-events: none;
    }
 
    .mp-gem {
      position: relative;
      z-index: 2;
      width: 50px;
      height: 50px;
      filter: drop-shadow(0 0 14px rgba(255, 255, 255, 0.45));
      animation: prismPulse 4s ease-in-out infinite;
    }
 
    .mp-gem svg {
      width: 100%;
      height: 100%;
      display: block;
    }
 
    .mp-label {
      position: absolute;
      left: 60px;
      top: 172px;
      transform: translateX(-50%);
      text-align: center;
      font-family: var(--font-sans);
      font-size: 0.72rem;
      font-weight: 800;
      letter-spacing: -0.02em;
      line-height: 1.1;
      color: rgba(248, 250, 252, 0.95);
      text-shadow:
        0 0 8px rgba(248, 250, 252, 0.75),
        0 0 16px rgba(248, 250, 252, 0.45),
        0 0 24px rgba(245, 213, 137, 0.3);
      animation: rawStoryPulse 4s ease-in-out infinite;
      pointer-events: none;
      z-index: 4;
    }
 
    .mp-label span {
      display: block;
    }
 
    /* Letter boxes: OPAQUE background (so rays don't bleed through), centered at x=230, rays end at x=210 */
    .mp-letter {
      position: absolute;
      right: 36px;
      width: 28px;
      height: 28px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: var(--font-sans);
      font-size: 0.95rem;
      font-weight: 300;
      color: var(--phase-color);
      border: 1.2px solid color-mix(in srgb, var(--phase-color) 80%, transparent);
      /* Opaque dark base with phase tint — blocks the ray glow underneath */
      background: color-mix(in srgb, var(--phase-color) 22%, var(--color-bg-deep, #0a1628));
      border-radius: 3px;
      text-shadow:
        0 0 8px color-mix(in srgb, var(--phase-color) 70%, transparent),
        0 0 16px color-mix(in srgb, var(--phase-color) 45%, transparent);
      z-index: 5;
    }
 
    .mp-p { top: 16px; }
    .mp-r { top: 61px; }
    .mp-i { top: 106px; }
    .mp-s { top: 151px; }
    .mp-m { top: 196px; }
  }
 
  /* ============ MOBILE PHASE CARDS ============ */
  .mobile-cards-container { display: none; }
 
  @media (max-width: 900px) {
    .mobile-cards-container {
      display: flex;
      flex-direction: column;
      gap: 12px;
      max-width: 480px;
      margin: 0 auto;
      /* Bottom padding so the M card top can scroll up to the trigger line */
      padding: 0 1rem 70vh;
    }
 
    .mobile-card {
      position: relative;
      padding: 0.95rem 1rem;
      border: 1px solid color-mix(in srgb, var(--phase-color) 25%, transparent);
      border-radius: 4px;
      background: color-mix(in srgb, var(--phase-color) 5%, transparent);
      /* Specific transitions — not "all" — so layout changes don't compete with visual changes.
         easeOutQuint = very smooth landing, no perceived bounce. */
      transition:
        background 0.7s cubic-bezier(0.22, 1, 0.36, 1),
        border-color 0.7s cubic-bezier(0.22, 1, 0.36, 1),
        box-shadow 0.7s cubic-bezier(0.22, 1, 0.36, 1);
    }
 
    .mobile-card.revealed {
      background: color-mix(in srgb, var(--phase-color) 16%, transparent);
      border-color: color-mix(in srgb, var(--phase-color) 50%, transparent);
      box-shadow:
        0 0 28px color-mix(in srgb, var(--phase-color) 35%, transparent),
        0 0 56px color-mix(in srgb, var(--phase-color) 18%, transparent);
    }
 
    .mc-header {
      display: flex;
      align-items: center;
      gap: 1rem;
    }
 
    .mc-letter {
      flex-shrink: 0;
      width: 48px;
      height: 48px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: var(--font-sans);
      font-size: 1.75rem;
      font-weight: 300;
      color: var(--phase-color);
      border: 1.5px solid color-mix(in srgb, var(--phase-color) 75%, transparent);
      background: color-mix(in srgb, var(--phase-color) 14%, transparent);
      border-radius: 4px;
      text-shadow:
        0 0 10px color-mix(in srgb, var(--phase-color) 70%, transparent),
        0 0 20px color-mix(in srgb, var(--phase-color) 45%, transparent);
    }
 
    .mc-name {
      font-family: var(--font-sans);
      font-size: 1rem;
      font-weight: 600;
      letter-spacing: 0.16em;
      color: var(--phase-color);
      line-height: 1;
      text-shadow: 0 0 12px color-mix(in srgb, var(--phase-color) 50%, transparent);
    }
 
    .mc-description {
      max-height: 0;
      opacity: 0;
      overflow: hidden;
      font-family: var(--font-sans);
      font-size: 0.88rem;
      font-weight: 300;
      line-height: 1.55;
      color: rgba(255, 255, 255, 0.88);
      /* Smooth ease-out cubic-bezier (easeOutQuint) — gentle landing, no bounce */
      transition:
        max-height 0.75s cubic-bezier(0.22, 1, 0.36, 1),
        opacity 0.55s cubic-bezier(0.22, 1, 0.36, 1) 0.1s,
        margin-top 0.75s cubic-bezier(0.22, 1, 0.36, 1);
    }
 
    .mobile-card.revealed .mc-description {
      max-height: 280px;
      opacity: 1;
      margin-top: 0.75rem;
    }
 
    .mc-subtitle {
      font-style: italic;
      color: var(--phase-color);
    }
  }
</style>
 
<div class="mobile-cards-container" id="mobileCards">
  {phases.map((phase) => (
    <div
      class="mobile-card"
      data-phase={phase.letter.toLowerCase()}
      style={`--phase-color: ${phase.colorHex}; --phase-color-rgb: ${phase.colorRgb};`}
    >
      <div class="mc-header">
        <div class="mc-letter">{phase.letter}</div>
        <div class="mc-name">{phase.name}</div>
      </div>
      <div class="mc-description">
        <span class="mc-subtitle">{phase.subtitle}</span> {phase.description}
      </div>
    </div>
  ))}
</div>
 
<script is:inline>
  (function () {
    'use strict';
 
    var THIN_HALF = 1.5;
    var WEDGE_HALF = 40;
    var HOVER_HALF = 54;
 
    var phases = ['p', 'r', 'i', 's', 'm'];
 
    function isMobile() {
      return window.innerWidth < 901;
    }
 
    function computeGeometry() {
      if (isMobile()) return;
 
      var container = document.querySelector('.prism-animation-container');
      var gem = document.getElementById('prismGem');
      var svg = document.getElementById('raysSvg');
      if (!container || !gem || !svg) return;
 
      var containerRect = container.getBoundingClientRect();
      var gemRect = gem.getBoundingClientRect();
 
      var prismX = gemRect.left - containerRect.left + gemRect.width / 2;
      var prismY = gemRect.top - containerRect.top + gemRect.height / 2;
 
      phases.forEach(function (phase) {
        var item = document.querySelector('.prism-item[data-phase="' + phase + '"]');
        if (!item) return;
        var itemRect = item.getBoundingClientRect();
 
        var targetX = itemRect.left - containerRect.left;
        var targetY = itemRect.top - containerRect.top + itemRect.height / 2;
 
        var thinPoints =
          prismX + ',' + prismY + ' ' +
          targetX + ',' + (targetY - THIN_HALF) + ' ' +
          targetX + ',' + (targetY + THIN_HALF);
 
        var wedgePoints =
          prismX + ',' + prismY + ' ' +
          targetX + ',' + (targetY - WEDGE_HALF) + ' ' +
          targetX + ',' + (targetY + WEDGE_HALF);
 
        var hoverPoints =
          prismX + ',' + prismY + ' ' +
          targetX + ',' + (targetY - HOVER_HALF) + ' ' +
          targetX + ',' + (targetY + HOVER_HALF);
 
        var ray = document.getElementById('ray-' + phase);
        if (ray) {
          ray.dataset.thinPoints = thinPoints;
          ray.dataset.wedgePoints = wedgePoints;
          ray.setAttribute('points', thinPoints);
          ray.style.opacity = '0.9';
 
          var grad = document.getElementById('ray-grad-' + phase);
          if (grad) {
            grad.setAttribute('x1', String(prismX));
            grad.setAttribute('y1', String(prismY));
            grad.setAttribute('x2', String(targetX));
            grad.setAttribute('y2', String(targetY));
          }
        }
 
        var hoverArea = document.getElementById('hover-' + phase);
        if (hoverArea) {
          hoverArea.setAttribute('points', hoverPoints);
        }
      });
    }
 
    function activate(phase) {
      phases.forEach(function (p) {
        var ray = document.getElementById('ray-' + p);
        if (!ray) return;
        ray.style.transition = 'opacity 0.4s ease, points 0.4s cubic-bezier(0.4, 0, 0.2, 1)';
        if (p === phase) {
          ray.setAttribute('points', ray.dataset.wedgePoints);
          ray.style.opacity = '0.95';
        } else {
          ray.setAttribute('points', ray.dataset.thinPoints);
          ray.style.opacity = '0.5';
        }
      });
 
      var items = document.querySelectorAll('.prism-item');
      for (var i = 0; i < items.length; i++) {
        if (items[i].getAttribute('data-phase') === phase) {
          items[i].classList.add('active');
        } else {
          items[i].classList.remove('active');
        }
      }
    }
 
    function deactivateAll() {
      phases.forEach(function (p) {
        var ray = document.getElementById('ray-' + p);
        if (!ray) return;
        ray.style.transition = 'opacity 0.4s ease, points 0.4s cubic-bezier(0.4, 0, 0.2, 1)';
        ray.setAttribute('points', ray.dataset.thinPoints);
        ray.style.opacity = '0.9';
      });
      var items = document.querySelectorAll('.prism-item');
      for (var i = 0; i < items.length; i++) {
        items[i].classList.remove('active');
      }
    }
 
    function attachDesktopHandlers() {
      phases.forEach(function (phase) {
        var hoverArea = document.getElementById('hover-' + phase);
        if (hoverArea) {
          hoverArea.addEventListener('mouseenter', function () {
            if (isMobile()) return;
            activate(phase);
          });
          hoverArea.addEventListener('mouseleave', function (e) {
            if (isMobile()) return;
            var toEl = e.relatedTarget;
            if (toEl && toEl.closest && toEl.closest('.prism-item[data-phase="' + phase + '"]')) {
              return;
            }
            deactivateAll();
          });
        }
      });
 
      var items = document.querySelectorAll('.prism-item');
      for (var i = 0; i < items.length; i++) {
        (function (item) {
          var phase = item.getAttribute('data-phase');
          item.addEventListener('mouseenter', function () {
            if (isMobile()) return;
            activate(phase);
          });
          item.addEventListener('mouseleave', function (e) {
            if (isMobile()) return;
            var toEl = e.relatedTarget;
            if (toEl && toEl.id === 'hover-' + phase) {
              return;
            }
            deactivateAll();
          });
        })(items[i]);
      }
    }
 
    /**
     * Mobile scrollspy: the active card is the LAST card whose top
     * has crossed the trigger line. This means:
     *  - At top of page: no card active (mini preview is the focus)
     *  - As user scrolls, each card activates when its top crosses the trigger
     *  - When the next card crosses, the previous one deactivates
     *  - The LAST card (M) activates and stays active even if user can't
     *    scroll further, because nothing else can take its place.
     */
    function setupMobileScrollSpy() {
      if (!isMobile()) return;
 
      var cards = document.querySelectorAll('.mobile-card');
      if (cards.length === 0) return;
 
      function updateActiveCard() {
        var triggerY = window.innerHeight * 0.4;
        var activeIdx = -1;
 
        // Find the last card whose top has crossed (is at or above) the trigger line
        for (var i = 0; i < cards.length; i++) {
          var rect = cards[i].getBoundingClientRect();
          if (rect.top <= triggerY) {
            activeIdx = i;
          }
        }
 
        for (var j = 0; j < cards.length; j++) {
          if (j === activeIdx) {
            cards[j].classList.add('revealed');
          } else {
            cards[j].classList.remove('revealed');
          }
        }
      }
 
      var rafId = null;
      function onScroll() {
        if (rafId) return;
        rafId = requestAnimationFrame(function () {
          updateActiveCard();
          rafId = null;
        });
      }
 
      window.addEventListener('scroll', onScroll, { passive: true });
      window.addEventListener('resize', onScroll, { passive: true });
 
      updateActiveCard();
    }
 
    function init() {
      requestAnimationFrame(function () {
        computeGeometry();
        attachDesktopHandlers();
        setupMobileScrollSpy();
      });
 
      var resizeTimer = null;
      window.addEventListener('resize', function () {
        clearTimeout(resizeTimer);
        resizeTimer = setTimeout(function () {
          deactivateAll();
          computeGeometry();
        }, 150);
      });
 
      console.log('[Process Test] Mobile scrollspy (last-crossed pattern) + opaque letters + smoother easing');
    }
 
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init);
    } else {
      init();
    }
  })();
</script>
 
