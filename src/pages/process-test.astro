---
import BaseLayout from '../layouts/BaseLayout.astro';
 
const phases = [
  {
    letter: 'P',
    name: 'PEOPLE',
    colorHex: '#d4756f',
    colorRgb: '212, 117, 111',
    subtitle: 'The Heart of every story.',
    description: 'Characters with desire, uniqueness, and complexity — found, drawn out, and revealed so your audience sees themselves in them.',
  },
  {
    letter: 'R',
    name: 'RESONANCE',
    colorHex: '#f5d589',
    colorRgb: '245, 213, 137',
    subtitle: 'The Why behind the narrative.',
    description: 'Stories crafted with clear purpose that resonate deeply — changing attitudes and driving action.',
  },
  {
    letter: 'I',
    name: 'IMMERSION',
    colorHex: '#a3bc7e',
    colorRgb: '163, 188, 126',
    subtitle: 'The Story Structure that transports.',
    description: 'Stories built to be so engaging that audiences become fully absorbed in your narrative world.',
  },
  {
    letter: 'S',
    name: 'STORYFINDING',
    colorHex: '#86a8c9',
    colorRgb: '134, 168, 201',
    subtitle: 'The Discovery process.',
    description: 'A systematic search for authentic narratives — pre-interviews, uncovering the specific moments.',
  },
  {
    letter: 'M',
    name: 'MOMENTS',
    colorHex: '#a583b5',
    colorRgb: '165, 131, 181',
    subtitle: 'The Visual language.',
    description: 'Moments captured to show rather than tell, using symbolism and surprise to amplify meaning.',
  },
];
---
 
<BaseLayout
  title="Process Animation Test — The Story Speaks"
  description="Test page for the PRISM animation prototype."
>
  <main class="test-page">
 
    <!-- Test page banner -->
    <div class="test-banner">
      <p class="test-banner-label">TEST PAGE — Animation Prototype</p>
      <a href="/process/" class="test-banner-link">← Back to /process/</a>
    </div>
 
    <section class="test-hero">
      <p class="eyebrow">Animation Prototype</p>
      <h1 class="test-headline">The <span class="prism-multicolor">
        <span style="color:#d4756f">P</span><span style="color:#f5d589">R</span><span style="color:#a3bc7e">I</span><span style="color:#86a8c9">S</span><span style="color:#a583b5">M</span>
      </span> Method — Animated</h1>
      <p class="test-intro">
        A faithful adaptation of the Luminous Story PRISM animation using our color spectrum. The beam enters from the left, the prism appears, and five colored rays fan outward to reveal each phase of the methodology.
      </p>
    </section>
 
    <!-- The animation scene -->
    <section class="animation-stage">
      <div class="animation-row">
 
        <!-- Left column: the animation area -->
        <div class="prism-animation-container" id="prismContainer">
          <div class="light-beam" id="lightBeam"></div>
          <div class="raw-story-label" id="rawStoryLabel">RAW STORY</div>
          <div class="particle-container" id="particleContainer"></div>
 
          <!-- SVG for the rays. overflow:visible so polygons can extend to the cards. -->
          <svg class="animation-svg" viewBox="0 0 1100 600" preserveAspectRatio="xMidYMid meet">
            <defs>
              <linearGradient id="ray-grad-p" gradientUnits="userSpaceOnUse">
                <stop offset="0%" stop-color="rgba(212, 117, 111, 0.35)"/>
                <stop offset="100%" stop-color="rgba(212, 117, 111, 0.85)"/>
              </linearGradient>
              <linearGradient id="ray-grad-r" gradientUnits="userSpaceOnUse">
                <stop offset="0%" stop-color="rgba(245, 213, 137, 0.35)"/>
                <stop offset="100%" stop-color="rgba(245, 213, 137, 0.85)"/>
              </linearGradient>
              <linearGradient id="ray-grad-i" gradientUnits="userSpaceOnUse">
                <stop offset="0%" stop-color="rgba(163, 188, 126, 0.35)"/>
                <stop offset="100%" stop-color="rgba(163, 188, 126, 0.85)"/>
              </linearGradient>
              <linearGradient id="ray-grad-s" gradientUnits="userSpaceOnUse">
                <stop offset="0%" stop-color="rgba(134, 168, 201, 0.35)"/>
                <stop offset="100%" stop-color="rgba(134, 168, 201, 0.85)"/>
              </linearGradient>
              <linearGradient id="ray-grad-m" gradientUnits="userSpaceOnUse">
                <stop offset="0%" stop-color="rgba(165, 131, 181, 0.35)"/>
                <stop offset="100%" stop-color="rgba(165, 131, 181, 0.85)"/>
              </linearGradient>
 
              <filter id="ray-blur" x="-20%" y="-50%" width="140%" height="200%">
                <feGaussianBlur in="SourceGraphic" stdDeviation="3"/>
              </filter>
            </defs>
 
            <!-- Five rays (initially collapsed at prism center) -->
            <polygon class="prism-ray" id="ray-p" points="225,300 225,300 225,300"
              fill="url(#ray-grad-p)"
              style="opacity: 0; filter: url(#ray-blur);"/>
            <polygon class="prism-ray" id="ray-r" points="225,300 225,300 225,300"
              fill="url(#ray-grad-r)"
              style="opacity: 0; filter: url(#ray-blur);"/>
            <polygon class="prism-ray" id="ray-i" points="225,300 225,300 225,300"
              fill="url(#ray-grad-i)"
              style="opacity: 0; filter: url(#ray-blur);"/>
            <polygon class="prism-ray" id="ray-s" points="225,300 225,300 225,300"
              fill="url(#ray-grad-s)"
              style="opacity: 0; filter: url(#ray-blur);"/>
            <polygon class="prism-ray" id="ray-m" points="225,300 225,300 225,300"
              fill="url(#ray-grad-m)"
              style="opacity: 0; filter: url(#ray-blur);"/>
          </svg>
 
          <!-- The prism pyramid that appears in the center -->
          <div class="prism-center" id="prismCenter">
            <svg class="prism-pyramid" viewBox="0 0 100 100" preserveAspectRatio="xMidYMid meet">
              <defs>
                <linearGradient id="pyramid-front" x1="0%" y1="0%" x2="100%" y2="100%">
                  <stop offset="0%"   stop-color="rgba(212, 117, 111, 0.7)"/>
                  <stop offset="25%"  stop-color="rgba(245, 213, 137, 0.7)"/>
                  <stop offset="50%"  stop-color="rgba(163, 188, 126, 0.7)"/>
                  <stop offset="75%"  stop-color="rgba(134, 168, 201, 0.7)"/>
                  <stop offset="100%" stop-color="rgba(165, 131, 181, 0.7)"/>
                </linearGradient>
                <linearGradient id="pyramid-side" x1="0%" y1="0%" x2="0%" y2="100%">
                  <stop offset="0%"   stop-color="rgba(134, 168, 201, 0.5)"/>
                  <stop offset="100%" stop-color="rgba(165, 131, 181, 0.5)"/>
                </linearGradient>
                <radialGradient id="pyramid-highlight">
                  <stop offset="0%"   stop-color="rgba(255,255,255,0.7)"/>
                  <stop offset="100%" stop-color="rgba(255,255,255,0)"/>
                </radialGradient>
              </defs>
 
              <!-- Front face -->
              <polygon points="50,10 8,82 90,82" fill="url(#pyramid-front)"
                stroke="rgba(255,255,255,0.5)" stroke-width="1.5"/>
              <!-- Right side face -->
              <polygon points="50,10 90,82 95,86" fill="url(#pyramid-side)"
                stroke="rgba(255,255,255,0.25)" stroke-width="1"/>
              <!-- Glass highlight -->
              <ellipse cx="50" cy="36" rx="18" ry="22" fill="url(#pyramid-highlight)"/>
              <!-- Apex point -->
              <circle cx="50" cy="10" r="2.5" fill="rgba(255,255,255,0.95)"/>
            </svg>
          </div>
        </div>
 
        <!-- Right column: the five phase cards -->
        <div class="phase-cards" id="phaseCards">
          {phases.map((phase) => (
            <article
              class={`phase-card phase-card-${phase.letter.toLowerCase()}`}
              data-phase={phase.letter.toLowerCase()}
              style={`--phase-color: ${phase.colorHex}; --phase-color-rgb: ${phase.colorRgb};`}
            >
              <div class="phase-letter-anim">{phase.letter}</div>
              <div class="phase-content">
                <h3 class="phase-name">{phase.name}</h3>
                <p class="phase-subtitle">{phase.subtitle}</p>
                <p class="phase-description">{phase.description}</p>
              </div>
            </article>
          ))}
        </div>
 
      </div>
 
      <!-- Replay button -->
      <div class="replay-wrapper">
        <button class="replay-button" id="replayBtn" type="button">
          <span class="replay-icon" aria-hidden="true">↻</span>
          <span>REPLAY ANIMATION</span>
        </button>
      </div>
    </section>
 
  </main>
</BaseLayout>
 
<style>
  /* ============ PAGE FOUNDATION ============ */
  .test-page {
    background: var(--color-bg-deep);
    min-height: 100vh;
    padding-top: 6rem;
    padding-bottom: 6rem;
  }
 
  .test-banner {
    max-width: 1200px;
    margin: 0 auto 3rem;
    padding: 1rem 2rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: color-mix(in srgb, var(--color-accent) 8%, transparent);
    border: 1px solid color-mix(in srgb, var(--color-accent) 30%, transparent);
    border-radius: 4px;
  }
 
  .test-banner-label {
    font-family: var(--font-wordmark, 'Fjalla One', sans-serif);
    font-size: 0.75rem;
    color: var(--color-accent);
    letter-spacing: 0.2em;
    margin: 0;
  }
 
  .test-banner-link {
    font-family: var(--font-sans);
    font-size: 0.8rem;
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color 0.2s ease;
  }
 
  .test-banner-link:hover {
    color: var(--color-accent);
  }
 
  .test-hero {
    max-width: 760px;
    margin: 0 auto 4rem;
    padding: 0 2rem;
    text-align: center;
  }
 
  .test-headline {
    font-family: var(--font-sans);
    font-size: clamp(1.5rem, 4vw, 2.5rem);
    font-weight: 300;
    line-height: 1.2;
    letter-spacing: -0.025em;
    margin: 1rem 0 1.5rem;
  }
 
  .prism-multicolor {
    font-weight: 300;
  }
 
  .test-intro {
    font-size: clamp(0.9rem, 1.3vw, 1rem);
    line-height: 1.7;
    color: var(--color-text-muted);
    max-width: 600px;
    margin: 0 auto;
    font-weight: 300;
  }
 
  /* ============ ANIMATION STAGE ============ */
  .animation-stage {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 2rem;
  }
 
  .animation-row {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 3rem;
  }
 
  /* ============ PRISM ANIMATION CONTAINER ============ */
  .prism-animation-container {
    position: relative;
    width: 100%;
    max-width: 450px;
    height: 450px;
    flex-shrink: 0;
  }
 
  .animation-svg {
    position: absolute;
    width: 100%;
    height: 100%;
    left: 0;
    top: 0;
    overflow: visible; /* Critical — lets rays extend to the cards on the right */
    pointer-events: none;
  }
 
  /* Light beam shooting in from the left */
  .light-beam {
    position: absolute;
    left: 0;
    top: 50%;
    transform: translateY(-50%);
    width: 0;
    height: 5px;
    background: linear-gradient(to right, rgba(255, 255, 255, 0.3), rgba(245, 213, 137, 1));
    opacity: 0;
    filter: blur(2px);
    box-shadow: 0 0 18px rgba(245, 213, 137, 0.8), 0 0 36px rgba(245, 213, 137, 0.4);
    pointer-events: none;
  }
 
  .light-beam.animating {
    animation: beamShoot 0.6s ease-out forwards;
  }
 
  @keyframes beamShoot {
    0%   { opacity: 0; width: 0; }
    5%   { opacity: 1; width: 30px; }
    100% { opacity: 1; width: 175px; }
  }
 
  /* RAW STORY label */
  .raw-story-label {
    position: absolute;
    left: 0;
    top: 50%;
    transform: translate(-2.5rem, calc(-50% - 1.5rem));
    font-family: var(--font-sans);
    font-size: 0.7rem;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.6);
    letter-spacing: 0.25em;
    text-transform: uppercase;
    opacity: 0;
    white-space: nowrap;
    pointer-events: none;
  }
 
  .raw-story-label.animating {
    animation: labelReveal 0.6s ease-out forwards;
  }
 
  @keyframes labelReveal {
    0%   { opacity: 0; }
    5%   { opacity: 1; }
    100% { opacity: 1; }
  }
 
  /* Particle container & particles */
  .particle-container {
    position: absolute;
    width: 100%;
    height: 100%;
    left: 0;
    top: 0;
    pointer-events: none;
  }
 
  .particle {
    position: absolute;
    border-radius: 50%;
    pointer-events: none;
  }
 
  /* The prism pyramid in the center */
  .prism-center {
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%) scale(0);
    width: 90px;
    height: 90px;
    opacity: 0;
    pointer-events: none;
    filter: drop-shadow(0 0 20px rgba(245, 213, 137, 0.5));
  }
 
  .prism-center.appearing {
    animation: prismAppear 0.33s ease forwards;
  }
 
  .prism-center.pulsing {
    animation: prismPulse 3s ease-in-out infinite;
  }
 
  .prism-pyramid {
    width: 100%;
    height: 100%;
  }
 
  @keyframes prismAppear {
    from { opacity: 0; transform: translate(-50%, -50%) scale(0); }
    to   { opacity: 1; transform: translate(-50%, -50%) scale(1); }
  }
 
  @keyframes prismPulse {
    0%, 100% {
      transform: translate(-50%, -50%) scale(1);
      filter: brightness(1) drop-shadow(0 0 20px rgba(245, 213, 137, 0.5));
    }
    50% {
      transform: translate(-50%, -50%) scale(1.11);
      filter: brightness(1.15) drop-shadow(0 0 32px rgba(245, 213, 137, 0.7));
    }
  }
 
  /* Rays use CSS transition for smooth point animation */
  .prism-ray {
    transition: opacity 0.35s ease;
  }
 
  /* ============ PHASE CARDS (right column) ============ */
  .phase-cards {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    flex: 1;
    width: 100%;
    max-width: 600px;
  }
 
  .phase-card {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    padding: 1.25rem 1.5rem;
    background: color-mix(in srgb, var(--phase-color) 6%, transparent);
    border: 1px solid color-mix(in srgb, var(--phase-color) 35%, transparent);
    border-radius: 4px;
    opacity: 0;
    transform: translateX(30px);
    transition: opacity 0.27s ease, transform 0.27s ease;
  }
 
  .phase-card.appearing {
    opacity: 1;
    transform: translateX(0);
  }
 
  .phase-letter-anim {
    flex-shrink: 0;
    width: 60px;
    height: 60px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-sans);
    font-size: 2.25rem;
    font-weight: 200;
    color: var(--phase-color);
    background: color-mix(in srgb, var(--phase-color) 12%, transparent);
    border: 1px solid color-mix(in srgb, var(--phase-color) 50%, transparent);
    border-radius: 4px;
    box-shadow: 0 0 18px color-mix(in srgb, var(--phase-color) 35%, transparent);
  }
 
  .phase-content {
    flex: 1;
    min-width: 0;
  }
 
  .phase-name {
    font-family: var(--font-sans);
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    color: var(--phase-color);
    margin: 0 0 0.35rem;
    line-height: 1;
  }
 
  .phase-subtitle {
    font-family: var(--font-sans);
    font-style: italic;
    font-weight: 300;
    font-size: 0.9rem;
    color: var(--phase-color);
    margin: 0 0 0.5rem;
    line-height: 1.3;
  }
 
  .phase-description {
    font-family: var(--font-sans);
    font-size: 0.82rem;
    font-weight: 300;
    line-height: 1.55;
    color: var(--color-text-muted);
    margin: 0;
  }
 
  /* ============ REPLAY BUTTON ============ */
  .replay-wrapper {
    margin-top: 4rem;
    text-align: center;
  }
 
  .replay-button {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.85rem 1.75rem;
    background: color-mix(in srgb, var(--color-accent) 12%, transparent);
    border: 1px solid var(--color-accent);
    border-radius: 2px;
    color: var(--color-accent);
    font-family: var(--font-wordmark, 'Fjalla One', sans-serif);
    font-size: 0.8rem;
    font-weight: 400;
    letter-spacing: 0.18em;
    cursor: pointer;
    text-transform: uppercase;
    transition: all 0.3s ease;
  }
 
  .replay-button:hover {
    background: color-mix(in srgb, var(--color-accent) 22%, transparent);
    transform: translateY(-1px);
  }
 
  .replay-icon {
    font-family: var(--font-sans);
    font-size: 1rem;
    font-weight: 400;
    letter-spacing: 0;
  }
 
  /* ============ DESKTOP LAYOUT ============ */
  @media (min-width: 992px) {
    .test-page {
      padding-top: 8rem;
    }
 
    .animation-row {
      flex-direction: row;
      align-items: center;
      gap: 4rem;
      min-height: 600px;
    }
 
    .prism-animation-container {
      width: 450px;
      height: 600px;
      max-width: 450px;
      flex-shrink: 0;
    }
 
    .phase-cards {
      max-width: 580px;
    }
 
    .phase-letter-anim {
      width: 70px;
      height: 70px;
      font-size: 2.5rem;
    }
 
    .phase-name {
      font-size: 0.95rem;
    }
 
    .phase-subtitle {
      font-size: 1.05rem;
    }
 
    .phase-description {
      font-size: 0.9rem;
    }
  }
</style>
 
<script is:inline>
  (function () {
    'use strict';
 
    var PARTICLE_COUNT = 40;
    var SVG_VIEW_WIDTH = 1100;
    var SVG_VIEW_HEIGHT = 600;
    var PRISM_CENTER_X = 225; // SVG coordinates
    var PRISM_CENTER_Y = 300;
    var RAY_FAN_WIDTH = 16; // perpendicular half-width at the target
 
    var COLORS = {
      p: 'rgba(212, 117, 111, 0.8)',
      r: 'rgba(245, 213, 137, 0.8)',
      i: 'rgba(163, 188, 126, 0.8)',
      s: 'rgba(134, 168, 201, 0.8)',
      m: 'rgba(165, 131, 181, 0.8)'
    };
 
    var COLOR_LIST = [COLORS.p, COLORS.r, COLORS.i, COLORS.s, COLORS.m];
 
    var RAY_CONFIG = [
      { id: 'ray-p', gradientId: 'ray-grad-p', cardLetter: 'p', delay: 833 },
      { id: 'ray-r', gradientId: 'ray-grad-r', cardLetter: 'r', delay: 900 },
      { id: 'ray-i', gradientId: 'ray-grad-i', cardLetter: 'i', delay: 967 },
      { id: 'ray-s', gradientId: 'ray-grad-s', cardLetter: 's', delay: 1033 },
      { id: 'ray-m', gradientId: 'ray-grad-m', cardLetter: 'm', delay: 1100 }
    ];
 
    function easeInOutQuart(t) {
      return t < 0.5 ? 8 * t * t * t * t : 1 - Math.pow(-2 * t + 2, 4) / 2;
    }
 
    function createParticles() {
      var container = document.getElementById('particleContainer');
      if (!container) return;
      container.innerHTML = '';
 
      var containerWidth = container.offsetWidth;
      var containerHeight = container.offsetHeight;
      var centerX = containerWidth / 2;
      var centerY = containerHeight / 2;
      var maxDistance = Math.min(containerWidth, containerHeight) * 0.45;
 
      for (var i = 0; i < PARTICLE_COUNT; i++) {
        var particle = document.createElement('div');
        particle.className = 'particle';
 
        var angle = Math.random() * Math.PI * 2;
        var distance = maxDistance * (0.7 + Math.random() * 0.3);
        var startX = centerX + Math.cos(angle) * distance;
        var startY = centerY + Math.sin(angle) * distance;
 
        var size = 2 + Math.random() * 3;
        var color = COLOR_LIST[Math.floor(Math.random() * COLOR_LIST.length)];
        var delay = Math.random() * 0.3;
 
        particle.style.left = startX + 'px';
        particle.style.top = startY + 'px';
        particle.style.width = size + 'px';
        particle.style.height = size + 'px';
        particle.style.background = color;
        particle.style.boxShadow = '0 0 ' + (6 + Math.random() * 10) + 'px ' + color;
        particle.style.opacity = '0';
 
        particle.dataset.startX = startX;
        particle.dataset.startY = startY;
        particle.dataset.centerX = centerX;
        particle.dataset.centerY = centerY;
        particle.dataset.delay = delay;
 
        container.appendChild(particle);
      }
    }
 
    function animateParticles() {
      var particles = document.querySelectorAll('.particle');
      var duration = 667;
      var startTime = Date.now();
 
      function step() {
        var elapsed = Date.now() - startTime;
        var progress = Math.min(elapsed / duration, 1);
 
        for (var i = 0; i < particles.length; i++) {
          var p = particles[i];
          var delay = parseFloat(p.dataset.delay) * 1000;
          var pProgress = Math.max(0, Math.min(1, (elapsed - delay) / duration));
          var eased = easeInOutQuart(pProgress);
 
          var sx = parseFloat(p.dataset.startX);
          var sy = parseFloat(p.dataset.startY);
          var cx = parseFloat(p.dataset.centerX);
          var cy = parseFloat(p.dataset.centerY);
 
          var x = sx + (cx - sx) * eased;
          var y = sy + (cy - sy) * eased;
 
          p.style.left = x + 'px';
          p.style.top = y + 'px';
          p.style.opacity = String(pProgress * 0.8);
        }
 
        if (progress < 1) {
          requestAnimationFrame(step);
        } else {
          setTimeout(function () {
            for (var i = 0; i < particles.length; i++) {
              particles[i].style.transition = 'opacity 0.6s ease';
              particles[i].style.opacity = '0';
            }
          }, 500);
        }
      }
 
      step();
    }
 
    function animateRays() {
      var container = document.getElementById('prismContainer');
      if (!container) return;
 
      RAY_CONFIG.forEach(function (rayConfig) {
        setTimeout(function () {
          var ray = document.getElementById(rayConfig.id);
          var gradient = document.getElementById(rayConfig.gradientId);
          var card = document.querySelector('.phase-card[data-phase="' + rayConfig.cardLetter + '"]');
          var letterEl = card ? card.querySelector('.phase-letter-anim') : null;
 
          if (!ray || !letterEl || !container) return;
 
          // Reveal the card
          if (card) card.classList.add('appearing');
 
          // Compute target position in SVG viewBox coordinates
          var letterRect = letterEl.getBoundingClientRect();
          var containerRect = container.getBoundingClientRect();
          var letterCenterX = letterRect.left - containerRect.left + letterRect.width / 2;
          var letterCenterY = letterRect.top - containerRect.top + letterRect.height / 2;
 
          var targetX = (letterCenterX / container.offsetWidth) * SVG_VIEW_WIDTH;
          var targetY = (letterCenterY / container.offsetHeight) * SVG_VIEW_HEIGHT;
 
          // Build a fanning triangle: point at prism center, wider at target
          var dx = targetX - PRISM_CENTER_X;
          var dy = targetY - PRISM_CENTER_Y;
          var len = Math.sqrt(dx * dx + dy * dy);
          if (len === 0) return;
 
          // Perpendicular unit vector (for the fan width)
          var perpX = -dy / len * RAY_FAN_WIDTH;
          var perpY = dx / len * RAY_FAN_WIDTH;
 
          var p1 = PRISM_CENTER_X + ',' + PRISM_CENTER_Y;
          var p2 = (targetX + perpX) + ',' + (targetY + perpY);
          var p3 = (targetX - perpX) + ',' + (targetY - perpY);
 
          // Update gradient direction so the brighter end is at the target
          if (gradient) {
            gradient.setAttribute('x1', String(PRISM_CENTER_X));
            gradient.setAttribute('y1', String(PRISM_CENTER_Y));
            gradient.setAttribute('x2', String(targetX));
            gradient.setAttribute('y2', String(targetY));
          }
 
          // Animate the polygon's points and opacity
          // We use a brief setTimeout to ensure CSS picks up the transition
          ray.setAttribute('points', p1 + ' ' + p2 + ' ' + p3);
          ray.style.opacity = '0.9';
        }, rayConfig.delay);
      });
    }
 
    function resetAnimation() {
      var beam = document.getElementById('lightBeam');
      var label = document.getElementById('rawStoryLabel');
      var prismCenter = document.getElementById('prismCenter');
 
      if (beam) {
        beam.classList.remove('animating');
        beam.style.width = '0';
        beam.style.opacity = '0';
      }
      if (label) {
        label.classList.remove('animating');
        label.style.opacity = '0';
      }
      if (prismCenter) {
        prismCenter.classList.remove('appearing', 'pulsing');
        prismCenter.style.opacity = '0';
        prismCenter.style.transform = 'translate(-50%, -50%) scale(0)';
      }
 
      var cards = document.querySelectorAll('.phase-card');
      for (var i = 0; i < cards.length; i++) {
        cards[i].classList.remove('appearing');
      }
 
      var rays = document.querySelectorAll('.prism-ray');
      for (var j = 0; j < rays.length; j++) {
        rays[j].style.opacity = '0';
        rays[j].setAttribute('points', PRISM_CENTER_X + ',' + PRISM_CENTER_Y + ' ' + PRISM_CENTER_X + ',' + PRISM_CENTER_Y + ' ' + PRISM_CENTER_X + ',' + PRISM_CENTER_Y);
      }
    }
 
    function startAnimation() {
      resetAnimation();
      createParticles();
 
      // Brief delay so reset takes effect before animation starts
      setTimeout(function () {
        var beam = document.getElementById('lightBeam');
        var label = document.getElementById('rawStoryLabel');
        var prismCenter = document.getElementById('prismCenter');
 
        if (beam) beam.classList.add('animating');
        if (label) label.classList.add('animating');
 
        animateParticles();
 
        // Prism center appears after beam reaches it
        setTimeout(function () {
          if (prismCenter) {
            prismCenter.classList.add('appearing');
            // After it finishes appearing, start the infinite pulse
            setTimeout(function () {
              prismCenter.classList.add('pulsing');
            }, 350);
          }
        }, 600);
 
        animateRays();
      }, 50);
    }
 
    function init() {
      var replayBtn = document.getElementById('replayBtn');
      if (replayBtn) {
        replayBtn.addEventListener('click', function () {
          startAnimation();
        });
      }
 
      // Start animation on initial page load with a brief delay so layout settles
      setTimeout(function () {
        startAnimation();
      }, 300);
 
      console.log('[Process Test] PRISM animation initialized');
    }
 
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init);
    } else {
      init();
    }
  })();
</script>
