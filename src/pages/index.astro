---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import IntroSection from '../components/IntroSection.astro';
import DiagnosticSection from '../components/DiagnosticSection.astro';
import PrismTeaserSection from '../components/PrismTeaserSection.astro';
import FilmTeaserSection from '../components/FilmTeaserSection.astro';
import TestimonialsSection from '../components/TestimonialsSection.astro';
import ClientLogosSection from '../components/ClientLogosSection.astro';
import FinalCTASection from '../components/FinalCTASection.astro';
---
<BaseLayout
  title="The Story Speaks — Emmy-Winning Documentary & Brand Films | Lance Murphey"
  description="Emmy-winning film and media studio led by Lance Murphey. Strategic documentary, brand, and impact storytelling for healthcare systems, research universities, nonprofits, and Fortune 500 brands. Based in Boulder, Colorado."
  ogImage="/images/og-default.jpg"
  canonicalPath="/"
>
  <main>
    <Hero />
    <IntroSection />
    <DiagnosticSection />
    <PrismTeaserSection />
    <FilmTeaserSection />
    <TestimonialsSection />
    <ClientLogosSection />
    <FinalCTASection />
  </main>
</BaseLayout>
