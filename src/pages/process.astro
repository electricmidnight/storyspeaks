---
import BaseLayout from '../layouts/BaseLayout.astro';
 
const phases = [
  {
    letter: 'P',
    name: 'PEOPLE',
    color: 'var(--prism-people)',
    colorHex: '#d4756f',
    subtitle: 'The Heart of every story.',
    description: 'Characters with desire, uniqueness, and complexity — found, drawn out, and revealed so your audience sees themselves in them.',
  },
  {
    letter: 'R',
    name: 'RESONANCE',
    color: 'var(--prism-resonance)',
    colorHex: '#f5d589',
    subtitle: 'The Why behind the narrative.',
    description: 'Stories crafted with clear purpose that resonate deeply — changing attitudes and driving action.',
  },
  {
    letter: 'I',
    name: 'IMMERSION',
    color: 'var(--prism-immersion)',
    colorHex: '#a3bc7e',
    subtitle: 'The Story Structure that transports.',
    description: 'Stories built to be so engaging that audiences become fully absorbed in your narrative world.',
  },
  {
    letter: 'S',
    name: 'STORYFINDING',
    color: 'var(--prism-storyfinding)',
    colorHex: '#86a8c9',
    subtitle: 'The Discovery process.',
    description: 'A systematic search for authentic narratives — pre-interviews, uncovering the specific moments.',
  },
  {
    letter: 'M',
    name: 'MOMENTS',
    color: 'var(--prism-moments)',
    colorHex: '#a583b5',
    subtitle: 'The Visual language.',
    description: 'Moments captured to show rather than tell, using symbolism and surprise to amplify meaning.',
  },
];
---
 
<BaseLayout
  title="Our Process — The Story Speaks"
  description="The PRISM Method: a proprietary five-phase narrative architecture for translating complex truth into resonant human experience."
>
  <main class="process-page">
 
    <!-- ============================================
         HERO SECTION
         ============================================ -->
    <section class="process-hero">
      <p class="eyebrow">Our Process</p>
 
      <h1 class="process-headline">
        The <span class="prism-multicolor">
          <span style="color:#d4756f">P</span><span style="color:#f5d589">R</span><span style="color:#a3bc7e">I</span><span style="color:#86a8c9">S</span><span style="color:#a583b5">M</span>
        </span> Method
      </h1>
 
      <p class="process-subtitle">The Architecture for Unforgettable Stories</p>
 
      <p class="process-intro">
        Most agencies promise creative magic. PRISM delivers strategic certainty. A proprietary narrative architecture designed to translate complex truth into resonant human experience.
      </p>
 
      <!-- The hero prism — full scene with all rays at equal brightness -->
      <div class="hero-prism">
        <svg class="prism-svg" viewBox="0 0 280 175" preserveAspectRatio="xMidYMid meet" aria-hidden="true">
          <defs>
            <linearGradient id="incoming-hero" x1="0%" y1="0%" x2="100%" y2="0%">
              <stop offset="0%" stop-color="#f5d589" stop-opacity="0"/>
              <stop offset="100%" stop-color="#f5d589" stop-opacity="1"/>
            </linearGradient>
            <linearGradient id="ray-p-hero" x1="0%" y1="0%" x2="100%" y2="0%"><stop offset="0%" stop-color="#d4756f" stop-opacity="1"/><stop offset="100%" stop-color="#d4756f" stop-opacity="0.45"/></linearGradient>
            <linearGradient id="ray-r-hero" x1="0%" y1="0%" x2="100%" y2="0%"><stop offset="0%" stop-color="#f5d589" stop-opacity="1"/><stop offset="100%" stop-color="#f5d589" stop-opacity="0.45"/></linearGradient>
            <linearGradient id="ray-i-hero" x1="0%" y1="0%" x2="100%" y2="0%"><stop offset="0%" stop-color="#a3bc7e" stop-opacity="1"/><stop offset="100%" stop-color="#a3bc7e" stop-opacity="0.45"/></linearGradient>
            <linearGradient id="ray-s-hero" x1="0%" y1="0%" x2="100%" y2="0%"><stop offset="0%" stop-color="#86a8c9" stop-opacity="1"/><stop offset="100%" stop-color="#86a8c9" stop-opacity="0.45"/></linearGradient>
            <linearGradient id="ray-m-hero" x1="0%" y1="0%" x2="100%" y2="0%"><stop offset="0%" stop-color="#a583b5" stop-opacity="1"/><stop offset="100%" stop-color="#a583b5" stop-opacity="0.45"/></linearGradient>
            <linearGradient id="prism-glass-hero" x1="0%" y1="0%" x2="100%" y2="100%">
              <stop offset="0%"   stop-color="#d4756f" stop-opacity="0.65"/>
              <stop offset="25%"  stop-color="#f5d589" stop-opacity="0.65"/>
              <stop offset="50%"  stop-color="#a3bc7e" stop-opacity="0.65"/>
              <stop offset="75%"  stop-color="#86a8c9" stop-opacity="0.65"/>
              <stop offset="100%" stop-color="#a583b5" stop-opacity="0.65"/>
            </linearGradient>
            <filter id="ray-glow-hero" x="-20%" y="-50%" width="140%" height="200%">
              <feGaussianBlur in="SourceGraphic" stdDeviation="2" result="b"/>
              <feMerge><feMergeNode in="b"/><feMergeNode in="SourceGraphic"/></feMerge>
            </filter>
          </defs>
 
          <!-- Stacked RAW STORY label -->
          <text x="32" y="80" text-anchor="end" class="raw-label">RAW</text>
          <text x="32" y="92" text-anchor="end" class="raw-label">STORY</text>
 
          <!-- Incoming light -->
          <line x1="36" y1="87" x2="48" y2="87" stroke="url(#incoming-hero)" stroke-width="2.5"/>
 
          <!-- Prism -->
          <polygon points="50,50 50,124 76,87" fill="url(#prism-glass-hero)" stroke="#ffffff" stroke-opacity="0.4" stroke-width="1.2"/>
 
          <!-- Five glowing rays -->
          <g filter="url(#ray-glow-hero)">
            <polygon points="76,87 240,15 240,28" fill="url(#ray-p-hero)"/>
            <polygon points="76,87 240,50 240,63" fill="url(#ray-r-hero)"/>
            <polygon points="76,87 240,82 240,95" fill="url(#ray-i-hero)"/>
            <polygon points="76,87 240,114 240,127" fill="url(#ray-s-hero)"/>
            <polygon points="76,87 240,146 240,159" fill="url(#ray-m-hero)"/>
          </g>
 
          <!-- Letter caps aligned at x=260 -->
          <g class="prism-cap-letters">
            <text x="260" y="27" text-anchor="middle" fill="#d4756f">P</text>
            <text x="260" y="60" text-anchor="middle" fill="#f5d589">R</text>
            <text x="260" y="93" text-anchor="middle" fill="#a3bc7e">I</text>
            <text x="260" y="124" text-anchor="middle" fill="#86a8c9">S</text>
            <text x="260" y="158" text-anchor="middle" fill="#a583b5">M</text>
          </g>
        </svg>
      </div>
    </section>
 
    <!-- ============================================
         PRISM PHASES — MOBILE STACKED CARDS
         (Hidden on desktop; replaced by sticky-prism scroll section)
         ============================================ -->
    <section class="phases-mobile">
      {phases.map((phase) => (
        <article
          class="phase-card-mobile"
          style={`--phase-color: ${phase.colorHex};`}
        >
          <div class="phase-letter-mobile" style={`color: ${phase.colorHex};`}>{phase.letter}</div>
          <div class="phase-text-mobile">
            <h3 class="phase-name-mobile" style={`color: ${phase.colorHex};`}>{phase.name}</h3>
            <p class="phase-subtitle-mobile">{phase.subtitle}</p>
            <p class="phase-desc-mobile">{phase.description}</p>
          </div>
        </article>
      ))}
    </section>
 
    <!-- ============================================
         PRISM PHASES — DESKTOP STICKY-PRISM SCROLL
         (Hidden on mobile; only renders at desktop breakpoint)
         ============================================ -->
    <section class="phases-desktop" id="phasesDesktop">
 
      <!-- The sticky prism (stays fixed as user scrolls through phases) -->
      <div class="sticky-prism-wrapper">
        <div class="sticky-prism">
          <svg class="prism-svg-sticky" viewBox="0 0 280 175" preserveAspectRatio="xMidYMid meet" aria-hidden="true">
            <defs>
              <linearGradient id="incoming-sticky" x1="0%" y1="0%" x2="100%" y2="0%">
                <stop offset="0%" stop-color="#f5d589" stop-opacity="0"/>
                <stop offset="100%" stop-color="#f5d589" stop-opacity="1"/>
              </linearGradient>
              <linearGradient id="ray-p-sticky" x1="0%" y1="0%" x2="100%" y2="0%"><stop offset="0%" stop-color="#d4756f" stop-opacity="1"/><stop offset="100%" stop-color="#d4756f" stop-opacity="0.45"/></linearGradient>
              <linearGradient id="ray-r-sticky" x1="0%" y1="0%" x2="100%" y2="0%"><stop offset="0%" stop-color="#f5d589" stop-opacity="1"/><stop offset="100%" stop-color="#f5d589" stop-opacity="0.45"/></linearGradient>
              <linearGradient id="ray-i-sticky" x1="0%" y1="0%" x2="100%" y2="0%"><stop offset="0%" stop-color="#a3bc7e" stop-opacity="1"/><stop offset="100%" stop-color="#a3bc7e" stop-opacity="0.45"/></linearGradient>
              <linearGradient id="ray-s-sticky" x1="0%" y1="0%" x2="100%" y2="0%"><stop offset="0%" stop-color="#86a8c9" stop-opacity="1"/><stop offset="100%" stop-color="#86a8c9" stop-opacity="0.45"/></linearGradient>
              <linearGradient id="ray-m-sticky" x1="0%" y1="0%" x2="100%" y2="0%"><stop offset="0%" stop-color="#a583b5" stop-opacity="1"/><stop offset="100%" stop-color="#a583b5" stop-opacity="0.45"/></linearGradient>
              <linearGradient id="prism-glass-sticky" x1="0%" y1="0%" x2="100%" y2="100%">
                <stop offset="0%"   stop-color="#d4756f" stop-opacity="0.65"/>
                <stop offset="25%"  stop-color="#f5d589" stop-opacity="0.65"/>
                <stop offset="50%"  stop-color="#a3bc7e" stop-opacity="0.65"/>
                <stop offset="75%"  stop-color="#86a8c9" stop-opacity="0.65"/>
                <stop offset="100%" stop-color="#a583b5" stop-opacity="0.65"/>
              </linearGradient>
              <filter id="ray-glow-sticky" x="-20%" y="-50%" width="140%" height="200%">
                <feGaussianBlur in="SourceGraphic" stdDeviation="2" result="b"/>
                <feMerge><feMergeNode in="b"/><feMergeNode in="SourceGraphic"/></feMerge>
              </filter>
            </defs>
 
            <text x="32" y="80" text-anchor="end" class="raw-label">RAW</text>
            <text x="32" y="92" text-anchor="end" class="raw-label">STORY</text>
            <line x1="36" y1="87" x2="48" y2="87" stroke="url(#incoming-sticky)" stroke-width="2.5"/>
            <polygon points="50,50 50,124 76,87" fill="url(#prism-glass-sticky)" stroke="#ffffff" stroke-opacity="0.4" stroke-width="1.2"/>
 
            <!-- Each ray has its own id so JS can toggle "active" class -->
            <g class="rays-group">
              <polygon class="ray ray-p" data-phase="p" filter="url(#ray-glow-sticky)" points="76,87 240,15 240,28" fill="url(#ray-p-sticky)"/>
              <polygon class="ray ray-r" data-phase="r" filter="url(#ray-glow-sticky)" points="76,87 240,50 240,63" fill="url(#ray-r-sticky)"/>
              <polygon class="ray ray-i" data-phase="i" filter="url(#ray-glow-sticky)" points="76,87 240,82 240,95" fill="url(#ray-i-sticky)"/>
              <polygon class="ray ray-s" data-phase="s" filter="url(#ray-glow-sticky)" points="76,87 240,114 240,127" fill="url(#ray-s-sticky)"/>
              <polygon class="ray ray-m" data-phase="m" filter="url(#ray-glow-sticky)" points="76,87 240,146 240,159" fill="url(#ray-m-sticky)"/>
            </g>
 
            <g class="prism-cap-letters">
              <text class="cap-letter" data-phase="p" x="260" y="27" text-anchor="middle" fill="#d4756f">P</text>
              <text class="cap-letter" data-phase="r" x="260" y="60" text-anchor="middle" fill="#f5d589">R</text>
              <text class="cap-letter" data-phase="i" x="260" y="93" text-anchor="middle" fill="#a3bc7e">I</text>
              <text class="cap-letter" data-phase="s" x="260" y="124" text-anchor="middle" fill="#86a8c9">S</text>
              <text class="cap-letter" data-phase="m" x="260" y="158" text-anchor="middle" fill="#a583b5">M</text>
            </g>
          </svg>
        </div>
      </div>
 
      <!-- Phase deep-dives (right column on desktop, observed by IntersectionObserver) -->
      <div class="phase-stack">
        {phases.map((phase) => (
          <article
            class="phase-block"
            data-phase={phase.letter.toLowerCase()}
            style={`--phase-color: ${phase.colorHex};`}
          >
            <div class="phase-letter-large" style={`color: ${phase.colorHex};`}>{phase.letter}</div>
            <h3 class="phase-name-large" style={`color: ${phase.colorHex};`}>{phase.name}</h3>
            <p class="phase-subtitle-large">{phase.subtitle}</p>
            <p class="phase-desc-large">{phase.description}</p>
          </article>
        ))}
      </div>
    </section>
 
    <!-- ============================================
         SECTION CTA — Mobile only (anchor link to Science section)
         ============================================ -->
    <div class="section-cta-wrapper">
      <a href="#science" class="section-cta">
        <span>THE SCIENCE BEHIND PRISM</span>
        <span class="cta-arrow">↓</span>
      </a>
    </div>
 
    <!-- ============================================
         WE ENGINEER INFLUENCE — Science section
         ============================================ -->
    <section class="science-section" id="science">
      <div class="science-eyebrow-wrapper">
        <span class="science-eyebrow-rule"></span>
        <p class="eyebrow science-eyebrow">The Science</p>
        <span class="science-eyebrow-rule"></span>
      </div>
 
      <h2 class="science-headline">
        <span class="science-headline-stories">STORIES</span>
        <span class="science-headline-engineer">ENGINEER</span>
        <span class="science-headline-influence">INFLUENCE.</span>
      </h2>
 
      <p class="science-subtitle">
        Story is the only evolutionary technology proven to synchronize the brain, bypass logic, and compel action. <span class="prism-multicolor"><span style="color:#d4756f">P</span><span style="color:#f5d589">R</span><span style="color:#a3bc7e">I</span><span style="color:#86a8c9">S</span><span style="color:#a583b5">M</span></span> is the architecture for harnessing these biological levers.
      </p>
 
      <div class="science-cards">
        <article class="science-card">
          <div class="science-card-icon" aria-hidden="true">
            <svg viewBox="0 0 60 60" fill="none">
              <circle cx="30" cy="30" r="8" stroke="currentColor" stroke-width="2" fill="none"/>
              <line x1="30" y1="22" x2="30" y2="10" stroke="currentColor" stroke-width="2"/>
              <line x1="30" y1="38" x2="30" y2="50" stroke="currentColor" stroke-width="2"/>
              <line x1="38" y1="30" x2="50" y2="30" stroke="currentColor" stroke-width="2"/>
              <line x1="22" y1="30" x2="10" y2="30" stroke="currentColor" stroke-width="2"/>
              <line x1="36" y1="36" x2="45" y2="45" stroke="currentColor" stroke-width="2"/>
              <line x1="24" y1="24" x2="15" y2="15" stroke="currentColor" stroke-width="2"/>
            </svg>
          </div>
          <h3 class="science-card-title">The Attention Hack</h3>
          <p class="science-card-subtitle">(Cortisol)</p>
          <p class="science-card-body">
            The brain is wired to ignore the predictable. It craves conflict. A narrative structured around high-stakes tension triggers a biological response — focus, in a distracted world. The work doesn't ask for attention; it seizes it.
          </p>
        </article>
 
        <article class="science-card">
          <div class="science-card-icon" aria-hidden="true">
            <svg viewBox="0 0 60 60" fill="none">
              <path d="M5 30 L15 20 L25 35 L35 15 L45 40 L55 30" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M5 30 L15 25 L25 32 L35 20 L45 38 L55 30" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round" opacity="0.5"/>
            </svg>
          </div>
          <h3 class="science-card-title">The Empathy Engine</h3>
          <p class="science-card-subtitle">(Oxytocin)</p>
          <p class="science-card-body">
            Facts inform, but stories connect. When an audience identifies with a character's struggle, their brain releases oxytocin — the "trust molecule." This bridges the gap between your brand and your audience, turning skepticism into solidarity.
          </p>
        </article>
 
        <article class="science-card">
          <div class="science-card-icon" aria-hidden="true">
            <svg viewBox="0 0 60 60" fill="none">
              <circle cx="30" cy="30" r="4" fill="currentColor"/>
              <circle cx="30" cy="30" r="12" stroke="currentColor" stroke-width="2" fill="none" opacity="0.6"/>
              <circle cx="30" cy="30" r="20" stroke="currentColor" stroke-width="2" fill="none" opacity="0.3"/>
            </svg>
          </div>
          <h3 class="science-card-title">The Action Protocol</h3>
          <p class="science-card-subtitle">(Narrative Transportation)</p>
          <p class="science-card-body">
            When a story is architected correctly, the viewer enters a state of "Narrative Transportation." They cease to be an observer and become a participant. In this state, beliefs are malleable, and the impulse to act becomes internal, not external.
          </p>
        </article>
      </div>
    </section>
 
    <!-- ============================================
         FINAL CTA
         ============================================ -->
    <section class="final-cta">
      <h2 class="final-cta-headline">Let's build your story.</h2>
      <p class="final-cta-tagline">Five Emmys. National Addys. TED-honored work in 20+ countries.</p>
      <a href="/contact/" class="btn btn-primary final-cta-btn">Start a Conversation</a>
    </section>
 
  </main>
</BaseLayout>
 
<style>
  /* ============================================
     PAGE FOUNDATION
     ============================================ */
  .process-page {
    background: var(--color-bg-deep);
    min-height: 100vh;
    padding-top: 6rem;
    padding-bottom: 6rem;
  }
 
  .raw-label {
    font-family: var(--font-sans);
    font-size: 7px;
    font-weight: 600;
    fill: rgba(255, 255, 255, 0.55);
    letter-spacing: 0.2em;
    text-transform: uppercase;
  }
 
  .prism-cap-letters text,
  .cap-letter {
    font-family: var(--font-sans);
    font-size: 16px;
    font-weight: 400;
    transition: opacity 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }
 
  .prism-multicolor {
    font-weight: 300;
    letter-spacing: 0.02em;
  }
 
  /* ============================================
     HERO SECTION
     ============================================ */
  .process-hero {
    max-width: 760px;
    margin: 0 auto 4rem;
    padding: 0 2rem;
    text-align: center;
  }
 
  .process-headline {
    font-family: var(--font-sans);
    font-size: clamp(1.5rem, 5vw, 3rem);
    font-weight: 300;
    line-height: 1.1;
    letter-spacing: -0.025em;
    margin: 1.25rem 0 1rem;
  }
 
  .process-subtitle {
    font-family: var(--font-sans);
    font-size: clamp(0.95rem, 1.6vw, 1.25rem);
    font-style: italic;
    font-weight: 300;
    color: var(--color-accent);
    margin: 0 0 2rem;
    letter-spacing: -0.01em;
  }
 
  .process-intro {
    font-size: clamp(0.9rem, 1.3vw, 1.05rem);
    line-height: 1.75;
    color: var(--color-text-muted);
    margin: 0 auto 3rem;
    max-width: 600px;
    font-weight: 300;
  }
 
  .hero-prism {
    max-width: 560px;
    margin: 0 auto;
  }
 
  .prism-svg {
    width: 100%;
    height: auto;
    display: block;
  }
 
  /* ============================================
     MOBILE STACKED PHASE CARDS
     ============================================ */
  .phases-mobile {
    max-width: 600px;
    margin: 0 auto;
    padding: 0 2rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
 
  .phase-card-mobile {
    display: flex;
    gap: 1rem;
    align-items: center;
    padding: 1.25rem;
    background: color-mix(in srgb, var(--phase-color, var(--color-accent)) 7%, transparent);
    border: 1px solid color-mix(in srgb, var(--phase-color, var(--color-accent)) 35%, transparent);
    border-radius: 3px;
    transition: all 0.3s ease;
  }
 
  .phase-card-mobile:hover {
    background: color-mix(in srgb, var(--phase-color, var(--color-accent)) 12%, transparent);
    border-color: color-mix(in srgb, var(--phase-color, var(--color-accent)) 55%, transparent);
  }
 
  .phase-letter-mobile {
    font-family: var(--font-sans);
    font-size: 2.25rem;
    font-weight: 300;
    line-height: 1;
    flex-shrink: 0;
    width: 2.5rem;
    text-align: center;
  }
 
  .phase-text-mobile {
    flex: 1;
  }
 
  .phase-name-mobile {
    font-family: var(--font-sans);
    font-size: 0.9rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    margin: 0 0 0.25rem;
    line-height: 1;
  }
 
  .phase-subtitle-mobile {
    font-family: var(--font-sans);
    font-style: italic;
    font-weight: 300;
    font-size: 0.85rem;
    color: var(--color-text-muted);
    margin: 0 0 0.25rem;
    line-height: 1.3;
  }
 
  .phase-desc-mobile {
    font-family: var(--font-sans);
    font-size: 0.8rem;
    font-weight: 300;
    color: var(--color-text-subtle);
    margin: 0;
    line-height: 1.5;
  }
 
  /* ============================================
     DESKTOP STICKY-PRISM SECTION (hidden by default, shown at breakpoint)
     ============================================ */
  .phases-desktop {
    display: none;
  }
 
  /* ============================================
     SECTION CTA (anchor link to Science section)
     ============================================ */
  .section-cta-wrapper {
    text-align: center;
    margin: 4rem auto 3rem;
    padding: 0 2rem;
  }
 
  .section-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.9rem 1.5rem;
    background: color-mix(in srgb, var(--color-accent) 10%, transparent);
    border: 1px solid var(--color-accent);
    border-radius: 2px;
    color: var(--color-accent);
    font-family: var(--font-wordmark);
    font-size: 0.78rem;
    font-weight: 400;
    letter-spacing: 0.15em;
    text-decoration: none;
    text-transform: uppercase;
    transition: all 0.3s ease;
    max-width: 280px;
  }
 
  .section-cta:hover {
    background: color-mix(in srgb, var(--color-accent) 20%, transparent);
  }
 
  .cta-arrow {
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 0.95rem;
    letter-spacing: 0;
  }
 
  /* ============================================
     SCIENCE SECTION
     ============================================ */
  .science-section {
    max-width: 1100px;
    margin: 5rem auto 4rem;
    padding: 0 2rem;
    text-align: center;
    scroll-margin-top: 100px;
  }
 
  .science-eyebrow-wrapper {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    margin-bottom: 2rem;
  }
 
  .science-eyebrow-rule {
    display: block;
    width: 50px;
    height: 1px;
    background: color-mix(in srgb, var(--color-accent) 40%, transparent);
  }
 
  .science-eyebrow {
    margin: 0;
  }
 
  .science-headline {
    font-family: var(--font-wordmark);
    font-size: clamp(1.75rem, 5vw, 3.25rem);
    line-height: 1.05;
    margin: 0 0 2rem;
    letter-spacing: 0.04em;
  }
 
  .science-headline-stories {
    color: rgba(255, 255, 255, 0.75);
    margin-right: 0.4em;
  }
 
  .science-headline-engineer {
    color: var(--color-text);
    margin-right: 0.4em;
  }
 
  .science-headline-influence {
