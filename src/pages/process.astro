<script is:inline>
  /* Desktop sticky-prism scroll interaction
     Watches each .phase-block; when it's near viewport center, brightens the matching ray. */
  (function () {
    function initStickyPrism() {
      // Only run if the desktop section is actually rendered (CSS media query controls visibility)
      var phasesDesktop = document.getElementById('phasesDesktop');
      if (!phasesDesktop) return;
 
      // Skip on small screens; the desktop interaction is irrelevant there
      if (window.innerWidth < 992) return;
 
      var rays = phasesDesktop.querySelectorAll('.ray');
      var capLetters = phasesDesktop.querySelectorAll('.cap-letter');
      var phaseBlocks = phasesDesktop.querySelectorAll('.phase-block');
 
      if (!rays.length || !phaseBlocks.length) {
        console.warn('[Process] sticky prism: rays or phase blocks missing');
        return;
      }
 
      function setActivePhase(phase) {
        for (var i = 0; i < rays.length; i++) {
          if (rays[i].getAttribute('data-phase') === phase) {
            rays[i].classList.remove('dimmed');
          } else {
            rays[i].classList.add('dimmed');
          }
        }
        for (var j = 0; j < capLetters.length; j++) {
          if (capLetters[j].getAttribute('data-phase') === phase) {
            capLetters[j].classList.remove('dimmed');
          } else {
            capLetters[j].classList.add('dimmed');
          }
        }
      }
 
      function clearActive() {
        for (var i = 0; i < rays.length; i++) rays[i].classList.remove('dimmed');
        for (var j = 0; j < capLetters.length; j++) capLetters[j].classList.remove('dimmed');
      }
 
      // Use IntersectionObserver to detect which phase block is closest to viewport center
      var observer = new IntersectionObserver(function (entries) {
        entries.forEach(function (entry) {
          if (entry.isIntersecting && entry.intersectionRatio > 0.5) {
            var phase = entry.target.getAttribute('data-phase');
            if (phase) setActivePhase(phase);
          }
        });
      }, {
        // Trigger when block is centered in viewport (40% top margin, 40% bottom = 20% sensitive band)
        rootMargin: '-40% 0px -40% 0px',
        threshold: [0, 0.51, 1]
      });
 
      for (var i = 0; i < phaseBlocks.length; i++) {
        observer.observe(phaseBlocks[i]);
      }
 
      // On resize past breakpoint, clear active state and let CSS take over
      window.addEventListener('resize', function () {
        if (window.innerWidth < 992) {
          clearActive();
        }
      });
 
      console.log('[Process] sticky prism initialized with', phaseBlocks.length, 'phase blocks');
    }
 
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initStickyPrism);
    } else {
      initStickyPrism();
    }
  })();
</script>
 
