---
import '../styles/global.css';

export interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'The Story Speaks | Emmy-Winning Storytelling, Rooted in the Rockies',
  description = 'The Story Speaks is an Emmy-winning film and video production company in Boulder, Colorado serving Denver, the Rockies and the world. Working with Fortune 500s, universities, hospitals, scientific institutions and brands.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />

    <!-- Open Graph / social -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Fjalla+One&family=Playfair+Display:ital,wght@0,400;1,400&display=swap" rel="stylesheet" />

    <title>{title}</title>
  </head>
---
import BrandMark from '../components/BrandMark.astro';
// ... any existing imports
---
<!-- inside <body>, before the <slot /> -->
  <body>
<nav class="site-nav">
  <div class="site-nav__inner">
    <BrandMark variant="on-dark" size="md" />
    <ul class="site-nav__links">
      <li><a href="/work/">Work</a></li>
      <li><a href="/about/">About</a></li>
      <li><a href="/contact/">Contact</a></li>
    </ul>
  </div>
</nav>
    <slot />
  </body>
</html>
